node_modules/
.scratch/
tokenization/
/release/

# Marp / build outputs
# (note: the four allow-listed locations below are intentionally
# tracked: examples/ ship-with-the-package demos, per-component +
# per-bucket galleries under lib/components/, per-integration
# galleries under lib/integrations/, and the CI baseline regression
# decks under test/integration/baseline-decks/. See
# engineering/workflow.md and CLAUDE.md. The rule below catches
# ad-hoc renders elsewhere in the tree.)
*.pptx
*.pdf
!examples/*.pdf
!exemplars/**/*.pdf
!lib/components/**/*.pdf
!lib/base/**/*.pdf
!lib/integrations/**/*.pdf
!test/integration/baseline-decks/*.pdf
!docs/*.pdf
!themes/*.pdf

# esbuild check tempfiles — produced next to the bundles by
# `npm run runtime:check` / `emulator:check`. The scripts clean up on
# success/failure; these catch the killed-mid-build case.
dist/lattice-runtime.js.check.tmp
dist/lattice-emulator.js.check.tmp

# Bucket-gallery build tempfiles — tools/build-bucket-galleries.js writes
# <bucket>.gallery.<theme>.tmp.md next to the source during render and
# normally deletes it; this catches the killed-mid-build case.
lib/components/**/*.gallery.*.tmp.md

# LibreOffice lock files
.~lock.*#

# macOS
.DS_Store

# Python bytecode (design/logo/generate.py)
__pycache__/
*.pyc

examples/*.html
examples/**/*.html
examples/*.notes.txt
lib/components/**/*.html
test/integration/**/*.html
!examples/*.pdf
!examples/**/*.pdf
!exemplars/**/*.pdf
!lib/components/**/*.pdf
!lib/base/**/*.pdf

# Regression-gate fresh-render tempfiles — tools/regression-gate.mjs renders
# each candidate into the gallery's OWN dir (so relative assets resolve) as a
# `.regr-*` dotfile and normally deletes it. This MUST sit after the
# `!lib/components/**/*.pdf` negations above, or that negation would force-track
# a `.regr-*.pdf` left behind by a killed-mid-run. Re-ignore the whole family.
lib/components/**/.regr-*
lib/base/**/.regr-*

# emulator render sidecars next to the palette-audit deck
themes/*.html

# Agent isolation worktrees (transient; auto-cleaned)
.claude/worktrees/
