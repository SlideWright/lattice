node_modules/
.scratch/
tokenization/

# Marp / build outputs
# (note: examples/*.pdf and lib/components/**/*.pdf are intentionally
# tracked as ship-with-the-package demos and per-component gallery
# decks — see docs/references/workflow.md and CLAUDE.md. The rule below
# catches ad-hoc renders elsewhere in the tree.)
*.pptx
*.pdf
!examples/*.pdf
!lib/components/**/*.pdf

# esbuild check tempfile — produced next to lattice-runtime.js by
# `npm run runtime:check`. The script cleans up on success/failure;
# this catches the case where the process was killed mid-build.
lattice-runtime.js.check.tmp

# LibreOffice lock files
.~lock.*#

# macOS
.DS_Store

examples/*.html
examples/**/*.html
lib/components/**/*.html
!examples/*.pdf
!examples/**/*.pdf
!lib/components/**/*.pdf
