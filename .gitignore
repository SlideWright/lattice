node_modules/
.scratch/
tokenization/

# Marp / build outputs
# (note: the four allow-listed locations below are intentionally
# tracked: examples/ ship-with-the-package demos, per-component +
# per-bucket galleries under lib/components/, per-integration
# galleries under lib/integrations/, and the CI baseline regression
# decks under test/integration/baseline-decks/. See
# docs/references/workflow.md and CLAUDE.md. The rule below catches
# ad-hoc renders elsewhere in the tree.)
*.pptx
*.pdf
!examples/*.pdf
!lib/components/**/*.pdf
!lib/base/**/*.pdf
!lib/integrations/**/*.pdf
!test/integration/baseline-decks/*.pdf
!docs/*.pdf
!themes/*.pdf

# esbuild check tempfile — produced next to lattice-runtime.js by
# `npm run runtime:check`. The script cleans up on success/failure;
# this catches the case where the process was killed mid-build.
lattice-runtime.js.check.tmp

# LibreOffice lock files
.~lock.*#

# macOS
.DS_Store

examples/*.html
examples/**/*.html
lib/components/**/*.html
test/integration/**/*.html
!examples/*.pdf
!examples/**/*.pdf
!lib/components/**/*.pdf
!lib/base/**/*.pdf
