{
  "doneMeansMerged": true,
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git fetch*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git rebase*)",
      "Bash(git push*)",
      "Bash(git pull*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git stash*)",
      "Bash(git merge*)",
      "Bash(git rev-parse*)",
      "Bash(git rev-list*)",
      "Bash(npm run lint*)",
      "Bash(npm test*)",
      "Bash(npm run test:*)",
      "Bash(npm run build*)",
      "Bash(npm run check:*)",
      "Bash(npm run preview*)",
      "Bash(npm run lint:deck*)",
      "Bash(node tools/*)",
      "Bash(npx marp*)",
      "Bash(marp*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-rebase-check.sh"
          }
        ]
      }
    ]
  }
}
