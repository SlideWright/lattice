---
// Per-component documentation, rendered from the manifest (the single source
// of truth) — the same fields the components.md reference and components.json
// catalog draw from, so the page never drifts from them. Anatomy ASCII is
// resolved from the canonical catalog (tools/anatomy-catalog.js) by the page
// and passed in.
//
// Props:
//   m            manifest object
//   anatomy      string|null  — resolved ASCII anatomy block
//   nameToBucket Record<string,string>  — for related-component links
const { m, anatomy = null, nameToBucket = {} } = Astro.props;

const base = import.meta.env.BASE_URL;
const url = (p) => `${base}/${p}`.replace(/([^:])\/{2,}/g, '$1/');

const esc = (s) =>
	String(s)
		.replace(/&/g, '&amp;')
		.replace(/</g, '&lt;')
		.replace(/>/g, '&gt;')
		.replace(/"/g, '&quot;');

// The small inline-Markdown subset the manifest prose uses (`code`, **bold**).
const inline = (s) =>
	esc(s)
		.replace(/`([^`]+)`/g, (_m, c) => `<code>${c}</code>`)
		.replace(/\*\*([^*]+)\*\*/g, (_m, b) => `<strong>${b}</strong>`);

const tags = Array.isArray(m.tags) ? m.tags : [];
const whenToUse = Array.isArray(m.whenToUse) ? m.whenToUse : [];
const antiPatterns = Array.isArray(m.antiPatterns) ? m.antiPatterns : [];
const slots = m.slots && Object.keys(m.slots).length ? Object.entries(m.slots) : [];
const variantDocs = m.variantDocs || {};
const variantKeys = Array.isArray(m.variants) ? m.variants.filter((v) => variantDocs[v]) : [];
const related = Array.isArray(m.related) ? m.related : [];
const skeleton = (m.skeleton || '').replace(/\n$/, '');
---

<div class="cdocs">
	{m.purpose && <p class="cdocs-purpose" set:html={inline(m.purpose)} />}

	{tags.length > 0 && (
		<div class="cdocs-tags">
			{tags.map((t) => <span class="cdocs-tag">{t}</span>)}
		</div>
	)}

	{whenToUse.length > 0 && (
		<section class="cdocs-guidance use">
			<h2>When to use</h2>
			<ul>
				{whenToUse.map((it) => (
					<li set:html={`<strong>${inline(it.title)}.</strong> ${inline(it.body)}`} />
				))}
			</ul>
		</section>
	)}

	{antiPatterns.length > 0 && (
		<section class="cdocs-guidance avoid">
			<h2>When not to use</h2>
			<ul>
				{antiPatterns.map((it) => (
					<li set:html={`<strong>${inline(it.title)}.</strong> ${inline(it.body)}`} />
				))}
			</ul>
		</section>
	)}

	<section class="cdocs-authoring">
		<h2>Authoring</h2>
		<pre class="cdocs-code"><code set:html={esc(skeleton)} /></pre>
	</section>

	{slots.length > 0 && (
		<section class="cdocs-slots">
			<h2>Slots</h2>
			<table>
				<thead>
					<tr><th>Slot</th><th>Selector</th><th>Required</th><th>Description</th></tr>
				</thead>
				<tbody>
					{slots.map(([name, slot]) => (
						<tr>
							<td><code>{name}</code></td>
							<td><code>{slot.selector}</code></td>
							<td>
								<span class={`cdocs-req ${slot.required ? 'yes' : 'no'}`}>{slot.required ? 'yes' : 'no'}</span>
							</td>
							<td set:html={inline(slot.description)} />
						</tr>
					))}
				</tbody>
			</table>
		</section>
	)}

	{anatomy && (
		<section class="cdocs-anatomy">
			<h2>Anatomy</h2>
			<pre class="cdocs-ascii"><code set:html={esc(anatomy)} /></pre>
		</section>
	)}

	{variantKeys.length > 0 && (
		<section class="cdocs-variants">
			<h2>Variants</h2>
			{variantKeys.map((v) => {
				const vd = variantDocs[v];
				return (
					<div class="cdocs-variant">
						<h3>
							<code>{v}</code>
							{vd.label && <span class="cdocs-variant-label"> — {vd.label}</span>}
						</h3>
						<p set:html={inline(vd.caption)} />
						<pre class="cdocs-code"><code set:html={esc((vd.sample || '').replace(/\n$/, ''))} /></pre>
					</div>
				);
			})}
		</section>
	)}

	{related.length > 0 && (
		<section class="cdocs-related">
			<h2>Related</h2>
			<ul class="cdocs-related-list">
				{related.map((r) => {
					const b = nameToBucket[r.name];
					return (
						<li>
							{b ? (
								<a class="cdocs-chip" href={url(`components/${b}/${r.name}/`)}>{r.name}</a>
							) : (
								<span class="cdocs-chip">{r.name}</span>
							)}
							<span class="cdocs-related-when" set:html={inline(r.when)} />
						</li>
					);
				})}
			</ul>
		</section>
	)}
</div>
