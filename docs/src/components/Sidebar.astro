---
// Override of Starlight's Sidebar. Identical to the default (persisted
// docs-section tree + the mobile preferences footer) but prepends a "Site"
// nav group carrying the full set of site destinations — Home, the guides,
// the interactive tools, Workbench, Components, GitHub.
//
// That group is hidden on desktop (the header nav carries it) and revealed
// only inside the mobile hamburger menu, so a reader on a phone/tablet can
// always get back to the landing page or jump anywhere on the site — the
// complaint that the logo was the only way out. Styling: lattice.css
// (.lx-sitenav). Default Sidebar: @astrojs/starlight/components/Sidebar.astro.
import MobileMenuFooter from 'virtual:starlight/components/MobileMenuFooter';
import SidebarPersister from '@astrojs/starlight/components/SidebarPersister.astro';
import SidebarSublist from '@astrojs/starlight/components/SidebarSublist.astro';
import { joinBase } from '../lib/base-url.mjs';

const { sidebar } = Astro.locals.starlightRoute;

const base = import.meta.env.BASE_URL;
const url = (p) => joinBase(base, p);
const here = Astro.url.pathname;
const links = [
	{ label: 'Home', href: url('') },
	{ label: 'Get started', href: url('getting-started/'), seg: 'getting-started' },
	{ label: 'Guides', href: url('guides/authoring/'), seg: 'guides' },
	{ label: 'Playground', href: url('playground/'), seg: 'playground' },
	{ label: 'Drawing Board', href: url('drawing-board/'), seg: 'drawing-board' },
	{ label: 'Workbench', href: url('workbench/'), seg: 'workbench' },
	{ label: 'Components', href: url('components/'), seg: 'components' },
];
const isCurrent = (seg) => seg && here.includes('/' + seg);
---

<nav class="lx-sitenav" aria-label="Site">
	<ul>
		{
			links.map((l) => (
				<li>
					<a href={l.href} aria-current={isCurrent(l.seg) ? 'page' : undefined}>
						{l.label}
					</a>
				</li>
			))
		}
		<li><a href="https://github.com/slidewright/lattice">GitHub</a></li>
	</ul>
</nav>

<SidebarPersister>
	<SidebarSublist sublist={sidebar} />
</SidebarPersister>

<div class="md:sl-hidden">
	<MobileMenuFooter />
</div>
