---
// Override of Starlight's header. Renders the ONE shared <SiteHeader> — the
// exact same top bar the standalone routes carry — so the docs zone reads as
// part of one website, not a bolted-on subsite. The header is no longer
// re-implemented here; SiteHeader owns the brand, nav, Tools disclosure, the
// universal ⌘K command palette (which replaced the standalone Starlight search
// pill — search is now uniform everywhere via Pagefind), and the theme
// controls.
//
// standalone={false}: Starlight's own .header already provides the sticky
// wrapper, so SiteHeader renders just the inner bar into it.
// mobileMenu={false}: Starlight owns the mobile menu here because it also
// carries the page TOC; the global nav still lives at the top of that menu
// (Sidebar.astro) so narrow viewports never dead-end at the logo.
// Styling: SiteHeader's co-located styles + docs/src/styles/lattice.css.
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import SiteHeader from './site/SiteHeader.astro';
import EngineWarm from './site/EngineWarm.astro';
import PerfOverlay from './site/PerfOverlay.astro';

// Same derivation the component portal uses: the palette names ARE the
// data-palette keys in the generated token file (indaco first → default).
const tokensCss = readFileSync(join(process.cwd(), 'src/styles/lattice-tokens.generated.css'), 'utf8');
const palettes = [...new Set([...tokensCss.matchAll(/data-palette="([^"]+)"/g)].map((x) => x[1]))];
---

<SiteHeader palettes={palettes} wide={true} standalone={false} mobileMenu={false} />

{/* Intent-gated engine warming on the docs pages: hovering/focusing an app
    link in the topbar warms the render bundle a beat before the jump.
    See src/lib/prefetch-engine.ts. */}
<EngineWarm />

{/* Live Core-Web-Vitals overlay on the docs zone, gated behind ?perf. */}
<PerfOverlay />
