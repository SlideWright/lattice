---
// Shared global topbar for the landing-styled standalone routes (landing,
// playground, component pages). Renders the brand, the global nav, and the
// palette / light-dark controls. The palette + mode controls are the shared
// <PaletteControls> island (src/components/site/), which owns the
// data-palette/data-mode writes via site-chrome.ts; the remaining ids
// (#nav-toggle, #topnav) are wired by each page's controller (or, for the
// component pages, by ComponentsLayout). `current` drives aria-current so
// "you are here" is true in the header.
//
// Props:
//   palettes  string[]  — selectable palette names (titleCased for display)
//   current   string?   — 'getting-started' | 'guides' | 'playground' | 'components'
//   wide      boolean   — full-bleed inner (playground/components) vs centered (landing)
// `current` is accepted for back-compat but no longer needed — aria-current is
// derived from the request path (isCurrent), so it's uniform across surfaces.
const { palettes = [], wide = false } = Astro.props;

import PaletteControls from './site/PaletteControls.tsx';
import { joinBase } from '../lib/base-url.mjs';
import { primaryNav, GITHUB_URL, isCurrent } from '../lib/nav.mjs';
const base = import.meta.env.BASE_URL;
const url = (p) => joinBase(base, p);

// Single source of truth (src/lib/nav.mjs) — same links on every surface.
const links = primaryNav(url);
const here = Astro.url.pathname;
---

<header class="topbar">
	<div class="wrap topbar-inner" style={wide ? 'max-width:none' : undefined}>
		<a class="brand" href={url('')}>
			<img class="brand-logo" src={url('lattice-mark-min.svg')} alt="" width="30" height="30" />
			<span class="brand-mark">Lattice</span>
		</a>
		<nav class="topnav" id="topnav">
			{links.map((l) => (
				<a class="navlink" href={l.href} aria-current={isCurrent(l, here) ? 'page' : undefined}>{l.label}</a>
			))}
			<a class="navlink" href={GITHUB_URL}>GitHub</a>
		</nav>
		<div class="topbar-actions">
			<div class="controls lx-ui">
				<PaletteControls client:idle palettes={palettes} />
			</div>
			<button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu" aria-controls="topnav" aria-expanded="false"></button>
		</div>
	</div>
</header>
