---
// Left navigation for the component reference — now a React island
// (ComponentNavIsland): fuzzy search + a "Group by" select over a grouped
// component tree, sharing one store with the index grid so search/regroup
// drive both. Highlights the current component. Replaces the vanilla
// component-browser.js nav rendering.
//
// Props:
//   catalog  built by lib/families.buildCatalog()
//   lenses   buildLenses() — for the Group by select options
//   current  string|null — active component name
import ComponentNavIsland from './components-ref/ComponentNavIsland.tsx';
const { catalog = [], lenses = [], current = null } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!-- client:visible (with a rootMargin so the above-fold sidebar still hydrates
     promptly): the nav is SSR'd and immediately usable as static markup; its
     fuzzy-search/regroup interactivity hydrates as it nears the viewport,
     deferring its JS off the critical path so the page's LCP isn't blocked. -->
<ComponentNavIsland client:visible={{ rootMargin: '600px' }} catalog={catalog} lenses={lenses} base={base} current={current} />
