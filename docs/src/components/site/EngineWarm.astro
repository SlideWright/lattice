---
// Drops the connection-first engine-bundle warming onto a page. Computes the
// SAME content-hashed `lattice-playground.js` URL the app pages load (so the
// prefetch and the eventual <script> share one cache entry), serialises it for
// the client, and hands it to warmEngine (src/lib/prefetch-engine.ts), which
// owns the eager/intent/off decision.
//
//   • allowEager — pass `true` only on the landing funnel (the highest-intent
//     entry point); every other surface (docs Header, comparison, the
//     component reference) leaves it false so warming is intent-gated: it fires
//     only when a pointer/focus/touch reaches for an app link. App pages
//     (playground/drawing-board/workbench) load the engine directly, so they
//     don't render this.
import { assetBase } from '../../playground/asset-version.mjs';
import { joinBase } from '../../lib/base-url.mjs';

interface Props {
	allowEager?: boolean;
}
const { allowEager = false } = Astro.props;

const base = import.meta.env.BASE_URL;
const engineUrl = joinBase(base, assetBase() + 'lattice-playground.js');
---

<script type="application/json" data-engine-warm set:html={JSON.stringify({ engineUrl, allowEager })}></script>
<script>
	import { warmEngine } from '../../lib/prefetch-engine.ts';
	const el = document.querySelector('script[data-engine-warm]');
	if (el?.textContent) {
		const { engineUrl, allowEager } = JSON.parse(el.textContent);
		warmEngine(engineUrl, { allowEager });
	}
</script>
