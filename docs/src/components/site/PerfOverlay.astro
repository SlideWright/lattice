---
// Live performance overlay — a draggable on-screen readout in two groups:
//   • WEB VITALS (page-load, one-shot): LCP / CLS / INP / FCP / TTFB, from
//     Google's `web-vitals`, colour-rated by its thresholds.
//   • RUNTIME (continuous, live while shown): FPS (requestAnimationFrame), MEM
//     (`performance.memory` JS-heap used, Chrome-only — row hidden elsewhere),
//     and CPU≈ — main-thread busy % from the Long Tasks API. NB browsers expose
//     no true CPU-usage API; CPU≈ is that main-thread proxy, hence the ≈, and
//     the row is hidden where Long Tasks is unsupported.
//
// All measured by the visitor's OWN browser. The point is real-device numbers:
// the repo's perf gating (engineering/decisions/2026-06-15-docs-perf-gating-
// policy.md §"Open human step") defers the landing-CLS / mobile-LCP question to
// real hardware because CI/sandbox can't load the CDN fonts and so never
// reproduces the font-swap reflow. This closes that gap with zero tooling.
//
// On/off is a shared, cross-surface preference (perf-overlay-prefs.js, mirroring
// tour-prefs.js) so it can be flipped two ways:
//   • the "Performance overlay" switch in the Drawing Board settings drawer
//     (governs every page, like the Guided-tours switch), and
//   • a `?perf` URL param (`?perf` on, `?perf=off` off) — the phone-friendly
//     entry that doesn't need the settings drawer. The param just writes the
//     pref. Tap × on the overlay to turn it off; the grip (⠿) on the header
//     marks it as draggable — drag to reposition (persisted).
//
// `web-vitals` is dynamically imported ONLY once the overlay is shown, and the
// runtime loops run ONLY while it's mounted, so a normal page view pays nothing.
// Availability is GA-gated in perf-overlay-prefs.js.
//
// Included once per page via ResourceHints (standalone routes), Header (docs
// zone) and features.astro (uses neither); a window guard makes a double-include
// a no-op.
---

<script>
	import {
		PERF_OVERLAY_AVAILABLE,
		onPerfOverlayEnabledChange,
		perfOverlayEnabled,
		setPerfOverlayEnabled,
	} from '../../playground/perf-overlay-prefs.js';

	if (PERF_OVERLAY_AVAILABLE && !window.__latticePerfOverlay) {
		window.__latticePerfOverlay = true;

		const POS_KEY = 'lattice-perf-overlay-pos';
		const RATING_COLOR = { good: '#16a34a', 'needs-improvement': '#d97706', poor: '#dc2626' };
		const GREY = '#52525b';
		// WEB-VITALS rows: [name, value formatter, unit]; array order is render order.
		const METRICS = [
			['LCP', (v) => Math.round(v), 'ms'],
			['CLS', (v) => v.toFixed(3), ''],
			['INP', (v) => Math.round(v), 'ms'],
			['FCP', (v) => Math.round(v), 'ms'],
			['TTFB', (v) => Math.round(v), 'ms'],
		];
		// RUNTIME rows are conditional on the platform exposing the API.
		const hasMem = typeof performance !== 'undefined' && !!performance.memory;
		const hasLongTasks = (() => {
			try {
				return PerformanceObserver.supportedEntryTypes.includes('longtask');
			} catch {
				return false;
			}
		})();
		const valHTML = (v, unit) => `${v}${unit ? `<span class="pf-unit">${unit}</span>` : ''}`;

		let host = null; // the overlay element, or null when hidden
		const refs = {}; // vital name → { val, dot }
		const rt = {}; // runtime key (FPS|MEM|CPU) → { val, dot }
		const cache = {}; // vital name → latest metric (survives unmount/remount)
		let vitalsStarted = false;

		// `?perf` / `?perf=off` writes the shared pref (no-op if absent).
		const params = new URLSearchParams(location.search);
		if (params.has('perf')) setPerfOverlayEnabled(params.get('perf') !== 'off');

		const paint = (m) => {
			const r = refs[m.name];
			if (!r) return;
			const def = METRICS.find(([n]) => n === m.name);
			r.val.innerHTML = valHTML(def[1](m.value), def[2]);
			r.dot.style.background = RATING_COLOR[m.rating] || GREY;
		};

		const startVitals = () => {
			if (vitalsStarted) return;
			vitalsStarted = true;
			import('web-vitals')
				.then(({ onLCP, onCLS, onINP, onFCP, onTTFB }) => {
					const opts = { reportAllChanges: true };
					const sink = (m) => {
						cache[m.name] = m;
						paint(m);
					};
					onLCP(sink, opts);
					onCLS(sink, opts);
					onINP(sink, opts);
					onFCP(sink, opts);
					onTTFB(sink, opts);
				})
				.catch(() => {
					if (host) host.querySelector('.pf-title').textContent = 'web vitals · failed to load';
				});
		};

		// ---- RUNTIME telemetry: live ONLY while mounted, fully torn down on hide ----
		let rafId = 0, memTimer = 0, cpuTimer = 0, ltObserver = null;
		let frames = 0, fpsLast = 0, blockedMs = 0;
		const setRT = (key, v, unit, rating) => {
			const r = rt[key];
			if (!r) return;
			r.val.innerHTML = valHTML(v, unit);
			r.dot.style.background = RATING_COLOR[rating] || GREY;
		};
		const startRuntime = () => {
			frames = 0;
			fpsLast = performance.now();
			const tick = (t) => {
				frames++;
				if (t - fpsLast >= 1000) {
					const fps = Math.round((frames * 1000) / (t - fpsLast));
					frames = 0;
					fpsLast = t;
					setRT('FPS', fps, 'fps', fps >= 50 ? 'good' : fps >= 30 ? 'needs-improvement' : 'poor');
				}
				rafId = requestAnimationFrame(tick);
			};
			rafId = requestAnimationFrame(tick);

			if (hasMem) {
				const sample = () => {
					const used = performance.memory.usedJSHeapSize / 1048576;
					const frac = performance.memory.usedJSHeapSize / performance.memory.jsHeapSizeLimit;
					setRT('MEM', Math.round(used), 'MB', frac <= 0.5 ? 'good' : frac <= 0.8 ? 'needs-improvement' : 'poor');
				};
				sample();
				memTimer = setInterval(sample, 1000);
			}

			if (hasLongTasks) {
				blockedMs = 0;
				try {
					ltObserver = new PerformanceObserver((list) => {
						for (const e of list.getEntries()) blockedMs += e.duration;
					});
					ltObserver.observe({ type: 'longtask', buffered: true });
				} catch {}
				cpuTimer = setInterval(() => {
					const pct = Math.min(100, Math.round((blockedMs / 1000) * 100));
					blockedMs = 0;
					setRT('CPU', pct, '%', pct <= 20 ? 'good' : pct <= 50 ? 'needs-improvement' : 'poor');
				}, 1000);
			}
		};
		const stopRuntime = () => {
			if (rafId) {
				cancelAnimationFrame(rafId);
				rafId = 0;
			}
			if (memTimer) {
				clearInterval(memTimer);
				memTimer = 0;
			}
			if (cpuTimer) {
				clearInterval(cpuTimer);
				cpuTimer = 0;
			}
			if (ltObserver) {
				try {
					ltObserver.disconnect();
				} catch {}
				ltObserver = null;
			}
		};

		// Drag the header to reposition; persists across pages. Pointer events
		// cover touch (touch-action:none on the header stops it scrolling). Move/up
		// listen on `document` for the duration of the drag, so it keeps tracking
		// even when the pointer leaves the small header (more reliable than
		// setPointerCapture across browsers).
		const makeDraggable = (el, handle) => {
			let sx = 0, sy = 0, ox = 0, oy = 0;
			const onMove = (e) => {
				const nx = Math.max(4, Math.min(ox + e.clientX - sx, innerWidth - el.offsetWidth - 4));
				const ny = Math.max(4, Math.min(oy + e.clientY - sy, innerHeight - el.offsetHeight - 4));
				el.style.left = `${nx}px`;
				el.style.top = `${ny}px`;
			};
			const onUp = () => {
				handle.style.cursor = 'grab';
				document.removeEventListener('pointermove', onMove);
				try {
					localStorage.setItem(POS_KEY, JSON.stringify({ x: parseFloat(el.style.left), y: parseFloat(el.style.top) }));
				} catch {}
			};
			handle.addEventListener('pointerdown', (e) => {
				if (e.target.closest('.pf-close')) return;
				const r = el.getBoundingClientRect();
				ox = r.left;
				oy = r.top;
				sx = e.clientX;
				sy = e.clientY;
				el.style.left = `${ox}px`;
				el.style.top = `${oy}px`;
				el.style.right = 'auto';
				el.style.bottom = 'auto';
				handle.style.cursor = 'grabbing';
				document.addEventListener('pointermove', onMove);
				document.addEventListener('pointerup', onUp, { once: true });
				e.preventDefault();
			});
		};

		const addRow = (parent, name, label, store) => {
			const row = document.createElement('div');
			row.className = 'pf-row';
			row.innerHTML = `<span class="pf-name"><span class="pf-dot"></span>${label}</span><span class="pf-val">–</span>`;
			parent.appendChild(row);
			store[name] = { val: row.querySelector('.pf-val'), dot: row.querySelector('.pf-dot') };
		};

		const build = () => {
			const el = document.createElement('div');
			el.id = 'lattice-perf-overlay';
			el.setAttribute('role', 'status');
			el.innerHTML = `
				<style>
					#lattice-perf-overlay {
						position: fixed;
						left: max(8px, env(safe-area-inset-left));
						bottom: max(8px, env(safe-area-inset-bottom));
						z-index: 2147483647;
						font: 12px/1.4 ui-monospace, "JetBrains Mono", Menlo, monospace;
						color: #f4f4f5;
						background: rgba(15, 17, 21, 0.92);
						border: 1px solid rgba(255, 255, 255, 0.14);
						border-radius: 10px;
						padding: 7px 10px 9px;
						box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4);
						backdrop-filter: blur(6px);
						min-width: 150px;
						user-select: none;
					}
					#lattice-perf-overlay .pf-head {
						display: flex;
						align-items: center;
						gap: 8px;
						margin-bottom: 6px;
						cursor: grab;
						touch-action: none;
					}
					#lattice-perf-overlay .pf-grip {
						display: grid;
						grid-template-columns: repeat(2, 3px);
						gap: 2px;
						padding: 1px;
						opacity: 0.45;
						flex: 0 0 auto;
						transition: opacity 0.15s;
					}
					#lattice-perf-overlay .pf-head:hover .pf-grip { opacity: 0.85; }
					#lattice-perf-overlay .pf-grip i {
						display: block;
						width: 3px;
						height: 3px;
						border-radius: 50%;
						background: #d4d4d8;
					}
					#lattice-perf-overlay .pf-title {
						flex: 1;
						font-size: 10px;
						letter-spacing: 0.08em;
						text-transform: uppercase;
						color: #a1a1aa;
					}
					#lattice-perf-overlay .pf-close {
						cursor: pointer;
						border: 0;
						background: transparent;
						color: #a1a1aa;
						font-size: 14px;
						line-height: 1;
						padding: 0 2px;
					}
					#lattice-perf-overlay .pf-row {
						display: flex;
						align-items: center;
						justify-content: space-between;
						gap: 14px;
						height: 18px;
					}
					#lattice-perf-overlay .pf-name {
						display: flex;
						align-items: center;
						gap: 7px;
						color: #d4d4d8;
					}
					#lattice-perf-overlay .pf-dot {
						width: 8px;
						height: 8px;
						border-radius: 50%;
						background: ${GREY};
						flex: 0 0 auto;
					}
					#lattice-perf-overlay .pf-val {
						font-variant-numeric: tabular-nums;
						color: #fafafa;
					}
					#lattice-perf-overlay .pf-unit {
						color: #71717a;
						font-size: 10px;
						margin-left: 2px;
					}
					#lattice-perf-overlay .pf-sep {
						display: flex;
						align-items: center;
						gap: 8px;
						margin: 7px 0 4px;
					}
					#lattice-perf-overlay .pf-sep span {
						font-size: 9px;
						letter-spacing: 0.1em;
						text-transform: uppercase;
						color: #71717a;
					}
					#lattice-perf-overlay .pf-sep::after {
						content: "";
						flex: 1;
						height: 1px;
						background: rgba(255, 255, 255, 0.1);
					}
				</style>
				<div class="pf-head">
					<span class="pf-grip" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i><i></i></span>
					<span class="pf-title">web vitals · live</span>
					<button class="pf-close" aria-label="Hide performance overlay">&times;</button>
				</div>
			`;
			for (const [name] of METRICS) addRow(el, name, name, refs);

			// RUNTIME group — separator + the live rows the platform supports.
			const sep = document.createElement('div');
			sep.className = 'pf-sep';
			sep.innerHTML = '<span>runtime</span>';
			el.appendChild(sep);
			addRow(el, 'FPS', 'FPS', rt);
			if (hasMem) addRow(el, 'MEM', 'MEM', rt);
			if (hasLongTasks) addRow(el, 'CPU', 'CPU<span class="pf-unit">≈</span>', rt);

			el.querySelector('.pf-close').addEventListener('click', () => setPerfOverlayEnabled(false));
			// Restore a dragged position, if any.
			try {
				const p = JSON.parse(localStorage.getItem(POS_KEY) || 'null');
				if (p && Number.isFinite(p.x) && Number.isFinite(p.y)) {
					el.style.left = `${p.x}px`;
					el.style.top = `${p.y}px`;
					el.style.right = 'auto';
					el.style.bottom = 'auto';
				}
			} catch {}
			makeDraggable(el, el.querySelector('.pf-head'));
			return el;
		};

		const mount = () => {
			if (host || !document.body) return;
			host = build();
			document.body.appendChild(host);
			for (const name in cache) paint(cache[name]); // repaint known vitals
			startVitals();
			startRuntime();
		};
		const unmount = () => {
			if (!host) return;
			stopRuntime();
			host.remove();
			host = null;
			for (const k in refs) delete refs[k];
			for (const k in rt) delete rt[k];
		};
		const sync = () => (perfOverlayEnabled() ? mount() : unmount());

		// Flipping the settings switch (or the × button) mounts/unmounts live.
		onPerfOverlayEnabledChange(sync);
		if (document.body) sync();
		else addEventListener('DOMContentLoaded', sync, { once: true });
	}
</script>
