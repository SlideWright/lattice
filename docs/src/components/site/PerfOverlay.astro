---
// Live Core-Web-Vitals overlay, gated behind a `?perf` query param so it costs
// nothing on a normal visit. The whole point is REAL-DEVICE measurement: the
// repo's perf gating (engineering/decisions/2026-06-15-docs-perf-gating-policy.md)
// defers the landing-CLS / mobile-LCP question to "real hardware" because the
// CI/sandbox can't load the CDN fonts and so never reproduces the font-swap
// reflow. This overlay closes that gap with zero tooling: open any page with
// `?perf` on a phone and the live LCP / CLS / INP / FCP / TTFB render on screen,
// measured by that device's own browser.
//
// Usage:
//   …/lattice/?perf       → turn the overlay on (sticky for the tab session)
//   …/lattice/?perf=off   → turn it off and clear the session flag
// The flag is kept in sessionStorage so it survives in-site navigation without
// re-appending the param. Tap the × to dismiss.
//
// Numbers come from Google's own `web-vitals` library (same algorithm as
// Lighthouse / CrUX: session-windowed CLS, INP from Event Timing), dynamically
// imported ONLY when the overlay is active, so the library chunk never loads on
// a normal page view. Each metric is colour-rated by the library's own
// good / needs-improvement / poor thresholds.
//
// Included once per page via ResourceHints (standalone routes), Header (docs
// zone) and features.astro (the one route that uses neither); a window guard
// makes a double-include a no-op.
---

<script>
	(() => {
		const KEY = 'lattice-perf-overlay';
		// Resolve active state: explicit param wins and is remembered; otherwise
		// fall back to the session flag so it persists across navigation.
		const params = new URLSearchParams(location.search);
		let active;
		if (params.has('perf')) {
			active = params.get('perf') !== 'off';
			try {
				if (active) sessionStorage.setItem(KEY, '1');
				else sessionStorage.removeItem(KEY);
			} catch {}
		} else {
			try {
				active = sessionStorage.getItem(KEY) === '1';
			} catch {
				active = false;
			}
		}
		if (!active || window.__latticePerfOverlay) return;
		window.__latticePerfOverlay = true;

		const RATING_COLOR = {
			good: '#16a34a',
			'needs-improvement': '#d97706',
			poor: '#dc2626',
		};
		// name → { label, format }. Order is the render order.
		const METRICS = [
			['LCP', (v) => `${Math.round(v)} ms`],
			['CLS', (v) => v.toFixed(3)],
			['INP', (v) => `${Math.round(v)} ms`],
			['FCP', (v) => `${Math.round(v)} ms`],
			['TTFB', (v) => `${Math.round(v)} ms`],
		];

		const mount = () => {
			const host = document.createElement('div');
			host.id = 'lattice-perf-overlay';
			host.setAttribute('role', 'status');
			host.innerHTML = `
				<style>
					#lattice-perf-overlay {
						position: fixed;
						left: max(8px, env(safe-area-inset-left));
						bottom: max(8px, env(safe-area-inset-bottom));
						z-index: 2147483647;
						font: 12px/1.4 ui-monospace, "JetBrains Mono", Menlo, monospace;
						color: #f4f4f5;
						background: rgba(15, 17, 21, 0.92);
						border: 1px solid rgba(255, 255, 255, 0.14);
						border-radius: 10px;
						padding: 8px 10px;
						box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4);
						backdrop-filter: blur(6px);
						min-width: 132px;
						user-select: none;
					}
					#lattice-perf-overlay .pf-head {
						display: flex;
						align-items: center;
						justify-content: space-between;
						gap: 12px;
						margin-bottom: 5px;
						font-size: 10px;
						letter-spacing: 0.08em;
						text-transform: uppercase;
						color: #a1a1aa;
					}
					#lattice-perf-overlay .pf-close {
						cursor: pointer;
						border: 0;
						background: transparent;
						color: #a1a1aa;
						font-size: 14px;
						line-height: 1;
						padding: 0 2px;
					}
					#lattice-perf-overlay .pf-row {
						display: flex;
						align-items: center;
						justify-content: space-between;
						gap: 14px;
					}
					#lattice-perf-overlay .pf-name {
						display: flex;
						align-items: center;
						gap: 6px;
						color: #d4d4d8;
					}
					#lattice-perf-overlay .pf-dot {
						width: 8px;
						height: 8px;
						border-radius: 50%;
						background: #52525b;
						flex: 0 0 auto;
					}
					#lattice-perf-overlay .pf-val {
						font-variant-numeric: tabular-nums;
						color: #fafafa;
					}
				</style>
				<div class="pf-head">
					<span>web vitals · live</span>
					<button class="pf-close" aria-label="Dismiss performance overlay">&times;</button>
				</div>
			`;
			const rows = {};
			for (const [name, fmt] of METRICS) {
				const row = document.createElement('div');
				row.className = 'pf-row';
				row.innerHTML = `<span class="pf-name"><span class="pf-dot"></span>${name}</span><span class="pf-val">–</span>`;
				host.appendChild(row);
				rows[name] = { el: row.querySelector('.pf-val'), dot: row.querySelector('.pf-dot'), fmt };
			}
			host.querySelector('.pf-close').addEventListener('click', () => {
				host.remove();
				try {
					sessionStorage.removeItem(KEY);
				} catch {}
			});
			document.body.appendChild(host);

			const update = (metric) => {
				const r = rows[metric.name];
				if (!r) return;
				r.el.textContent = r.fmt(metric.value);
				r.dot.style.background = RATING_COLOR[metric.rating] || '#52525b';
			};

			import('web-vitals')
				.then(({ onLCP, onCLS, onINP, onFCP, onTTFB }) => {
					const opts = { reportAllChanges: true };
					onLCP(update, opts);
					onCLS(update, opts);
					onINP(update, opts);
					onFCP(update, opts);
					onTTFB(update, opts);
				})
				.catch(() => {
					host.querySelector('.pf-head span').textContent = 'web vitals · failed to load';
				});
		};

		if (document.body) mount();
		else addEventListener('DOMContentLoaded', mount, { once: true });
	})();
</script>
