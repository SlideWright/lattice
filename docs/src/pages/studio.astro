---
// The Studio — the unified workspace prototype from the redesign decision doc
// (engineering/decisions/2026-06-21-app-redesign.md). A single standalone route
// that renders the v4 lean shell as ONE React island (StudioShell), wired live:
// a real CodeMirror editor, a live engine preview (DeckPreview), the Architect,
// the deck Inspector, Share / Workspace / Present overlays, the ⌘K palette, and
// the Fabricate studio. It is ADDITIVE — it does not touch the shipped Drawing
// Board / Playground; the engine is loaded on demand exactly as those do.
import '../styles/landing.css';
import StudioShell from '../components/studio/StudioShell.tsx';
import ResourceHints from '../components/site/ResourceHints.astro';
import EngineWarm from '../components/site/EngineWarm.astro';
import { joinBase } from '../lib/base-url.mjs';
import { assetBase } from '../playground/asset-version.mjs';

const base = import.meta.env.BASE_URL;
const url = (p) => joinBase(base, p);
const pg = assetBase();

const options = {
	themeBase: url(pg + 'themes/'),
	runtimeUrl: url(pg + 'lattice-runtime.js'),
	engineUrl: url(pg + 'lattice-playground.js'),
};
---

<!doctype html>
<html lang="en" data-palette="indaco" data-mode="light">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<ResourceHints />
		<title>Lattice Studio — one workspace</title>
		<meta name="description" content="The Lattice Studio: compose, present, and fabricate decks in one workspace. A live prototype of the app redesign." />
		<link rel="icon" type="image/svg+xml" href={url('favicon.svg')} />
		<style is:global>
			html, body { margin: 0; height: 100%; overflow: hidden; }
		</style>
		<script is:inline>
			(function () {
				var r = document.documentElement;
				try {
					var p = localStorage.getItem('lattice-studio-palette');
					if (p) r.setAttribute('data-palette', p);
					var m = localStorage.getItem('lattice-docs-mode');
					if (m === 'light' || m === 'dark') r.setAttribute('data-mode', m);
					else if (window.matchMedia && matchMedia('(prefers-color-scheme: dark)').matches) r.setAttribute('data-mode', 'dark');
				} catch (e) {}
			})();
		</script>
	</head>
	<body>
		<!-- client:only — the Studio is a browser app surface (no SSR/SEO need),
		     so it never server-renders; this also sidesteps Browser-API-on-server. -->
		<StudioShell client:only="react" options={options} />
		<EngineWarm allowEager />
	</body>
</html>
