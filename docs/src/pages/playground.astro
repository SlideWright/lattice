---
// Lattice playground — a standalone Astro route (like the landing) that runs
// the marp-cli render path client-side via docs/public/playground/
// lattice-playground.js. Type Lattice markdown, pick a component template, see
// it render live in the chosen palette.
import { createRequire } from 'node:module';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import '../styles/landing.css';
import '../styles/playground.css';

const docsRoot = process.cwd();
const repoRoot = join(docsRoot, '..');
const require = createRequire(import.meta.url);
const { loadAll } = require(join(repoRoot, 'lib/components', 'index.js'));
const manifests = loadAll();

const base = import.meta.env.BASE_URL;
const url = (p) => `${base}/${p}`.replace(/([^:])\/{2,}/g, '$1/');

const tokensCss = readFileSync(join(docsRoot, 'src/styles/lattice-tokens.generated.css'), 'utf8');
const palettes = [...new Set([...tokensCss.matchAll(/data-palette="([^"]+)"/g)].map((m) => m[1]))];
const titleCase = (s) => s.replace(/(^|-)(\w)/g, (_, sep, c) => (sep ? ' ' : '') + c.toUpperCase());

// Template catalog for the picker, grouped by Function family. Each component
// carries its documented variants (modifiers) so the Variant dropdown can load
// any of them into the editor.
const FUNCTION_ORDER = ['anchor', 'statement', 'inventory', 'comparison', 'progression', 'evidence', 'imagery'];
const catalog = {};
for (const m of manifests) {
	const variantDocs = m.variantDocs || {};
	const variantKeys = Array.isArray(m.variants) ? m.variants.filter((v) => variantDocs[v]) : [];
	catalog[m.name] = {
		skeleton: m.skeleton,
		sample: m.sample || m.skeleton,
		variants: variantKeys.map((v) => ({ key: v, label: v, caption: variantDocs[v].caption || '', sample: variantDocs[v].sample })),
	};
}
const groups = FUNCTION_ORDER.map((fn) => ({
	fn,
	items: manifests.filter((m) => m.function === fn).map((m) => m.name).sort(),
})).filter((g) => g.items.length);

// Starter deck = the hero component's sample (verdict-grid).
const heroComp = manifests.find((m) => m.showcase && m.showcase.hero);
const starter = (heroComp && heroComp.sample) || '<!-- _class: title silent -->\n\n# Lattice\n';

const pgData = JSON.stringify({
	catalog,
	themeBase: url('playground/themes/'),
	runtimeUrl: url('playground/lattice-runtime.js'),
	defaultPalette: 'indaco',
});
---

<!doctype html>
<html lang="en" data-palette="indaco" data-mode="light">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Lattice playground — try it in the browser</title>
		<meta name="description" content="Write Lattice Markdown and watch it render to boardroom slides live in your browser. Start from any component template." />
		<link rel="icon" type="image/png" href={url('lattice-logo.png')} />
		<script is:inline>
			(function () {
				var r = document.documentElement;
				try {
					var p = localStorage.getItem('lattice-docs-palette');
					if (p) r.setAttribute('data-palette', p);
					var m = localStorage.getItem('lattice-docs-mode');
					if (m === 'light' || m === 'dark') r.setAttribute('data-mode', m);
					else if (window.matchMedia && matchMedia('(prefers-color-scheme: dark)').matches) r.setAttribute('data-mode', 'dark');
				} catch (e) {}
			})();
		</script>
	</head>
	<body>
		<header class="topbar">
			<div class="wrap topbar-inner" style="max-width:none">
				<a class="brand" href={url('')}>
					<img class="brand-logo" src={url('lattice-logo.png')} alt="" width="30" height="30" />
					<span class="brand-mark">Lattice</span>
				</a>
				<nav class="topnav" id="topnav">
					<a class="navlink" href={url('getting-started/')}>Get started</a>
					<a class="navlink" href={url('guides/authoring/')}>Guides</a>
					<a class="navlink" href={url('playground/')} aria-current="page">Playground</a>
					<a class="navlink" href={url('components/')}>Components</a>
					<a class="navlink" href="https://github.com/slidewright/lattice">GitHub</a>
				</nav>
				<div class="topbar-actions">
					<div class="controls">
						<select class="palette-select" id="palette" aria-label="Palette">
							{palettes.map((p) => <option value={p}>{titleCase(p)}</option>)}
						</select>
						<button class="mode-toggle" id="mode-toggle" aria-label="Toggle light / dark" title="Toggle light / dark"></button>
					</div>
					<button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu" aria-controls="topnav" aria-expanded="false">☰</button>
				</div>
			</div>
		</header>

		<div class="pg-bar">
			<div class="pg-picker">
				<label for="pg-template">Template</label>
				<select id="pg-template" aria-label="Component template">
					<option value="">Pick a component…</option>
					{groups.map((g) => (
						<optgroup label={titleCase(g.fn)}>
							{g.items.map((n) => <option value={n}>{n}</option>)}
						</optgroup>
					))}
				</select>
			</div>
			<div class="pg-picker">
				<label for="pg-variant">Variant</label>
				<select id="pg-variant" aria-label="Component variant" disabled>
					<option value="">—</option>
				</select>
			</div>
			<button class="pg-btn" id="pg-insert-sample">Insert example</button>
			<button class="pg-btn" id="pg-insert-skeleton">Insert skeleton</button>
			<span class="spacer"></span>
			<span class="pg-status" id="pg-status">Ready.</span>
			<div class="pg-tabs" role="tablist">
				<button class="pg-tab" id="tab-edit" role="tab" aria-selected="true">Edit</button>
				<button class="pg-tab" id="tab-preview" role="tab" aria-selected="false">Preview</button>
			</div>
		</div>

		<main class="pg-split">
			<section class="pg-pane editor">
				<div class="pg-pane-label">Markdown</div>
				<!-- CodeMirror mounts into #editor-host. The textarea is the no-JS /
				     pre-hydration fallback and the source of the starter text;
				     editor.js reads its value, then replaces it. -->
				<div class="pg-editor-host" id="editor-host">
					<textarea id="editor" spellcheck="false" aria-label="Lattice markdown editor">{starter}</textarea>
				</div>
			</section>
			<section class="pg-pane preview">
				<div class="pg-pane-label">Rendered slides</div>
				<div class="pg-preview-wrap">
					<iframe id="preview" title="Rendered slides preview"></iframe>
				</div>
			</section>
		</main>

		<script type="application/json" id="pg-data" is:inline set:html={pgData}></script>

		<!-- CodeMirror editor (bundled by Astro/Vite). Mounts into #editor-host,
		     seeded from the textarea, and exposes a tiny adapter on window so the
		     inline controller below reads/writes source through it. Falls back to
		     the textarea if this module fails to load. -->
		<script>
			import { createEditor } from '../playground/editor.js';
			const host = document.getElementById('editor-host');
			const ta = document.getElementById('editor');
			const initial = ta ? ta.value : '';
			let notify = null;
			const ed = createEditor({ parent: host, doc: initial, onChange: (v) => { if (notify) notify(v); } });
			if (ta) ta.remove();
			window.__pgEditor = {
				getValue: () => ed.getValue(),
				setValue: (t) => ed.setValue(t),
				focus: () => ed.focus(),
				onChange: (fn) => { notify = fn; },
			};
			window.dispatchEvent(new Event('pg-editor-ready'));
		</script>

		<script is:inline defer src={url('playground/lattice-playground.js')}></script>
		<script is:inline>
			(function () {
				var data = JSON.parse(document.getElementById('pg-data').textContent);
				var catalog = data.catalog;
				var THEME_BASE = data.themeBase;
				var RUNTIME_URL = data.runtimeUrl;
				var root = document.documentElement;
				var frame = document.getElementById('preview');
				var statusEl = document.getElementById('pg-status');
				var paletteSel = document.getElementById('palette');
				var modeBtn = document.getElementById('mode-toggle');
				var tmplSel = document.getElementById('pg-template');
				var varSel = document.getElementById('pg-variant');

				// Source accessors: prefer the CodeMirror adapter (window.__pgEditor),
				// fall back to the textarea if the editor module hasn't loaded yet or
				// failed (no-JS safety). All source reads/writes go through these.
				function getSource() {
					if (window.__pgEditor) return window.__pgEditor.getValue();
					var ta = document.getElementById('editor');
					return ta ? ta.value : '';
				}
				function setSource(text) {
					if (window.__pgEditor) { window.__pgEditor.setValue(text); return; }
					var ta = document.getElementById('editor');
					if (ta) ta.value = text;
				}

				// Persist the editor across reloads / refresh / session end so the
				// author's in-progress deck survives (palette + mode already persist
				// via the shared localStorage keys).
				var SOURCE_KEY = 'lattice-docs-pg-source';
				function saveSource() { try { localStorage.setItem(SOURCE_KEY, getSource()); } catch (e) {} }

				paletteSel.value = root.getAttribute('data-palette');
				var fetched = {}; // theme name -> Promise<cssText>
				var latticeReady = null;

				function setStatus(msg, isErr) {
					statusEl.textContent = msg;
					statusEl.classList.toggle('err', !!isErr);
				}

				function fetchTheme(name) {
					if (!fetched[name]) {
						fetched[name] = fetch(THEME_BASE + name + '.css').then(function (r) {
							if (!r.ok) throw new Error('theme ' + name + ' (' + r.status + ')');
							return r.text();
						});
					}
					return fetched[name];
				}

				function ensureThemes(palette, mode) {
					var PG = window.LatticePlayground;
					if (!latticeReady) latticeReady = fetchTheme('lattice').then(function (css) { PG.addThemes([css]); });
					var jobs = [latticeReady];
					if (!PG.hasTheme(palette)) jobs.push(fetchTheme(palette).then(function (css) { PG.addThemes([css]); }));
					var darkName = palette + '-dark';
					if (mode === 'dark') {
						jobs.push(fetchTheme(darkName).then(function (css) { PG.addThemes([css]); }).catch(function () {}));
					}
					return Promise.all(jobs);
				}

				var KATEX = 'https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css';
				// UMD build sets window.mermaid, which lattice-runtime.js polls for and
				// then renders ```mermaid fences (and charts/split-panels via applyAllToDom).
				var MERMAID = 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js';

				// The engine renders with inlineSVG:false (see lib/playground/index.js),
				// so each slide is a plain fixed-size <section> inside <div class="marpit">
				// rather than Marp's <svg><foreignObject> wrapper. This `fit` routine
				// scales every section to the iframe width with a CSS transform; a
				// negative margin-bottom collapses the gap the un-scaled box would
				// otherwise leave (transform doesn't change layout box size). Re-run on
				// viewport resize and on content-height changes (Mermaid/charts render
				// async, growing a section after the first pass). The Marp Safari
				// foreignObject polyfill is gone — there's no foreignObject to fix, which
				// is exactly why the WebKit render failures disappear.
				var FIT = [
					'(function(){',
					'  function fit(){',
					'    var marpit=document.querySelector(".marpit"); if(!marpit) return;',
					'    var w=marpit.clientWidth; if(!w) return;',
					'    var secs=marpit.querySelectorAll(":scope>section");',
					'    for(var i=0;i<secs.length;i++){var s=secs[i];',
					'      var sw=s.offsetWidth||1280, sh=s.offsetHeight||720;',
					'      var sc=w/sw;',
					'      s.style.transformOrigin="top left";',
					'      s.style.transform="scale("+sc+")";',
					'      s.style.marginBottom=(sh*sc-sh+16)+"px";',
					'    }',
					'  }',
					'  window.addEventListener("resize",fit);',
					'  if(typeof ResizeObserver!=="undefined"){',
					'    var ro=new ResizeObserver(function(){fit();});',
					'    var m=document.querySelector(".marpit");',
					'    if(m){ro.observe(document.documentElement);',
					'      var ss=m.querySelectorAll(":scope>section");',
					'      for(var i=0;i<ss.length;i++) ro.observe(ss[i]);}',
					'  }',
					'  fit();',
					// Backstop for async Mermaid/chart renders that grow a section after
					// the observers are attached (or where ResizeObserver is absent).
					'  [60,300,1200,2500].forEach(function(t){setTimeout(fit,t);});',
					'})();',
				].join('\n');

				function writeFrame(html, css, mode) {
					var bg = mode === 'dark' ? '#0c0c0c' : '#e7e7ea';
					// Use srcdoc (a fresh browsing context per render), NOT
					// doc.open()/write()/close(). The latter clears the document but
					// KEEPS the iframe window, so lattice-runtime.js's one-shot guard
					// (globalScope.__llMermaidBootstrapLoaded) survives — the starter
					// render sets it, and every later render short-circuits the whole
					// runtime, so Mermaid/charts added after the first edit never
					// render. A fresh srcdoc window resets the guard each time.
					// See engineering/gotchas.md "Playground: Mermaid stops rendering".
					frame.srcdoc =
						'<!doctype html><html><head><meta charset="utf-8">' +
						'<link rel="stylesheet" href="' + KATEX + '">' +
						'<style>html,body{margin:0;padding:18px;background:' + bg + ';}' +
						'.marpit>section{display:block;transform-origin:top left;' +
						'box-shadow:0 8px 30px rgba(0,0,0,.22);border-radius:6px;}' +
						css + '</style></head><body>' + html +
						'<scr' + 'ipt src="' + MERMAID + '"></scr' + 'ipt>' +
						'<scr' + 'ipt src="' + RUNTIME_URL + '"></scr' + 'ipt>' +
						'<scr' + 'ipt>' + FIT + '</scr' + 'ipt>' +
						'</body></html>';
				}

				var timer = null;
				function scheduleRender() { clearTimeout(timer); timer = setTimeout(render, 220); }

				function render() {
					var PG = window.LatticePlayground;
					if (!PG) { setStatus('Loading engine…'); return setTimeout(render, 60); }
					var palette = root.getAttribute('data-palette') || 'indaco';
					var mode = root.getAttribute('data-mode') === 'dark' ? 'dark' : 'light';
					setStatus('Rendering…');
					ensureThemes(palette, mode).then(function () {
						var theme = mode === 'dark' && PG.hasTheme(palette + '-dark') ? palette + '-dark' : palette;
						try {
							var out = PG.render(getSource(), theme);
							writeFrame(out.html, out.css, mode);
							setStatus('Rendered ' + (out.html.match(/<\/section>/g) || []).length + ' slide(s).');
						} catch (e) {
							setStatus(String(e.message || e), true);
						}
					}).catch(function (e) { setStatus(String(e.message || e), true); });
				}

				// Wire change events. CodeMirror reports edits via its onChange
				// adapter; until/if it loads, the textarea's input event covers it.
				function onEdit() { saveSource(); syncPickers(); scheduleRender(); }
				function wireEditorEvents() {
					if (window.__pgEditor) {
						window.__pgEditor.onChange(onEdit);
						// Restore persisted source into the live editor, then render it.
						try { var saved = localStorage.getItem(SOURCE_KEY); if (saved != null) setSource(saved); } catch (e) {}
						syncPickers();
						render();
					}
				}
				if (window.__pgEditor) wireEditorEvents();
				else window.addEventListener('pg-editor-ready', wireEditorEvents);
				// Fallback: textarea input (only fires if CodeMirror never replaced it).
				var taEl = document.getElementById('editor');
				if (taEl) taEl.addEventListener('input', onEdit);

				// Fill the Variant dropdown for the picked component: 'default' (the
				// base sample) plus each documented modifier. Disabled when the
				// component has no variants (or none is picked).
				function populateVariants(name) {
					var comp = name && catalog[name];
					varSel.innerHTML = '';
					var variants = (comp && comp.variants) || [];
					if (!comp || !variants.length) {
						var none = document.createElement('option');
						none.value = '';
						none.textContent = '—';
						varSel.appendChild(none);
						varSel.disabled = true;
						return;
					}
					varSel.disabled = false;
					var def = document.createElement('option');
					def.value = 'default';
					def.textContent = 'default';
					varSel.appendChild(def);
					variants.forEach(function (v) {
						var o = document.createElement('option');
						o.value = v.key;
						o.textContent = v.label;
						if (v.caption) o.title = v.caption;
						varSel.appendChild(o);
					});
					varSel.value = 'default';
				}

				// Detect which component (and variant) the current source is, from the
				// first `<!-- _class: ... -->`: the first class token that names a
				// component, with any remaining token that matches one of its variant
				// keys. Lets the pickers reflect a deck loaded via the "Open in
				// Playground" handoff, a reload, or a paste — instead of sitting on
				// "Pick a component…".
				function detectComponent(src) {
					var m = /<!--\s*_class:\s*([^>]*?)\s*-->/.exec(src || '');
					if (!m) return null;
					var tokens = m[1].trim().split(/\s+/).filter(Boolean);
					var name = null;
					for (var i = 0; i < tokens.length; i++) { if (catalog[tokens[i]]) { name = tokens[i]; break; } }
					if (!name) return null;
					var variant = 'default';
					var vs = (catalog[name].variants || []);
					for (var j = 0; j < vs.length; j++) { if (tokens.indexOf(vs[j].key) >= 0) { variant = vs[j].key; break; } }
					return { name: name, variant: variant };
				}

				// Sync the Template + Variant pickers to whatever the editor holds.
				function syncPickers() {
					var det = detectComponent(getSource());
					if (!det) return;
					if (tmplSel.value !== det.name) { tmplSel.value = det.name; populateVariants(det.name); }
					else if (varSel.disabled && (catalog[det.name].variants || []).length) { populateVariants(det.name); }
					for (var i = 0; i < varSel.options.length; i++) {
						if (varSel.options[i].value === det.variant) { varSel.value = det.variant; break; }
					}
				}

				tmplSel.addEventListener('change', function () {
					var name = tmplSel.value;
					if (name && catalog[name]) { setSource(catalog[name].sample); populateVariants(name); saveSource(); render(); }
				});
				varSel.addEventListener('change', function () {
					var comp = catalog[tmplSel.value];
					if (!comp) return;
					var key = varSel.value;
					var md = comp.sample;
					if (key && key !== 'default') {
						var v = (comp.variants || []).filter(function (x) { return x.key === key; })[0];
						if (v) md = v.sample;
					}
					setSource(md); saveSource(); render();
				});
				document.getElementById('pg-insert-sample').addEventListener('click', function () {
					var name = tmplSel.value;
					if (name && catalog[name]) { setSource(catalog[name].sample); populateVariants(name); saveSource(); render(); }
					else setStatus('Pick a component first.', true);
				});
				document.getElementById('pg-insert-skeleton').addEventListener('click', function () {
					var name = tmplSel.value;
					if (name && catalog[name]) { setSource(catalog[name].skeleton); populateVariants(name); saveSource(); render(); }
					else setStatus('Pick a component first.', true);
				});
				// Reflect whatever the editor currently holds (starter deck, restored
				// handoff, or persisted source) in the Template + Variant pickers.
				syncPickers();

				paletteSel.addEventListener('change', function () {
					root.setAttribute('data-palette', paletteSel.value);
					try { localStorage.setItem('lattice-docs-palette', paletteSel.value); } catch (e) {}
					render();
				});
				modeBtn.addEventListener('click', function () {
					var next = root.getAttribute('data-mode') === 'dark' ? 'light' : 'dark';
					root.setAttribute('data-mode', next);
					try { localStorage.setItem('lattice-docs-mode', next); } catch (e) {}
					render();
				});

				// Re-sync + re-render on back/forward (bfcache) restores, where the
				// pre-paint script doesn't re-run — so a theme picked elsewhere
				// sticks when you navigate back to the playground.
				window.addEventListener('pageshow', function () {
					try {
						var p = localStorage.getItem('lattice-docs-palette');
						var m = localStorage.getItem('lattice-docs-mode');
						var changed = false;
						if (p && p !== root.getAttribute('data-palette')) { root.setAttribute('data-palette', p); changed = true; }
						if ((m === 'light' || m === 'dark') && m !== root.getAttribute('data-mode')) { root.setAttribute('data-mode', m); changed = true; }
						paletteSel.value = root.getAttribute('data-palette');
						if (changed) render();
					} catch (e) {}
				});

				var navToggle = document.getElementById('nav-toggle');
				var topbar = document.querySelector('.topbar');
				if (navToggle && topbar) {
					navToggle.addEventListener('click', function () {
						var open = topbar.classList.toggle('nav-open');
						navToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
					});
				}

				// Mobile Edit | Preview tabs.
				var tabEdit = document.getElementById('tab-edit');
				var tabPreview = document.getElementById('tab-preview');
				function setPane(which) {
					document.body.setAttribute('data-pane', which);
					tabEdit.setAttribute('aria-selected', which === 'edit');
					tabPreview.setAttribute('aria-selected', which === 'preview');
				}
				tabEdit.addEventListener('click', function () { setPane('edit'); });
				tabPreview.addEventListener('click', function () { setPane('preview'); render(); });
				setPane('edit');

				render();
			})();
		</script>
	</body>
</html>
