---
// Lattice playground — a standalone Astro route (like the landing) that runs
// the marp-cli render path client-side via docs/public/playground/
// lattice-playground.js. Type Lattice markdown, pick a component template, see
// it render live in the chosen palette.
//
// Phase 3 of the shadcn migration: the surface is a React + shadcn island
// (PlaygroundApp). Astro owns the page shell (head, topbar, the engine
// <script> tags); React owns the toolbar, editor host, preview iframe, and the
// Sheets — WRAPPING the irreducible engine pieces (CodeMirror editor.js, the
// filmstrip deck-preview.js, the shared deck-config.js, window.LatticePlayground)
// rather than reimplementing them. See engineering/decisions/2026-06-09-shadcn-migration.md §0.
import { createRequire } from 'node:module';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import '../styles/landing.css';
import '../styles/playground.css';
import '../styles/deck-config.css';
import PaletteControls from '../components/site/PaletteControls.tsx';
import PlaygroundApp from '../components/playground/PlaygroundApp.tsx';
import { buildCatalog, buildLenses } from '../lib/families.mjs';
import { joinBase } from '../lib/base-url.mjs';
import { primaryNav, GITHUB_URL, isCurrent } from '../lib/nav.mjs';
import { isPreviewDeploy } from '../lib/deploy-env.mjs';
import { assetBase } from '../playground/asset-version.mjs';
import { loadGalleries, GALLERY_GROUPS } from '../playground/galleries.mjs';

const docsRoot = process.cwd();
const repoRoot = join(docsRoot, '..');
const require = createRequire(import.meta.url);
const { loadAll, manifestBucket } = require(join(repoRoot, 'lib/components', 'index.js'));
const { FINISH_NAMES } = require(join(repoRoot, 'lib/core', 'resolve-finish.js'));
const manifests = loadAll();

const base = import.meta.env.BASE_URL;
const url = (p) => joinBase(base, p);
const navLinks = primaryNav(url); // shared primary nav — src/lib/nav.mjs
const here = Astro.url.pathname;
// Cache-busted prefix for the playground's runtime-fetched assets (see
// asset-version.mjs); the bare `playground/` route is unchanged.
const pg = assetBase();

// Guided tours run on the production site only — never local dev or the
// Cloudflare PR previews. Baked into the HTML so the client gate is build-time.
const previewDeploy = isPreviewDeploy({
	dev: import.meta.env.DEV,
	cfPages: process.env.CF_PAGES,
	cfBranch: process.env.CF_PAGES_BRANCH,
});

const tokensCss = readFileSync(join(docsRoot, 'src/styles/lattice-tokens.generated.css'), 'utf8');
const palettes = [...new Set([...tokensCss.matchAll(/data-palette="([^"]+)"/g)].map((m) => m[1]))];

// Template catalog for the picker. Each component carries its documented
// variants (modifiers) so the Variant dropdown can load any of them into the
// editor. The `components` array (the Function·Form·Substance / family / tags
// fields) feeds the searchable, groupable popover picker — reusing the same
// buildCatalog + the shared search-core the component reference browses with.
const catalog = {};
for (const m of manifests) {
	const variantDocs = m.variantDocs || {};
	const variantKeys = Array.isArray(m.variants) ? m.variants.filter((v) => variantDocs[v]) : [];
	catalog[m.name] = {
		skeleton: m.skeleton,
		sample: m.sample || m.skeleton,
		variants: variantKeys.map((v) => ({ key: v, label: v, caption: variantDocs[v].caption || '', sample: variantDocs[v].sample })),
	};
}
const components = buildCatalog(manifests, manifestBucket);
const lenses = buildLenses();

// Starter deck = the hero component's sample (verdict-grid).
const heroComp = manifests.find((m) => m.showcase && m.showcase.hero);
const starter = (heroComp && heroComp.sample) || '<!-- _class: title silent -->\n\n# Lattice\n';

// Full showcase + per-family survey decks for the "Load a deck" drawer. Loaded
// from repo markdown at build time (galleries.mjs), with local image assets
// inlined as data URIs so the preview iframe renders them. The Sheet renders
// labels + slide counts; the controller maps id → source.
const galleries = loadGalleries(repoRoot);
const galleryGroups = GALLERY_GROUPS.map((grp) => ({
	key: grp.key,
	hint: grp.hint,
	items: galleries
		.filter((g) => g.group === grp.key)
		.map((g) => ({ id: g.id, label: g.label, slides: g.slides })),
})).filter((grp) => grp.items.length);
const gallerySources = Object.fromEntries(galleries.map((g) => [g.id, g.source]));

// The full data payload for the React island. Passed as a prop (Astro
// serializes it); the deck sources can contain a literal `</script>` (the jargon
// gallery ends with two), but as a serialized prop — not an inline <script> —
// Astro escapes it safely, so the old `<` hand-escape is no longer needed.
const pgData = {
	catalog,
	components,
	lenses,
	gallerySources,
	galleryGroups,
	themeBase: url(pg + 'themes/'),
	runtimeUrl: url(pg + 'lattice-runtime.js'),
	engineUrl: url(pg + 'lattice-playground.js'),
	palettes,
	finishes: FINISH_NAMES,
	starter,
};
---

<!doctype html>
<html lang="en" data-palette="indaco" data-mode="light" data-tours={previewDeploy ? 'off' : 'on'}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Lattice playground — try it in the browser</title>
		<meta name="description" content="Write Lattice Markdown and watch it render to boardroom slides live in your browser. Start from any component template." />
		<link rel="icon" type="image/png" href={url('lattice-logo.png')} />
		<script is:inline>
			(function () {
				var r = document.documentElement;
				try {
					var p = localStorage.getItem('lattice-docs-palette');
					if (p) r.setAttribute('data-palette', p);
					var m = localStorage.getItem('lattice-docs-mode');
					if (m === 'light' || m === 'dark') r.setAttribute('data-mode', m);
					else if (window.matchMedia && matchMedia('(prefers-color-scheme: dark)').matches) r.setAttribute('data-mode', 'dark');
				} catch (e) {}
			})();
		</script>
	</head>
	<body class="pg-page">
		<header class="topbar">
			<div class="wrap topbar-inner" style="max-width:none">
				<a class="brand" href={url('')}>
					<img class="brand-logo" src={url('lattice-logo.png')} alt="" width="30" height="30" />
					<span class="brand-mark">Lattice</span>
				</a>
				<nav class="topnav" id="topnav">
					{navLinks.map((l) => (
						<a class="navlink" href={l.href} aria-current={isCurrent(l, here) ? 'page' : undefined}>{l.label}</a>
					))}
					<a class="navlink" href={GITHUB_URL}>GitHub</a>
				</nav>
				<div class="topbar-actions">
					<div class="controls lx-ui">
						<PaletteControls client:idle palettes={palettes} />
					</div>
					<button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu" aria-controls="topnav" aria-expanded="false"></button>
				</div>
			</div>
		</header>

		<!-- The playground surface: one React + shadcn island owning the toolbar
		     (component Popover+Command picker, variant Select, mobile Edit/Preview
		     Tabs, status, the Deck-setup + Galleries Sheets), the CodeMirror editor
		     host, and the preview iframe. -->
		<PlaygroundApp client:load data={pgData} />

		<!-- Guided tour: first-visit walkthrough + replay button (driver.js). The
		     tour targets the live DOM by selector, so it runs after the island
		     hydrates; it's unchanged from the vanilla surface. -->
		<script>
			import { initPlaygroundTour } from '../playground/playground-tour.js';
			initPlaygroundTour();
		</script>

		<!-- Bridge: expose the shared filmstrip-preview controller (deck-preview.js)
		     on window so the React render loop (playground-engine.ts) can drive the
		     iframe write/patch/fit through one implementation (also used by the
		     Drawing Board and both Workbench studios). Deferred like the engine
		     bundle; the controller guards on window.LatticeDeckPreview's presence. -->
		<script>
			import { renderDeck } from '../playground/deck-preview.js';
			window.LatticeDeckPreview = { renderDeck };
		</script>

		<!-- The marp render engine (window.LatticePlayground) is loaded ON DEMAND by
		     load-engine.ts (PlaygroundApp triggers it on idle, after the chrome
		     paints), not eagerly here — so the toolbar + editor host paint without
		     the ~554KB-gz bundle blocking. The render loop polls for the global. -->

		<!-- Mobile nav-toggle (the topbar hamburger) — the one bit of surrounding
		     chrome still wired imperatively, identical to the other standalone
		     routes (landing, drawing board). -->
		<script is:inline>
			(function () {
				var navToggle = document.getElementById('nav-toggle');
				var topbar = document.querySelector('.topbar');
				if (navToggle && topbar) {
					navToggle.addEventListener('click', function () {
						var open = topbar.classList.toggle('nav-open');
						navToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
					});
				}
			})();
		</script>
	</body>
</html>
