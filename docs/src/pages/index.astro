---
// Lattice landing page — a standalone Astro route (NOT a Starlight page), so it
// renders full-bleed with the engine's own tokens instead of Starlight chrome.
// The docs pages (/getting-started, /introduction, …) stay 100% Starlight.
//
// Phase 4 of the shadcn migration: the marketing sections are React + Tailwind +
// shadcn. Astro owns the page shell (head, topbar, footer, the engine <script>);
// React owns the content. Static sections (hero copy/CTAs, feature/why/next
// cards, section heads) render SERVER-SIDE with NO client: directive → zero JS.
// Only the genuinely interactive bits hydrate: the hero Preview/Source Tabs
// (HeroPreview), the field-card live previews (FieldCardsLive), and the restyle
// carousel (RestyleShowcase). Each WRAPS the irreducible engine via the shared
// <DeckPreview> bridge (src/components/DeckPreview.tsx → src/lib/single-slide-render.ts)
// — it never reimplements the marp render.
// See engineering/decisions/2026-06-09-shadcn-migration.md §0.
import { readFileSync } from 'node:fs';
import { createRequire } from 'node:module';
import { join } from 'node:path';
import '../styles/landing.css';
import SiteHeader from '../components/site/SiteHeader.astro';
import { HeroCopy } from '../components/landing/HeroCopy.tsx';
import HeroPreview from '../components/landing/HeroPreview.tsx';
import {
	ByomSection,
	FieldCards,
	HowItWorks,
	NextSteps,
	ProofStrip,
	SectionHead,
	WhyCards,
} from '../components/landing/sections.tsx';
import FieldCardsLive from '../components/landing/FieldCardsLive.tsx';
import RestyleShowcase from '../components/landing/RestyleShowcase.tsx';
import { assetBase } from '../playground/asset-version.mjs';
import { joinBase } from '../lib/base-url.mjs';
import ResourceHints from '../components/site/ResourceHints.astro';
import EngineWarm from '../components/site/EngineWarm.astro';

// Astro evaluates this frontmatter at build time with cwd = docs/, so anchor
// repo reads to cwd (import.meta.url is unreliable once the page is bundled).
const docsRoot = process.cwd();
const repoRoot = join(docsRoot, '..');
const require = createRequire(import.meta.url);
const { loadAll } = require(join(repoRoot, 'lib/components', 'index.js'));
const manifests = loadAll();

// Base-path-safe URL builder (project pages live under /lattice/).
const base = import.meta.env.BASE_URL;
const url = (p) => joinBase(base, p);
// Cache-busted prefix for the playground's runtime-fetched assets — see
// asset-version.mjs. `playground/` (the route) stays bare.
const pg = assetBase();

// Palette list = the distinct names baked into the generated token CSS — one
// source of truth (themes/*.css via build-landing-tokens.js), no duplication.
const tokensCss = readFileSync(join(docsRoot, 'src/styles/lattice-tokens.generated.css'), 'utf8');
const palettes = [...new Set([...tokensCss.matchAll(/data-palette="([^"]+)"/g)].map((m) => m[1]))];
const titleCase = (s) => s.replace(/(^|-)(\w)/g, (_, sep, c) => (sep ? ' ' : '') + c.toUpperCase());

// The hero's left panel shows the REAL manifest sample that produced the right
// panel's rendered slide image — so "write this, get this" is literally true.
// Hero = the component flagged `showcase.hero` in its manifest; its sample is
// shown verbatim as the headline source and rendered as the hero slide.
const heroComp = manifests.find((m) => m.showcase && m.showcase.hero);
const escapeHtml = (s) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
const heroSource = heroComp.sample.trim();
const heroCodeHtml = heroSource
	.split('\n')
	.map((line) => {
		let cls = 'ln-dim';
		if (/^<!--\s*_class/.test(line)) cls = 'ln-class';
		else if (/^#{1,6}\s/.test(line)) cls = 'ln-h';
		return `<span class="${cls}">${escapeHtml(line) || ' '}</span>`;
	})
	.join('\n');

// "One source, every palette" demo = ONE slide re-rendered live through every
// palette. Swatch colours are each palette's light `--accent`, read from the
// generated tokens CSS (the same source the topbar selector lists).
const restyleComp = manifests.find((m) => m.name === 'kpi');
const paletteAccents = palettes.map((name) => {
	const hit = tokensCss.match(
		new RegExp(`\\[data-palette="${name}"\\]\\[data-mode="light"\\]\\{[^}]*?--accent:(#[0-9A-Fa-f]{3,8})`),
	);
	return { name, label: titleCase(name), accent: hit ? hit[1] : '#888888' };
});

// Live-render data: the islands render the hero, the field cards, and the
// restyle demo through the engine runtime so they follow the selected palette +
// light/dark, instead of being baked-in-indaco static images.
const needsMermaid = (s) => /```mermaid/.test(s || '');

// The "speaks your field" cards each render a REAL slide live (no static image)
// through the same engine runtime the hero + carousel use. One representative
// component per field — its manifest sample is the source rendered in the card.
const CARD_COMPONENTS = ['math', 'gantt', 'diagram', 'obligation-matrix', 'radar', 'cards-grid'];
const cardData = CARD_COMPONENTS.reduce((acc, n) => {
	const m = manifests.find((x) => x.name === n);
	if (m) {
		const s = m.sample || m.skeleton;
		acc[n] = { sample: s, mermaid: needsMermaid(s) };
	}
	return acc;
}, {});

// Shared engine endpoints handed to every live island. `engineUrl` is the
// ~554KB-gz render bundle: it is no longer loaded eagerly in <head> — each
// island loads it on demand (load-engine.ts, via the bridge's whenReady) when
// it first needs to render, so the static hero text paints first.
const themeBase = url(pg + 'themes/');
const runtimeUrl = url(pg + 'lattice-runtime.js');
const engineUrl = url(pg + 'lattice-playground.js');

const heroData = {
	sample: heroComp.sample,
	mermaid: needsMermaid(heroComp.sample),
	codeHtml: heroCodeHtml,
	componentName: heroComp.name,
	themeBase,
	runtimeUrl,
	engineUrl,
};
const fieldCardsData = { cards: cardData, themeBase, runtimeUrl, engineUrl };
const restyleData = {
	sample: restyleComp.sample || restyleComp.skeleton,
	mermaid: needsMermaid(restyleComp.sample || restyleComp.skeleton),
	palettes: paletteAccents,
	themeBase,
	runtimeUrl,
	engineUrl,
};

const nextSteps = [
	{
		href: url('getting-started/'),
		title: 'Get started',
		body: 'Install the toolchain and render your first deck in a few minutes.',
		cta: 'Getting started',
	},
	{
		href: url('guides/authoring/'),
		title: 'Author decks',
		body: "See every layout, what it's for, and the Markdown that feeds it.",
		cta: 'Authoring guide',
	},
	{
		href: url('components/'),
		title: 'Browse the layouts',
		body: 'Every layout with a live preview and an in-browser editor — themable in all palettes.',
		cta: 'Layout reference',
	},
	{
		href: url('playground/'),
		title: "Can't install anything?",
		body: 'Open the playground — the full engine runs in your browser, nothing to install. The SlideWright desktop app is on the way.',
		cta: 'Open the playground',
	},
];
---

<!doctype html>
<html lang="en" data-palette="indaco" data-mode="light">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<ResourceHints />
		<title>Lattice — Markdown to boardroom-ready slide decks (PDF, PPTX)</title>
		<meta
			name="description"
			content="Write plain Markdown, pick a layout per slide, and Lattice renders a polished PDF, PPTX, or HTML deck with one palette and zero design work. Free, offline, MIT-licensed."
		/>
		<link rel="icon" type="image/svg+xml" href={url('favicon.svg')} />
		<!-- Set palette/mode before first paint to avoid a flash. Shares the
		     portal's localStorage keys so a choice carries across the jump. -->
		<script is:inline>
			(function () {
				var r = document.documentElement;
				try {
					var p = localStorage.getItem('lattice-docs-palette');
					if (p) r.setAttribute('data-palette', p);
					var m = localStorage.getItem('lattice-docs-mode');
					if (m === 'light' || m === 'dark') r.setAttribute('data-mode', m);
					else if (window.matchMedia && matchMedia('(prefers-color-scheme: dark)').matches)
						r.setAttribute('data-mode', 'dark');
				} catch (e) {}
			})();
		</script>
	</head>
	<body>
		<SiteHeader palettes={palettes} />

		<main>
			<!-- Hero -->
			<section class="py-[clamp(48px,7vw,96px)] pb-[clamp(40px,5vw,72px)]">
				<div class="wrap grid grid-cols-1 items-center gap-[clamp(28px,4vw,56px)] lg:grid-cols-[1.05fr_1fr]">
					<!-- Static copy + CTAs (zero JS). -->
					<HeroCopy
						playgroundHref={url('playground/')}
						getStartedHref={url('getting-started/')}
						galleryHref={url('gallery.pdf')}
					/>
					<!-- Interactive Preview/Source flip + live render (hydrates). -->
					<HeroPreview client:load data={heroData} />
				</div>
			</section>

			<!-- How it works — a slim three-step band -->
			<section class="border-y border-border bg-muted py-[clamp(28px,3.5vw,44px)]">
				<div class="wrap">
					<HowItWorks />
				</div>
			</section>

			<!-- Range: speaks your field -->
			<section class="py-[clamp(48px,6vw,88px)]">
				<div class="wrap">
					<SectionHead eyebrow="Whatever you do, there's a slide for it" title="Your field already has a notation. Lattice speaks it.">
						You write the same lists, tables, and fenced blocks you already know. Lattice renders each in the notation
						your discipline expects — no drawing tools, no boxes to nudge.
					</SectionHead>
					<FieldCards playgroundHref={url('playground/')} layoutCount={manifests.length} />
				</div>
				<!-- Invisible controller: fills the cards' live hosts + wires "Edit this
				     deck". client:load (not client:visible) because this island renders
				     null — a zero-box element has nothing for client:visible's observer to
				     intersect, so it would never hydrate. It does its OWN lazy render
				     (IntersectionObserver on the section), so eager hydration is cheap. -->
				<FieldCardsLive client:idle data={fieldCardsData} />
			</section>

			<!-- Why -->
			<section class="border-y border-border bg-muted py-[clamp(48px,6vw,88px)]">
				<div class="wrap">
					<SectionHead eyebrow="Why decks drift, and why these don't" title="Every deck looks like it came from the same team — because it did.">
						Slide tools make every slide a blank canvas, so the headline font on page 4 drifts from page 5 and the accent
						blue wanders between two shades. Lattice removes the canvas. You choose meaning; the engine owns the pixels.
					</SectionHead>
					<WhyCards />
				</div>
			</section>

			<!-- Proof — one receipt from /comparison, a slim band -->
			<section class="py-[clamp(40px,5vw,64px)]">
				<div class="wrap">
					<ProofStrip comparisonHref={url('comparison/')} />
				</div>
			</section>

			<!-- Bring your own model — the agent-workflow wedge -->
			<section class="border-y border-border bg-muted py-[clamp(48px,6vw,88px)]">
				<div class="wrap">
					<ByomSection featuresHref={url('features/')} />
				</div>
			</section>

			<!-- Showcase -->
			<section class="py-[clamp(48px,6vw,88px)]">
				<div class="wrap">
					<SectionHead eyebrow="One source, every palette" title="Change one line. Restyle the whole deck.">
						Watch a single slide move through every palette — in light or dark. This is the one-file palette
						contract paying off: edit one <code class="font-mono text-[0.88em] text-primary">theme:</code> line and the whole deck follows.
					</SectionHead>
					<RestyleShowcase client:visible data={restyleData} />
				</div>
			</section>

			<!-- Next steps -->
			<section class="border-t border-border bg-muted py-[clamp(48px,6vw,88px)]">
				<div class="wrap">
					<SectionHead eyebrow="Where to go next" title="Pick a starting point.">
						The engine ships today; the SlideWright desktop app is on the way.
					</SectionHead>
					<NextSteps links={nextSteps} />
				</div>
			</section>
		</main>

		<footer class="foot">
			<div class="wrap foot-inner">
				<a class="brand" href={url('')}>
					<img class="brand-logo" src={url('lattice-mark-min.svg')} alt="" width="26" height="26" />
					<span class="brand-mark">Lattice</span>
				</a>
				<nav>
					<a href={url('introduction/')}>What is Lattice?</a>
					<a href={url('story/')}>Story</a>
					<a href={url('getting-started/')}>Get started</a>
					<a href={url('playground/')}>Playground</a>
					<a href={url('drawing-board/')}>Drawing Board</a>
					<a href={url('workbench/')}>Workbench</a>
					<a href={url('guides/authoring/')}>Authoring</a>
					<a href={url('components/')}>Components</a>
					<a href={url('features/')}>Features</a>
					<a href={url('comparison/')}>Comparison</a>
					<a href="https://github.com/slidewright/lattice">GitHub</a>
				</nav>
				<span class="legal">Designed by humans. Refined with Claude. · Part of Lattice Style · MIT-licensed</span>
			</div>
		</footer>

		<!-- The marp render engine (window.LatticePlayground) is NOT loaded here
		     anymore — it's injected ON DEMAND by load-engine.ts the first time a
		     live island needs to render (hero mount, field/restyle in view), so the
		     static hero text paints without the ~554KB-gz bundle competing for the
		     main thread. The engine URL is wired through the island data payloads. -->
		<!-- Warm that same bundle into cache per the connection-first policy.
		     allowEager: this is the funnel into the apps, so a fast link fetches it
		     on idle (priming the jump to Playground/Drawing Board); a slow link or
		     Save-Data stays hands-off. See src/lib/prefetch-engine.ts. -->
		<EngineWarm allowEager />
	</body>
</html>
