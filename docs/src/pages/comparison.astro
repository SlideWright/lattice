---
// Lattice comparison page — a standalone Astro route (NOT a Starlight page), so
// it renders full-bleed with the engine's own tokens, a sibling to index.astro.
//
// This is an HONEST, FAIR, OPINIONATED comparison: it credits each rival's real
// strengths, makes Lattice's deterministic/boardroom case with sourced evidence,
// and concedes Lattice's own weaknesses (no WYSIWYG, no live co-editing, a
// learning curve). The cited source-of-truth for every load-bearing claim is
// engineering/decisions/2026-06-14-competitive-analysis.md. Keep them in sync.
//
// Static content only — rendered to HTML server-side (no client: directive →
// zero JS). The page shell (head, topbar, footer, nav toggle) mirrors
// index.astro; SectionHead is reused from the landing for heading consistency.
import '../styles/landing.css';
import SiteHeader from '../components/site/SiteHeader.astro';
import ResourceHints from '../components/site/ResourceHints.astro';
import EngineWarm from '../components/site/EngineWarm.astro';
import { SectionHead } from '../components/landing/sections.tsx';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import { joinBase } from '../lib/base-url.mjs';
import { GITHUB_URL } from '../lib/nav.mjs';

const base = import.meta.env.BASE_URL;
const url = (p) => joinBase(base, p);

// Palette list = the distinct names baked into the generated token CSS — one
// source of truth, same as the landing topbar selector.
const docsRoot = process.cwd();
const tokensCss = readFileSync(join(docsRoot, 'src/styles/lattice-tokens.generated.css'), 'utf8');
const palettes = [...new Set([...tokensCss.matchAll(/data-palette="([^"]+)"/g)].map((m) => m[1]))];

const SOURCE_DOC = `${GITHUB_URL}/blob/main/engineering/decisions/2026-06-14-competitive-analysis.md`;

// ── The matrix ──────────────────────────────────────────────────────────────
// Columns are the axes that actually matter for high-stakes, recurring decks.
// Marks: 'yes' (strong) · 'part' (partial/conditional) · 'no'. Lattice does NOT
// win every row — the ❌s are the point; they make the ✅s credible.
const COLS = ['Lattice', 'AI generators', 'Office + AI', 'Code engines', 'Design / collab'];
const ROWS = [
	{
		axis: 'Deterministic, reproducible output',
		why: 'Same input → identical pixels, every time.',
		marks: ['yes', 'no', 'part', 'yes', 'no'],
	},
	{
		axis: 'Plain-text, git-diffable source',
		why: 'Review a deck like code — line by line.',
		marks: ['yes', 'no', 'no', 'yes', 'no'],
	},
	{
		axis: 'Brand enforced as tokens, not promises',
		why: 'The theme owns the pixels; nobody can drift off-brand.',
		marks: ['yes', 'part', 'part', 'part', 'part'],
	},
	{
		axis: 'Boardroom polish out of the box',
		why: 'Looks finished before you touch it.',
		marks: ['yes', 'part', 'part', 'no', 'yes'],
	},
	{
		axis: 'Export fidelity across formats',
		why: 'It looks the same on every machine you send it to.',
		marks: ['yes', 'no', 'part', 'part', 'part'],
	},
	{
		axis: 'Real-time co-editing',
		why: 'Several people in one live document.',
		marks: ['no', 'yes', 'yes', 'no', 'yes'],
	},
	{
		axis: 'WYSIWYG, no learning curve',
		why: 'Drag, drop, done — no syntax to learn.',
		marks: ['no', 'yes', 'yes', 'no', 'yes'],
	},
	{
		axis: 'Reliably agent / AI-authorable',
		why: 'An LLM can drive it to on-brand output, not just guess.',
		marks: ['yes', 'part', 'part', 'part', 'part'],
	},
	{
		axis: 'No vendor lock-in (your file, offline, MIT)',
		why: 'It runs where your code runs and can never be switched off.',
		marks: ['yes', 'no', 'no', 'yes', 'no'],
	},
];
const MARK = {
	yes: { glyph: '●', label: 'Yes', cls: 'mk-yes' },
	part: { glyph: '◐', label: 'Partial', cls: 'mk-part' },
	no: { glyph: '○', label: 'No', cls: 'mk-no' },
};

// ── The four families ───────────────────────────────────────────────────────
const FAMILIES = [
	{
		name: 'AI generators',
		tools: 'Gamma · Beautiful.ai · Decktopus · Presentations.ai · Plus AI · MagicSlides · SlidesAI · (Tome, RIP)',
		win: 'They are fast. A prompt becomes a presentable first draft in about a minute, and it looks modern out of the box. Nothing kills a blank page quicker. For a throwaway internal deck, grab one.',
		fall: 'They roll the dice every time. Regenerate one slide and the layout reshuffles under you. Exports break: Gamma flattens its PowerPoint to uneditable images and swaps your fonts for Calibri. Every deck drifts toward the same house style. And the numbers come with no sources.',
	},
	{
		name: 'Office suites + AI',
		tools: 'PowerPoint + Copilot · Google Slides + Gemini · Apple Keynote',
		win: 'These own the boardroom today. PowerPoint is the universal format, Google runs the best live co-editing on the market, and everyone already knows how to drive all three. That reach is a real moat.',
		fall: 'The file is a binary blob or a cloud object, so git cannot diff it. You get final_v3_FINAL.pptx instead. Fonts fall back and layouts reflow on the next machine, so “looks right here” means nothing. The brand guide sits in a folder nobody enforces. And Copilot rolls the dice and hallucinates like the rest.',
	},
	{
		name: 'Code engines',
		tools: 'Marp · reveal.js · Slidev · Beamer · Quarto · Spectacle',
		win: 'Our family. Free, open source, plain text, diffable in git, deterministic. If you live in a terminal, these are the lock-in-free choice, and Slidev is the sharpest of the lot.',
		fall: 'None of them ships a design system. You get a handful of themes and raw CSS, then you build every layout yourself. Boardroom polish takes real design work. Several use a browser-print PDF path, and the output changes machine to machine.',
	},
	{
		name: 'Design & collab tools',
		tools: 'Pitch · Canva · Figma Slides',
		win: 'Strong on design, strong on collaboration. A marketing team that wants beautiful slides and live multiplayer editing gets both here. Figma’s design control and Canva’s template range are the real thing.',
		fall: 'The deck lives in someone else’s cloud as a proprietary object. You cannot diff it, cannot rebuild it from text, and you steer the brand through a GUI kit instead of code. Canva output reads as “a Canva template.” Figma Slides still ships PPTX export bugs. Pitch cut most of its staff in 2024 and walked away from presentations.',
	},
];

// ── The receipts (sourced evidence) ─────────────────────────────────────────
const RECEIPTS = [
	{
		stat: '0–20%',
		head: 'How much of an AI deck checks out',
		body: 'One team fed the same 10-slide prompt to six tools and verified every claim. Gamma scored 20%. Beautiful.ai and Canva managed 17%. Tome hit 0%. Canva pinned invented statistics to a real, named school. One tool out of six cited a source.',
		cite: 'Fact-check of 6 AI presentation makers, Feb 2026',
		href: 'https://medium.com/@neel2108/we-fact-checked-6-ai-presentation-makers-heres-how-often-they-hallucinate-90e6093e42fc',
		note: 'One prompt, one deck per tool, so read it as directional. The mechanism holds: an LLM predicts plausible text, it does not look facts up.',
	},
	{
		stat: '×3',
		head: 'Brand violations after a Copilot rollout',
		body: 'One report tracked a European bank that gave Copilot to 42 of its presentation staff. Six weeks in, 8% still used it, slide quality had dropped, and brand violations had tripled. One slide claimed a “43% funding increase.” The real number was 12%.',
		cite: 'Octigen, “Why Copilot for PowerPoint fails,” 2026',
		href: 'https://octigen.com/blog/posts/2026-04-01-copilot-for-powerpoint-reasons-it-fails/',
		note: 'A vendor-adjacent account, specific but not independently confirmed. Microsoft’s own docs tell you to review Copilot output by hand.',
	},
	{
		stat: '25M',
		head: 'Users whose decks got switched off',
		body: 'Tome reached 25 million users. Then its founders shut it down in April 2025: “We killed a product used by 25M people.” Decks nobody exported in time were deleted for good. A Markdown deck in your own git repo cannot be switched off under you.',
		cite: 'VentureBeat, on Tome’s shutdown & pivot, 2025',
		href: 'https://venturebeat.com/technology/tomes-founders-ditch-viral-presentation-app-with-20m-users-to-build-ai',
		note: 'Under 2% of users paid, on less than $4M in revenue against $81M raised. Reach is not the same as value.',
	},
	{
		stat: 'AU$439k',
		head: 'A consultancy refunded a report for AI fabrications',
		body: 'Deloitte refunded part of a AU$439k government report after it surfaced fake references and a made-up court quote. KPMG pulled a report when 40 of its 45 citations were fabricated. The deck is where work like that gets presented.',
		cite: 'ACS / AI Incident Database, Oct 2025',
		href: 'https://ia.acs.org.au/article/2025/deloitte-to-refund-government-over-ai-errors.html',
		note: 'The hardest evidence to argue with: AI deliverables ship with invented facts.',
	},
];

// ── Lattice's honest weaknesses ─────────────────────────────────────────────
const WEAKNESSES = [
	{
		head: 'No WYSIWYG editor',
		body: 'You write Markdown and pick a component. You do not drag a box across a canvas. The Drawing Board shows a live preview, not direct manipulation. If you think in pictures instead of structure, that grates.',
	},
	{
		head: 'A real learning curve',
		body: 'Markdown, a CLI, 53 components, and an authoring contract with rules. Lattice gives you consistency at scale for that. Your first deck still takes longer than typing a prompt into Gamma.',
	},
	{
		head: 'No real-time co-editing',
		body: 'Collaboration runs through git: branches, diffs, pull requests. Not five cursors in one live document. If your team lives in Google Slides, that is a real change of habit.',
	},
	{
		head: 'Setup, not sign-up',
		body: 'You install Node, a headless Chromium, and a Mermaid CLI. It runs offline and phones home to nobody. Clone-and-install still asks more of you than opening a browser tab.',
	},
	{
		head: 'A young ecosystem',
		body: 'Lattice is at v1.0.0. The components and tokens are stable. The desktop app has not shipped, and the tooling around the engine is young.',
	},
	{
		head: 'Not for the stage',
		body: 'No builds, no transitions, no presenter animations. Lattice makes documents you email and archive. For a live keynote, use Keynote.',
	},
];
---

<!doctype html>
<html lang="en" data-palette="indaco" data-mode="light">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<ResourceHints />
		<title>Lattice vs. the alternatives — an honest comparison</title>
		<meta
			name="description"
			content="An honest, sourced comparison of Lattice against AI deck generators (Gamma, Beautiful.ai), office suites (PowerPoint, Google Slides), code engines (Marp, Slidev), and design tools (Canva, Pitch) — including where Lattice itself falls short."
		/>
		<link rel="icon" type="image/svg+xml" href={url('favicon.svg')} />
		<script is:inline>
			(function () {
				var r = document.documentElement;
				try {
					var p = localStorage.getItem('lattice-docs-palette');
					if (p) r.setAttribute('data-palette', p);
					var m = localStorage.getItem('lattice-docs-mode');
					if (m === 'light' || m === 'dark') r.setAttribute('data-mode', m);
					else if (window.matchMedia && matchMedia('(prefers-color-scheme: dark)').matches)
						r.setAttribute('data-mode', 'dark');
				} catch (e) {}
			})();
		</script>
		<style>
			/* Comparison-matrix marks — colour-blind-safe glyphs + tokenised hues. */
			.mk { display: inline-flex; align-items: center; justify-content: center; font-size: 18px; line-height: 1; }
			.mk-yes { color: var(--accent); }
			.mk-part { color: var(--text-muted); }
			.mk-no { color: var(--border); }
			.cmp-table { border-collapse: collapse; width: 100%; min-width: 720px; }
			.cmp-table th, .cmp-table td { padding: 13px 14px; text-align: center; border-bottom: 1px solid var(--border); }
			.cmp-table thead th { font-size: 13px; font-weight: 600; color: var(--text-heading); vertical-align: bottom; }
			.cmp-table thead th.col-lattice { color: var(--accent); }
			.cmp-table td.axis, .cmp-table th.axis { text-align: left; width: 38%; }
			.cmp-table tbody tr:hover { background: var(--bg-alt); }
			.cmp-table .col-lattice { background: color-mix(in srgb, var(--accent) 6%, transparent); }
		</style>
	</head>
	<body>
		<SiteHeader palettes={palettes} />

		<main>
			<!-- Hero -->
			<section class="py-[clamp(48px,7vw,96px)] pb-[clamp(32px,4vw,56px)]">
				<div class="wrap max-w-[52rem]">
					<p class="m-0 mb-4 font-mono text-[12px] font-medium uppercase tracking-[0.16em] text-primary">
						An honest comparison
					</p>
					<h1 class="m-0 mb-5 font-[var(--font-display)] text-[clamp(34px,5.2vw,60px)] font-bold leading-[1.04] tracking-[-0.02em] text-[var(--text-heading)]">
						The artsy deck wins the demo. The deterministic deck wins the boardroom.
					</h1>
					<p class="m-0 mb-4 text-[clamp(17px,2vw,20px)] leading-[1.5] text-foreground">
						AI tools spin up gorgeous slides in seconds. We tested them. We tested the office suites, the design apps,
						and the code engines too. Some of them do real work. But a board deck answers to investors, regulators, and
						legal. Beautiful was never the bar. The bar is <strong>correct output, on brand, the same every time</strong>,
						and most of these tools miss it.
					</p>
					<p class="m-0 text-[15.5px] leading-[1.6] text-muted-foreground">
						This page names names and shows its sources. It also tells you where Lattice is the wrong call, because a
						comparison you cannot trust is worth nothing.
					</p>
					<div class="mt-8 flex flex-wrap gap-3">
						<a
							href={url('playground/')}
							class="inline-flex items-center rounded-lg bg-primary px-5 py-2.5 text-[15px] font-semibold shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-lg"
							style="color: var(--on-accent);"
						>
							Try the playground
						</a>
						<a
							href="#matrix"
							class="inline-flex items-center rounded-lg border border-border bg-card px-5 py-2.5 text-[15px] font-semibold transition-colors hover:border-primary"
							style="color: var(--text-body);"
						>
							Jump to the matrix
						</a>
					</div>
				</div>
			</section>

			<!-- Thesis -->
			<section class="border-t border-border py-[clamp(48px,6vw,88px)]">
				<div class="wrap">
					<SectionHead
						eyebrow="The argument"
						title="Speed and control are the same coin."
					>
						The choices that make AI generators fast are the same choices that break them. Auto-layout, web-first
						rendering, one stochastic roll for the whole deck. Those give you the speed. They also give you broken
						exports, brand drift, sameness, and output you cannot reproduce. You do not get one without the other.
					</SectionHead>
					<div class="grid grid-cols-1 gap-[18px] lg:grid-cols-[1.15fr_1fr]">
						<div class="rounded-xl border border-border bg-card p-[26px] shadow-sm">
							<h3 class="m-0 mb-3 font-[var(--font-body)] text-[19px] font-semibold tracking-[-0.01em] text-[var(--text-heading)]">
								So split the layers.
							</h3>
							<p class="m-0 mb-3 text-[15.5px] leading-[1.6] text-foreground">
								Let the model draft the words. Then hand those words to a deterministic engine that owns every visual
								decision. <strong>The AI writes. The engine renders</strong> — same pixels, on brand, every time.
								Regulated industries already work this way: probabilistic reasoning, reproducible output.
							</p>
							<p class="m-0 text-[15.5px] leading-[1.6] text-foreground">
								AI generators do the opposite. They fuse content, facts, and design into one roll and get each one
								partly wrong. That is the worst way to fail, because a single invented number poisons trust in
								everything else on the page.
							</p>
						</div>
						<div class="flex flex-col gap-[18px]">
							<blockquote class="m-0 rounded-xl border border-border bg-muted p-[22px]">
								<p class="m-0 mb-2.5 text-[16px] italic leading-[1.5] text-[var(--text-heading)]">
									“A beautiful slide with a confident-looking statistic and no citation is just an opinion with good
									typography.”
								</p>
								<footer class="text-[13px] text-muted-foreground">— Fact-check of 6 AI presentation makers, 2026</footer>
							</blockquote>
							<blockquote class="m-0 rounded-xl border border-border bg-muted p-[22px]">
								<p class="m-0 mb-2.5 text-[16px] italic leading-[1.5] text-[var(--text-heading)]">
									“When a model produces a different output for the same input on consecutive runs, that is not a
									feature — it is a compliance violation.”
								</p>
								<footer class="text-[13px] text-muted-foreground">— MightyBot, <em>What is Deterministic AI</em></footer>
							</blockquote>
						</div>
					</div>
				</div>
			</section>

			<!-- Concession first -->
			<section class="border-y border-border bg-muted py-[clamp(48px,6vw,88px)]">
				<div class="wrap">
					<SectionHead
						eyebrow="Credit where it’s due"
						title="Where the others beat us."
					>
						These tools are not bad, and the people who built them are not fools. If you need one of the things below,
						use them, not Lattice. Here is what they do better.
					</SectionHead>
					<div class="grid grid-cols-1 gap-[18px] sm:grid-cols-2 lg:grid-cols-4">
						<div class="rounded-xl border border-border bg-card p-[22px] shadow-sm">
							<h3 class="m-0 mb-2 text-[16px] font-semibold text-[var(--text-heading)]">Raw speed</h3>
							<p class="m-0 text-[14.5px] leading-[1.55] text-foreground">One sentence becomes a full draft in under a minute. Nothing beats an AI generator at killing the blank page.</p>
						</div>
						<div class="rounded-xl border border-border bg-card p-[22px] shadow-sm">
							<h3 class="m-0 mb-2 text-[16px] font-semibold text-[var(--text-heading)]">Real-time collaboration</h3>
							<p class="m-0 text-[14.5px] leading-[1.55] text-foreground">Google Slides runs the best live multiplayer in the business. Several people, one document, right now. Lattice cannot match it.</p>
						</div>
						<div class="rounded-xl border border-border bg-card p-[22px] shadow-sm">
							<h3 class="m-0 mb-2 text-[16px] font-semibold text-[var(--text-heading)]">Ubiquity</h3>
							<p class="m-0 text-[14.5px] leading-[1.55] text-foreground">Everyone can open a <code class="font-mono text-[0.88em] text-primary">.pptx</code>. PowerPoint runs the boardroom, and that reach is a real moat.</p>
						</div>
						<div class="rounded-xl border border-border bg-card p-[22px] shadow-sm">
							<h3 class="m-0 mb-2 text-[16px] font-semibold text-[var(--text-heading)]">Point-and-click ease</h3>
							<p class="m-0 text-[14.5px] leading-[1.55] text-foreground">WYSIWYG and template galleries need no syntax at all. For a one-off casual deck, that immediacy is hard to give up.</p>
						</div>
					</div>
				</div>
			</section>

			<!-- The four families -->
			<section class="py-[clamp(48px,6vw,88px)]">
				<div class="wrap">
					<SectionHead
						eyebrow="The field"
						title="Four families. One honest read on each."
					>
						The presentation world splits into four camps. Here is what each one is for, and where each one breaks
						once the deck has to answer to a board.
					</SectionHead>
					<div class="grid grid-cols-1 gap-[18px] lg:grid-cols-2">
						{FAMILIES.map((f) => (
							<div class="flex flex-col rounded-xl border border-border bg-card p-[26px] shadow-sm">
								<h3 class="m-0 mb-1 font-[var(--font-body)] text-[20px] font-semibold tracking-[-0.01em] text-[var(--text-heading)]">
									{f.name}
								</h3>
								<p class="m-0 mb-4 font-mono text-[12.5px] leading-[1.5] text-muted-foreground">{f.tools}</p>
								<p class="m-0 mb-3 text-[14.5px] leading-[1.6] text-foreground">
									<span class="font-semibold text-primary">Where it wins. </span>{f.win}
								</p>
								<p class="m-0 text-[14.5px] leading-[1.6] text-foreground">
									<span class="font-semibold text-[var(--text-heading)]">Where it falls short. </span>{f.fall}
								</p>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- The matrix -->
			<section id="matrix" class="scroll-mt-20 border-y border-border bg-muted py-[clamp(48px,6vw,88px)]">
				<div class="wrap">
					<SectionHead
						eyebrow="Side by side"
						title="The capabilities that decide a high-stakes deck."
					>
						We score capability, not feature count. Lattice loses rows here. It trades live collaboration and
						point-and-click ease for reproducible output, enforced brand, and a file you own. That is the whole pitch.
					</SectionHead>
					<div class="overflow-x-auto rounded-xl border border-border bg-card">
						<table class="cmp-table">
							<thead>
								<tr>
									<th class="axis">Capability</th>
									{COLS.map((c) => (
										<th class={c === 'Lattice' ? 'col-lattice' : undefined}>{c}</th>
									))}
								</tr>
							</thead>
							<tbody>
								{ROWS.map((r) => (
									<tr>
										<td class="axis">
											<span class="block text-[14.5px] font-semibold text-[var(--text-heading)]">{r.axis}</span>
											<span class="block text-[12.5px] leading-[1.45] text-muted-foreground">{r.why}</span>
										</td>
										{r.marks.map((m, i) => (
											<td class={COLS[i] === 'Lattice' ? 'col-lattice' : undefined}>
												<span class={`mk ${MARK[m].cls}`} role="img" aria-label={MARK[m].label}>{MARK[m].glyph}</span>
											</td>
										))}
									</tr>
								))}
							</tbody>
						</table>
					</div>
					<p class="mt-4 flex flex-wrap items-center gap-x-5 gap-y-1.5 text-[13px] text-muted-foreground">
						<span><span class="mk mk-yes align-middle">●</span> Strong</span>
						<span><span class="mk mk-part align-middle">◐</span> Partial / conditional</span>
						<span><span class="mk mk-no align-middle">○</span> No</span>
						<span class="italic">Columns are families; individual tools vary — see the notes above and the sources below.</span>
					</p>
				</div>
			</section>

			<!-- The receipts -->
			<section class="py-[clamp(48px,6vw,88px)]">
				<div class="wrap">
					<SectionHead
						eyebrow="The receipts"
						title="The case, with sources attached."
					>
						Strong claims need evidence. Every claim below links out and carries the caveat a skeptical reader should
						want.
					</SectionHead>
					<div class="grid grid-cols-1 gap-[18px] sm:grid-cols-2">
						{RECEIPTS.map((r) => (
							<div class="flex flex-col rounded-xl border border-border bg-card p-[26px] shadow-sm">
								<div class="mb-3 font-[var(--font-display)] text-[clamp(34px,4vw,46px)] font-bold leading-none text-primary">
									{r.stat}
								</div>
								<h3 class="m-0 mb-2.5 font-[var(--font-body)] text-[17px] font-semibold leading-[1.3] text-[var(--text-heading)]">
									{r.head}
								</h3>
								<p class="m-0 mb-3 text-[14.5px] leading-[1.6] text-foreground">{r.body}</p>
								<p class="m-0 mb-3 text-[13px] italic leading-[1.5] text-muted-foreground">{r.note}</p>
								<a
									href={r.href}
									class="mt-auto inline-flex w-fit text-[13px] font-semibold text-primary hover:underline"
									rel="nofollow noopener"
									target="_blank"
								>
									{r.cite} ↗
								</a>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- Isn't this just Marp? -->
			<section class="border-y border-border bg-muted py-[clamp(48px,6vw,88px)]">
				<div class="wrap">
					<SectionHead
						eyebrow="The fair question"
						title="“Isn’t Lattice just Marp with a coat of paint?”"
					>
						No. Lattice runs on its own engine and its own design system. Marp is one export path out of a
						Lattice deck; the engine inside is ours.
					</SectionHead>
					<div class="grid grid-cols-1 gap-[18px] lg:grid-cols-2">
						<div class="rounded-xl border border-border bg-card p-[26px] shadow-sm">
							<h3 class="m-0 mb-3 text-[17px] font-semibold text-[var(--text-heading)]">What we started from</h3>
							<p class="m-0 text-[14.5px] leading-[1.65] text-foreground">
								One good idea: write a deck in Markdown and render it through headless Chromium to PDF. Plain text
								buys determinism and git diffs, true of every code engine. We built on Marp’s engine for the early
								versions, then replaced it with our own at v1.0.0.
							</p>
						</div>
						<div class="rounded-xl border border-border bg-card p-[26px] shadow-sm">
							<h3 class="m-0 mb-3 text-[17px] font-semibold text-[var(--text-heading)]">What Lattice is now</h3>
							<p class="m-0 mb-3 text-[14.5px] leading-[1.65] text-foreground">
								Marp’s own docs say it has <strong>“no component system, design tokens, slots, or layout
								primitives,”</strong> and it ships three generic themes. Lattice brings all of it:
							</p>
							<ul class="m-0 list-disc space-y-1.5 pl-5 text-[14.5px] leading-[1.55] text-foreground">
								<li><strong>53 components</strong> across 12 buckets. Pick the meaning, get the composition.</li>
								<li>A <strong>design-token system</strong> and <strong>14 editorial palettes + 4 colour-blind-safe</strong>. Layouts never name a colour.</li>
								<li><strong>Boardroom-grade defaults</strong> and WCAG-AA contrast in every palette, light and dark.</li>
								<li>An <strong>owned, pinned render engine</strong>. We dropped the Marp dependency at v1.0.0 and pinned the toolchain end to end. It renders plain HTML sections, not SVG-wrapped slides, so modern CSS — container queries, counters, masks — works natively and layout holds across browsers.</li>
								<li><strong>Agent authoring.</strong> A machine catalog and a shared linter steer an LLM to on-brand decks instead of guesses.</li>
							</ul>
						</div>
					</div>
				</div>
			</section>

			<!-- On AI: bring your own model -->
			<section class="border-t border-border py-[clamp(48px,6vw,88px)]">
				<div class="wrap">
					<SectionHead
						eyebrow="On AI"
						title="Bring your own model. We don’t own the AI layer."
					>
						The AI generators own the model. You get theirs, priced their way, swapped out from under you whenever
						they like. Lattice takes the opposite stance: the AI layer is yours. You pick the model today, and you keep
						that choice tomorrow.
					</SectionHead>
					<div class="grid grid-cols-1 gap-[18px] lg:grid-cols-3">
						<div class="flex flex-col rounded-xl border border-border bg-card p-[26px] shadow-sm">
							<h3 class="m-0 mb-3 font-[var(--font-body)] text-[18px] font-semibold tracking-[-0.01em] text-[var(--text-heading)]">
								Your model, your choice
							</h3>
							<p class="m-0 mb-3 text-[14.5px] leading-[1.6] text-foreground">
								Lattice talks to <strong>OpenRouter</strong>, so you can drive any of 500+ models — Claude, GPT,
								Gemini, DeepSeek, Llama, and the free tiers — and switch whenever you want.
							</p>
							<p class="m-0 text-[14.5px] leading-[1.6] text-foreground">
								We build and test Lattice on <strong>Claude</strong>, because we think it’s the best, and we default to
								<strong>Sonnet</strong> for the best work per dollar. It’s a default, not a cage.
							</p>
						</div>
						<div class="flex flex-col rounded-xl border border-border bg-card p-[26px] shadow-sm">
							<h3 class="m-0 mb-3 font-[var(--font-body)] text-[18px] font-semibold tracking-[-0.01em] text-[var(--text-heading)]">
								Built to keep the bill down
							</h3>
							<p class="m-0 mb-3 text-[14.5px] leading-[1.6] text-foreground">
								We use AI too, and we know how fast the meter runs. So the Coach finds and fixes most issues with
								<strong>no model call at all</strong> — you spend tokens only when you actually ask the AI to write
								something.
							</p>
							<p class="m-0 text-[14.5px] leading-[1.6] text-foreground">
								When it does call out, Lattice <strong>caches the instructions</strong> across your whole session and
								sends the model a <strong>compact catalog</strong> instead of a wall of docs. Less in, less out, lower
								bill.
							</p>
						</div>
						<div class="flex flex-col rounded-xl border border-border bg-card p-[26px] shadow-sm">
							<h3 class="m-0 mb-3 font-[var(--font-body)] text-[18px] font-semibold tracking-[-0.01em] text-[var(--text-heading)]">
								You hold the controls
							</h3>
							<p class="m-0 mb-3 text-[14.5px] leading-[1.6] text-foreground">
								OpenRouter handles billing and routing; Lattice adds a layer on top. Pick a model with its
								<strong>live price</strong> in front of you. Set a <strong>session budget</strong> — Lattice warns at
								80% and can stop at 100%.
							</p>
							<p class="m-0 text-[14.5px] leading-[1.6] text-foreground">
								Your spend and your account balance stay on screen the whole time. No surprise invoice at the end of
								the month.
							</p>
						</div>
					</div>
					<p class="mt-6 max-w-[68ch] text-[14px] leading-[1.6] text-muted-foreground">
						Today you connect your own OpenRouter account in one click — your key, your credits, your spend.
						<span class="font-semibold text-[var(--text-heading)]">Next:</span> bring your own provider key, so you can
						point Lattice straight at Anthropic or OpenAI and cut out the middle layer entirely.
					</p>
				</div>
			</section>

			<!-- Our warts -->
			<section class="py-[clamp(48px,6vw,88px)]">
				<div class="wrap">
					<SectionHead
						eyebrow="Where we’re weaker"
						title="When Lattice is the wrong tool."
					>
						An honest page owns its weak spots. If any of these is a hard requirement, use something else. We would
						rather lose you here than disappoint you later.
					</SectionHead>
					<div class="grid grid-cols-1 gap-[18px] sm:grid-cols-2 lg:grid-cols-3">
						{WEAKNESSES.map((w) => (
							<div class="rounded-xl border border-border bg-card p-[24px] shadow-sm">
								<h3 class="m-0 mb-2 text-[16px] font-semibold text-[var(--text-heading)]">{w.head}</h3>
								<p class="m-0 text-[14.5px] leading-[1.6] text-foreground">{w.body}</p>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- Where Lattice is going (killer-feature slot) -->
			<section class="border-y border-border bg-muted py-[clamp(48px,6vw,88px)]">
				<div class="wrap">
					<SectionHead
						eyebrow="Where Lattice is going"
						title="The deterministic core is the floor, not the ceiling."
					>
						Everything above ships today at v1.0.0. Every roadmap item runs on the same engine, with the same
						guarantees, and adds reach without giving any of that up.
					</SectionHead>
					<div class="grid grid-cols-1 gap-[18px] sm:grid-cols-2 lg:grid-cols-3">
						<div class="rounded-xl border border-border bg-card p-[24px] shadow-sm">
							<h3 class="m-0 mb-2 text-[16px] font-semibold text-[var(--text-heading)]">SlideWright desktop</h3>
							<p class="m-0 text-[14.5px] leading-[1.6] text-foreground">A native app wraps the same engine, for people who want the determinism and skip the terminal.</p>
						</div>
						<div class="rounded-xl border border-border bg-card p-[24px] shadow-sm">
							<h3 class="m-0 mb-2 text-[16px] font-semibold text-[var(--text-heading)]">Deeper agent authoring</h3>
							<p class="m-0 text-[14.5px] leading-[1.6] text-foreground">The machine catalog and linter make Lattice an easy target for an LLM, so an agent drafts a deck that lands on brand instead of guessing at layout.</p>
						</div>
						<div class="rounded-xl border border-primary p-[24px] shadow-sm" style="background: color-mix(in srgb, var(--accent) 7%, transparent);">
							<h3 class="m-0 mb-2 text-[16px] font-semibold text-primary">One we’re not ready to name</h3>
							<p class="m-0 text-[14.5px] leading-[1.6] text-foreground">One more capability is coming. It changes what a deterministic deck engine can do. We will ship it when it is ready.</p>
						</div>
					</div>
				</div>
			</section>

			<!-- CTA -->
			<section class="py-[clamp(48px,6vw,88px)]">
				<div class="wrap">
					<SectionHead eyebrow="See for yourself" title="See it yourself." />
					<div class="grid grid-cols-1 gap-[18px] sm:grid-cols-2 lg:grid-cols-3">
						<a
							href={url('playground/')}
							class="group block rounded-xl border border-border bg-card p-[26px] text-card-foreground shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary hover:shadow-lg"
