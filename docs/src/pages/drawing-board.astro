---
// The Drawing Board — a first-class, browser-only deck-authoring workspace.
//
// A sibling to the playground, NOT an evolution of it (proposal:
// engineering/decisions/2026-06-07-drawing-board-architect.md). Three resizable
// panels — the Architect · the editor · the live filmstrip — over a deck rail.
// Reuses render path #2 client-side: window.LatticePlayground (from
// docs/public/playground/lattice-playground.js) + the runtime bundle, exactly
// like the playground, so no 4th render path is introduced.
//
// Phase 1 / Slice 0-1 here: the shell, resizers, and the editor->engine
// heartbeat, with the Architect as a crafted empty-state. Persistence (Slice 3),
// export (Slice 4), and the deterministic Architect (Slice 5) fill the framed
// panels in later slices. Build plan:
// engineering/decisions/2026-06-07-drawing-board-phase-1-plan.md.
import { createRequire } from 'node:module';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import '../styles/landing.css';
import '../styles/drawing-board.css';
import { SLIDE_BOX } from '../playground/frame-css.js';
import { assetBase } from '../playground/asset-version.mjs';
import { joinBase } from '../lib/base-url.mjs';
import { pickGrammarVariants } from '../playground/architect-knowledge.js';

const docsRoot = process.cwd();
const repoRoot = join(docsRoot, '..');
const require = createRequire(import.meta.url);
const { loadAll, manifestBucket } = require(join(repoRoot, 'lib/components', 'index.js'));
const manifests = loadAll();

// Compact catalog for the Architect's onboarding retrieval + scaffolding, and the
// Lattice primer fed to Converse so the cloud model knows how to AUTHOR each layout
// (not just that it exists): name + bucket + tags + one-line description + the
// authoring skeleton + variants + slot contracts.
const obCatalog = manifests.map((m) => ({
	name: m.name,
	bucket: manifestBucket(m),
	tags: m.tags || [],
	summary: m.description || '',
	skeleton: m.skeleton || m.sample || `<!-- _class: ${m.name} -->\n`,
	variants: m.variants || [],
	// Variants whose AUTHORING grammar differs from the base skeleton (e.g.
	// `list-tabular metric` → `1. Name `value``) ship their own skeleton so the
	// cloud model authors/validates them correctly instead of against the base.
	variantSkeletons: pickGrammarVariants(m),
	slots: Object.entries(m.slots || {}).map(([name, v]) => ({
		name,
		required: !!v.required,
		description: (v.description || '').slice(0, 240),
	})),
}));

// The Architect's deterministic linter runs in the browser against the same
// pure lint-core the Node CLI uses; only the name/modifier VOCABULARY is data,
// computed here at build time from the live manifests and shipped in the page.
const { buildVocab } = require(join(repoRoot, 'lib/authoring', 'lint.js'));
const _vocab = buildVocab(manifests);
// Serialize the map region/group vocab (Sets → arrays) for the page handoff,
// so the Architect's "did you mean" resolves country/state names client-side
// from static data instead of asking the model.
const mapRegions = Object.fromEntries(
	Object.entries(_vocab.mapRegions || {}).map(([k, v]) => [k, { valid: [...v.valid], names: v.names }]),
);
const lintVocab = {
	names: [..._vocab.names],
	modifiers: [..._vocab.modifiers],
	universalModifiers: [..._vocab.universalModifiers],
	mapRegions,
};

const base = import.meta.env.BASE_URL;
const url = (p) => joinBase(base, p);
// Cache-busted prefix for the playground's runtime-fetched assets (see
// asset-version.mjs); the bare `playground/` route is unchanged.
const pg = assetBase();

const tokensCss = readFileSync(join(docsRoot, 'src/styles/lattice-tokens.generated.css'), 'utf8');
const palettes = [...new Set([...tokensCss.matchAll(/data-palette="([^"]+)"/g)].map((m) => m[1]))];
const titleCase = (s) => s.replace(/(^|-)(\w)/g, (_, sep, c) => (sep ? ' ' : '') + c.toUpperCase());

// Starter deck = a known-good sample (the hero component's), so the heartbeat
// renders something real on first load without risking an authoring footgun.
const heroComp = manifests.find((m) => m.showcase && m.showcase.hero);
const starter =
	(heroComp && heroComp.sample) ||
	'<!-- _class: title silent -->\n\n`the drawing board`\n\n# A new deck\n\nStart sketching — the preview tracks every edit.\n';

const dbData = JSON.stringify({
	themeBase: url(pg + 'themes/'),
	runtimeUrl: url(pg + 'lattice-runtime.js'),
	defaultPalette: 'indaco',
	slideBox: SLIDE_BOX,
	starter,
	lintVocab,
	catalog: obCatalog,
});
---

<!doctype html>
<html lang="en" data-palette="indaco" data-mode="light">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>The Drawing Board — author Lattice decks in your browser</title>
		<meta
			name="description"
			content="A browser-only authoring workspace for Lattice decks: write Markdown, watch it render live, with the Architect at your side."
		/>
		<link rel="icon" type="image/png" href={url('lattice-logo.png')} />
		<script is:inline>
			(function () {
				var r = document.documentElement;
				try {
					var p = localStorage.getItem('lattice-docs-palette');
					if (p) r.setAttribute('data-palette', p);
					var m = localStorage.getItem('lattice-docs-mode');
					if (m === 'light' || m === 'dark') r.setAttribute('data-mode', m);
					else if (window.matchMedia && matchMedia('(prefers-color-scheme: dark)').matches) r.setAttribute('data-mode', 'dark');
				} catch (e) {}
			})();
		</script>
	</head>
	<body class="db-page" data-pane="editor">
		<header class="topbar">
			<div class="wrap topbar-inner" style="max-width:none">
				<a class="brand" href={url('')}>
					<img class="brand-logo" src={url('lattice-logo.png')} alt="" width="30" height="30" />
					<span class="brand-mark">Lattice</span>
				</a>
				<nav class="topnav" id="topnav">
					<a class="navlink" href={url('getting-started/')}>Get started</a>
					<a class="navlink" href={url('guides/authoring/')}>Guides</a>
					<a class="navlink" href={url('playground/')}>Playground</a>
					<a class="navlink" href={url('drawing-board/')} aria-current="page">Drawing Board</a>
					<a class="navlink" href={url('components/')}>Components</a>
					<a class="navlink" href="https://github.com/slidewright/lattice">GitHub</a>
				</nav>
				<div class="topbar-actions">
					<div class="controls">
						<select class="palette-select" id="palette" aria-label="Palette">
							{palettes.map((p) => <option value={p}>{titleCase(p)}</option>)}
						</select>
						<button class="mode-toggle" id="mode-toggle" aria-label="Toggle light / dark" title="Toggle light / dark"></button>
					</div>
					<button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu" aria-controls="topnav" aria-expanded="false"></button>
				</div>
			</div>
		</header>

		<div class="db-workspace" id="db-workspace">
			<!-- The Architect — deterministic onboarding + live review (Slice 5). The
			     deck library + checkpoint history fold into the "Decks" popover in this
			     panel's head; workspace + on-device-AI preferences into the settings
			     chip beside it. (The old standalone rail is retired.) -->
			<section class="db-panel db-architect" id="db-architect">
				<div class="db-panel-head">
					<span class="db-panel-title">The Architect</span>
					<span class="db-spacer"></span>
					<!-- The deck-name gateway: the control names the deck you're on, and
					     opening it reveals everything you can do with decks (switch / new /
					     versions). Replaces the old ambiguous "Decks" + "New" labels. -->
					<button class="db-deck-gw" id="db-decks-open" aria-haspopup="dialog" aria-expanded="false" aria-controls="db-decks-pop" title="Decks &amp; versions">
						<span class="db-deck-gw-dot" aria-hidden="true"></span>
						<span class="db-deck-gw-name" id="db-deck-gw-name">Deck</span>
					</button>
					<!-- Settings entry that also signals the live AI tier: gear (tap to
					     configure) + short tier word + a status dot (filled = AI active,
					     hollow = deterministic floor). Label text driven by settings JS. -->
					<button class="db-model-chip is-floor" id="db-model-chip" aria-haspopup="dialog" aria-expanded="false" aria-controls="db-settings-drawer" title="Settings — workspace &amp; on-device AI"><span class="db-model-chip-label">Floor</span></button>
				</div>
				<div class="db-panel-body db-arch-body" id="db-arch-body" data-arch-mode="coach" data-converse-ready="false">
					<div class="db-arch-scroll">
						<div class="db-arch-mark">
							<span class="db-arch-glyph" aria-hidden="true">A</span>
							<span class="db-arch-name">the Architect<small>your deck partner</small></span>
						</div>
						<div class="db-arch-onboard" id="db-arch-onboard"></div>

						<!-- Coach (deterministic) vs Converse (generative) — the help mode for
						     this deck. Coach is buttons + result cards (no fake chat); Converse
						     is a real conversation, shown only when a real model is available. -->
						<div class="db-arch-modes" id="db-arch-modes" role="tablist" aria-label="Architect mode">
							<button class="db-arch-mode" data-mode="coach" role="tab" aria-selected="true">Coach</button>
							<button class="db-arch-mode" data-mode="converse" role="tab" aria-selected="false">Converse</button>
						</div>

						<!-- Coach view: the deterministic assessment + action chips. -->
						<div class="db-coach" data-view="coach">
							<!-- The Architect's post-onboarding greeting (Drafting/Freehand) lands
							     here — visible in the default Coach mode. -->
							<p class="db-coach-intro" id="db-coach-intro" aria-live="polite"></p>
							<div class="db-arch-review" id="db-arch-review" aria-live="polite"></div>
							<div class="db-coach-chips" id="db-coach-chips"></div>
							<div class="db-coach-card" id="db-coach-card" aria-live="polite"></div>
						</div>

						<!-- Converse view: the real conversation (thread). -->
						<div class="db-converse" data-view="converse">
							<div class="db-arch-chat" id="db-arch-chat" aria-live="polite"></div>
							<div class="db-converse-empty" id="db-converse-empty">
								<p>Converse is a real AI conversation about your deck — the ask, a specific slide, tightening a line. (Coach handles the scores and fixes.)</p>
								<div class="db-converse-connect-wrap" id="db-converse-connect-wrap">
									<div class="db-converse-connect-row" id="db-converse-connect-row">
										<button class="db-btn db-btn-primary db-converse-connect-or" id="db-converse-connect-or" type="button">Connect OpenRouter — your account</button>
									</div>
									<p class="db-converse-fine">OpenRouter uses your own account credits via one-click sign-in — pick any of 500+ models. Your deck’s text is sent to the chosen model to generate replies. Prefer on-device? Turn it on from the settings chip.</p>
								</div>
							</div>
						</div>
					</div>
					<!-- Jump to top / latest — shown only when the panel overflows and you're
					     away from that end, so long threads + edit cards aren't a scroll slog. -->
					<div class="db-arch-jump" id="db-arch-jump">
						<button class="db-arch-jump-btn" data-dir="top" type="button" aria-label="Scroll to top" title="Top" hidden></button>
						<button class="db-arch-jump-btn" data-dir="bottom" type="button" aria-label="Scroll to latest" title="Latest" hidden></button>
					</div>
					<!-- The composer — only in Converse, only when a real model backs it. -->
					<form class="db-arch-composer" id="db-arch-composer">
						<textarea id="db-arch-input" rows="1" placeholder="Ask the Architect about your deck…" aria-label="Message the Architect"></textarea>
						<button type="submit" class="db-arch-send" aria-label="Send"></button>
					</form>
				</div>
			</section>

			<div class="db-resizer" id="db-resize-left" data-target="arch" role="separator" aria-orientation="vertical" aria-label="Resize the Architect panel"></div>

			<!-- Editor -->
			<section class="db-panel db-editor" id="db-editor">
				<div class="db-panel-head">
					<span class="db-panel-title">Markdown</span>
					<button class="db-btn db-focus-open" id="db-focus-open" hidden title="Edit the diagram/math block under the cursor in isolation">Focus</button>
					<div class="db-refine" id="db-refine-wrap">
						<button class="db-btn db-refine-open" id="db-refine-open" hidden aria-haspopup="menu">Refine</button>
						<div class="db-refine-pop" id="db-refine-menu" role="menu" hidden></div>
					</div>
					<span class="db-spacer"></span>
					<div class="db-export" id="db-export-wrap">
						<button class="db-btn" id="db-export" aria-haspopup="menu" aria-expanded="false" title="Export this deck">Export</button>
						<div class="db-export-menu" id="db-export-menu" role="menu" hidden>
							<button class="db-menu-item" type="button" data-export="md" role="menuitem">Markdown<small>.md — the source</small></button>
							<button class="db-menu-item" type="button" data-export="pdf" role="menuitem">PDF<small>.pdf — one click</small></button>
							<button class="db-menu-item" type="button" data-export="pptx" role="menuitem">PowerPoint<small>.pptx — image slides</small></button>
							<button class="db-menu-item" type="button" data-export="print" role="menuitem">Print<small>vector + selectable text</small></button>
						</div>
					</div>
				</div>
				<div class="db-panel-body">
					<!-- CodeMirror mounts into #db-editor-host; the textarea is the no-JS /
					     pre-hydration fallback and the source of the starter text. -->
					<div class="db-editor-host" id="db-editor-host">
						<textarea id="db-editor-ta" spellcheck="false" aria-label="Lattice markdown editor">{starter}</textarea>
					</div>
				</div>
			</section>

			<div class="db-resizer" id="db-resize-right" data-target="preview" role="separator" aria-orientation="vertical" aria-label="Resize the preview panel"></div>

			<!-- Preview filmstrip -->
			<section class="db-panel db-preview" id="db-preview">
				<div class="db-panel-head">
					<span class="db-panel-title">Slides</span>
					<button class="db-btn db-practice-open" id="db-practice-open" title="Rehearse full-screen with pacing">Practice</button>
					<span class="db-spacer"></span>
					<span class="db-status" id="db-status">Ready.</span>
				</div>
				<div class="db-panel-body">
					<iframe id="db-frame" class="db-filmstrip" title="Rendered slides"></iframe>
				</div>
			</section>

			<!-- Mobile pane switcher (shown <=1024px) -->
			<nav class="db-mobile-tabs" role="tablist" aria-label="Workspace panes">
				<button class="db-mobile-tab" data-pane="architect" role="tab" aria-selected="false">Architect</button>
				<button class="db-mobile-tab" data-pane="editor" role="tab" aria-selected="true">Edit</button>
				<button class="db-mobile-tab" data-pane="preview" role="tab" aria-selected="false">Preview</button>
			</nav>

			<!-- Slide-in drawers — decks + settings. Modal panels that slide from the
			     left over a shared scrim, mirroring the component-reference nav drawer
			     (transform + scrim + body.db-drawer-open), with a scrollable body. -->
			<button class="db-drawer-scrim" id="db-drawer-scrim" type="button" aria-label="Close" hidden></button>

			<!-- The deck drawer — the deck-name gateway's destination. Two axes, two
			     tabs: Decks (space — which deck: switch / new) and Versions (time —
			     which state of this deck: view / restore, read-only until you act). -->
			<aside class="db-drawer db-drawer-decks" id="db-decks-pop" role="dialog" aria-modal="true" aria-label="Decks and versions" aria-hidden="true">
				<div class="db-drawer-head">
					<span class="db-panel-title">Decks</span>
					<span class="db-spacer"></span>
					<button class="db-drawer-close" data-drawer-close aria-label="Close" title="Close"></button>
				</div>
				<div class="db-drawer-tabs" role="tablist" aria-label="Decks and versions">
					<button class="db-drawer-tab is-on" id="db-tab-decks" type="button" role="tab" aria-selected="true" aria-controls="db-pane-decks" data-pane="decks">Decks</button>
					<button class="db-drawer-tab" id="db-tab-versions" type="button" role="tab" aria-selected="false" aria-controls="db-pane-versions" data-pane="versions">Versions</button>
				</div>
				<div class="db-drawer-body">
					<!-- Space axis: the deck library. New deck lives here, in context — a
					     new entry joins the list right below it. -->
					<div class="db-drawer-pane" id="db-pane-decks" role="tabpanel" aria-labelledby="db-tab-decks">
						<button class="db-new-deck" id="db-new-deck" type="button" aria-label="New deck" title="New deck"><span class="db-new-deck-label">New deck</span></button>
						<div class="db-deck-list" id="db-deck-list">
							<p class="db-rail-note">Loading your decks…</p>
						</div>
					</div>
					<!-- Time axis: this deck's versions. Opening changes nothing; Restore is
					     the one deliberate action. AI edits land here automatically. -->
					<div class="db-drawer-pane" id="db-pane-versions" role="tabpanel" aria-labelledby="db-tab-versions" hidden>
						<p class="db-versions-note">Every state of <span class="db-hist-scope" id="db-hist-scope" title="Versions apply to the active deck"></span>. Opening this changes nothing — <strong>Restore</strong> is the only action.</p>
						<div class="db-versions-actions">
							<button class="db-btn db-checkpoint-btn" id="db-checkpoint" type="button" aria-label="Save a version" title="Mark a state you can return to">Save a version</button>
						</div>
						<ul class="db-history-list db-timeline" id="db-history-list"></ul>
					</div>
				</div>
			</aside>

			<aside class="db-drawer db-drawer-settings" id="db-settings-drawer" role="dialog" aria-modal="true" aria-label="Settings" aria-hidden="true">
				<div class="db-drawer-head">
					<span class="db-panel-title">Settings</span>
					<span class="db-spacer"></span>
					<button class="db-drawer-close" data-drawer-close aria-label="Close settings" title="Close"></button>
				</div>
				<div class="db-drawer-body" id="db-settings-pop"></div>
			</aside>
		</div>

		<!-- Practice mode — full-screen rehearsal overlay (deterministic pacing +
		     pause cues). Renders the deck one slide at a time in its own engine
		     iframe; created lazily on first open. -->
		<div class="db-practice" id="db-practice" hidden></div>

		<!-- Focus edit mode — isolated sub-editor + live fragment preview for the
		     ```mermaid / ```chart / $$…$$ block under the cursor (deterministic). -->
		<div class="db-focus" id="db-focus" hidden></div>

		<script type="application/json" id="db-data" is:inline set:html={dbData}></script>

		<!-- CodeMirror editor (bundled by Astro/Vite). Mounts into #db-editor-host,
		     seeded from the textarea, exposes a tiny adapter on window. -->
		<script>
			import { createEditor } from '../playground/editor.js';
			const host = document.getElementById('db-editor-host');
			const ta = document.getElementById('db-editor-ta');
			const initial = ta ? ta.value : '';
			// Catalog + vocab feed slide-context autocomplete (component names +
			// modifiers inside `_class:`), the same handoff the Architect lints from.
			const data = JSON.parse(document.getElementById('db-data').textContent);
			let notify = null;
			const cursorFns = []; // multiple consumers (filmstrip sync + focus toolbar)
			const ed = createEditor({
				parent: host,
				doc: initial,
				vocab: data.lintVocab,
				catalog: data.catalog,
				onChange: (v) => { if (notify) notify(v); },
				onCursor: (line) => { for (const f of cursorFns) f(line); },
			});
			if (ta) ta.remove();
			window.__dbEditor = {
				getValue: () => ed.getValue(),
				setValue: (t) => ed.setValue(t),
				focus: () => ed.focus(),
				goToLine: (n) => ed.goToLine(n),
				getCursorLine: () => ed.getCursorLine(),
				replaceLines: (a, b, t) => ed.replaceLines(a, b, t),
				getSelection: () => ed.getSelection(),
				replaceSelection: (t) => ed.replaceSelection(t),
				onChange: (fn) => { notify = fn; },
				onCursor: (fn) => { cursorFns.push(fn); },
			};
			window.dispatchEvent(new Event('db-editor-ready'));
		</script>

		<!-- Local persistence + checkpoint history (Slice 3). Owns the deck/history
		     rail; bridges to the controller via the db-deck-loaded event +
		     window.__dbStore. Dependency-free (raw IndexedDB). -->
		<script>
			import { createStore } from '../playground/drawing-board-store.js';
			const data = JSON.parse(document.getElementById('db-data').textContent);
			const store = createStore({
				getSource: () => (window.__dbEditor ? window.__dbEditor.getValue() : ''),
				onLoadDeck: (source) => window.dispatchEvent(new CustomEvent('db-deck-loaded', { detail: { source } })),
				starter: data.starter || '',
			});
			window.__dbStore = store;
			window.dispatchEvent(new Event('db-store-ready'));
			store.init();
		</script>

		<!-- The Architect — deterministic live review (Slice 5). Runs the shared,
		     browser-safe lint-core against every edit; renders findings with reveal +
		     fix guidance. Zero model. -->
		<script>
			import { createArchitect, createOnboarding } from '../playground/drawing-board-architect.js';
			import { createArchitectModel } from '../playground/architect-model.js';
			import { createChat } from '../playground/drawing-board-chat.js';
			import { scrollJumpState } from '../playground/chat-markdown.js';
			import { createModelSettings } from '../playground/drawing-board-settings.js';
			import { createCoachConsole } from '../playground/coach-console.js';
			import { getPref } from '../playground/drawing-board-prefs.js';
			const data = JSON.parse(document.getElementById('db-data').textContent);

			// The on-device model ladder (Phase 2). Defaults on; degrades to the
			// deterministic floor when no model is present (which is every browser
			// until a tier loads). One switch (lattice-db-model=off) forces the floor.
			const model = createArchitectModel({
				getSettings: () => {
					let on = true;
					try { on = localStorage.getItem('lattice-db-model') !== 'off'; } catch (e) {}
					return { modelEnabled: on };
				},
			});
			window.__dbModel = model;

			// Model settings (Slice 8): the settings chip shows the live tier; the popover
			// toggles on-device AI, downloads a tier, and removes the cached weights.
			const settings = createModelSettings({
				host: document.getElementById('db-settings-pop'),
				trigger: document.getElementById('db-model-chip'),
				model,
				isOpen: () => { const d = document.getElementById('db-settings-drawer'); return !!d && d.classList.contains('is-open'); },
				onChange: () => { if (window.__dbChat) window.__dbChat.reload(); if (window.__dbSyncConverse) window.__dbSyncConverse(); },
			});
			window.__dbSettings = settings;

			// Slide-in drawers (decks + settings) — modal panels over a shared scrim,
			// mirroring the component-reference nav drawer. A trigger opens its drawer;
			// the scrim, the close button, or Escape closes it. Settings re-renders its
			// body on open (the deck drawer's body is kept live by the store).
			(function () {
				var scrim = document.getElementById('db-drawer-scrim');
				var defs = {
					'db-decks-pop': { trigger: '#db-decks-open', onOpen: function () { if (window.__dbDrawerTab) window.__dbDrawerTab('decks'); } },
					'db-settings-drawer': { trigger: '#db-model-chip', onOpen: function () { if (window.__dbSettings && window.__dbSettings.openTab) window.__dbSettings.openTab('cloud'); else if (window.__dbSettings && window.__dbSettings.render) window.__dbSettings.render(); } },
				};
				var current = null;
				function openDrawer(id) {
					if (current && current !== id) shut(current);
					var d = defs[id]; if (!d || !d.el) return;
					d.el.classList.add('is-open');
					d.el.setAttribute('aria-hidden', 'false');
					if (d.trigEl) d.trigEl.setAttribute('aria-expanded', 'true');
					if (scrim) scrim.hidden = false;
					document.body.classList.add('db-drawer-open');
					current = id;
					if (d.onOpen) d.onOpen();
					var c = d.el.querySelector('[data-drawer-close]'); if (c) c.focus();
				}
				function shut(id) {
					var d = defs[id]; if (!d || !d.el) return;
					d.el.classList.remove('is-open');
					d.el.setAttribute('aria-hidden', 'true');
					if (d.trigEl) d.trigEl.setAttribute('aria-expanded', 'false');
					if (current === id) {
						current = null;
						if (scrim) scrim.hidden = true;
						document.body.classList.remove('db-drawer-open');
						if (d.trigEl) d.trigEl.focus();
					}
				}
				function close() { if (current) shut(current); }
				Object.keys(defs).forEach(function (id) {
					var d = defs[id];
					d.el = document.getElementById(id);
					d.trigEl = document.querySelector(d.trigger);
					if (d.trigEl) d.trigEl.addEventListener('click', function (e) { e.stopPropagation(); current === id ? close() : openDrawer(id); });
				});
				Array.prototype.forEach.call(document.querySelectorAll('[data-drawer-close]'), function (b) { b.addEventListener('click', close); });
				if (scrim) scrim.addEventListener('click', close);
				document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && current) close(); });
				window.__dbToggleDecks = function () { current === 'db-decks-pop' ? close() : openDrawer('db-decks-pop'); };
			})();

			// The deck drawer's two axes — Decks (space) | Versions (time). Tabs swap
			// the two panes; nothing here mutates a deck, so switching tabs is free.
			(function () {
				var tabs = Array.prototype.slice.call(document.querySelectorAll('.db-drawer-tab'));
				var panes = { decks: document.getElementById('db-pane-decks'), versions: document.getElementById('db-pane-versions') };
				function show(which) {
					if (!panes[which]) return;
					tabs.forEach(function (t) {
						var on = t.getAttribute('data-pane') === which;
						t.classList.toggle('is-on', on);
