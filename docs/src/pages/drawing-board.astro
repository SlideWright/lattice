				try { localStorage.setItem('lattice-db-arch-mode', mode); } catch (e) {}
			}
			window.__dbSetArchMode = setArchMode; // the onboarding lands the user in Coach
			for (const t of document.querySelectorAll('.db-arch-mode')) t.addEventListener('click', () => setArchMode(t.getAttribute('data-mode')));
			// Landing mode on reload: the preference pins Coach/Converse, or 'remember'
			// falls back to whichever mode you last used (the legacy behaviour).
			try {
				const landing = getPref('landingMode');
