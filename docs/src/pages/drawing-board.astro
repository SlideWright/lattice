---
// The Drawing Board — a first-class, browser-only deck-authoring workspace.
//
// A sibling to the playground, NOT an evolution of it (proposal:
// engineering/decisions/2026-06-07-drawing-board-architect.md). Three resizable
// panels — the Architect · the editor · the live filmstrip — over a deck rail.
// Reuses render path #2 client-side: window.LatticePlayground (from
// docs/public/playground/lattice-playground.js) + the runtime bundle, exactly
// like the playground, so no 4th render path is introduced.
//
// Phase 1 / Slice 0-1 here: the shell, resizers, and the editor->engine
// heartbeat, with the Architect as a crafted empty-state. Persistence (Slice 3),
// export (Slice 4), and the deterministic Architect (Slice 5) fill the framed
// panels in later slices. Build plan:
// engineering/decisions/2026-06-07-drawing-board-phase-1-plan.md.
import { createRequire } from 'node:module';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import '../styles/landing.css';
import '../styles/drawing-board.css';
import { SLIDE_BOX } from '../playground/frame-css.js';
import { previewFontFaceCss } from '../playground/font-embed.js';
import { assetBase } from '../playground/asset-version.mjs';
import { joinBase } from '../lib/base-url.mjs';
import { pickGrammarVariants } from '../playground/architect-knowledge.js';

const docsRoot = process.cwd();
const repoRoot = join(docsRoot, '..');
const require = createRequire(import.meta.url);
const { loadAll, manifestBucket, familyModifiersFor } = require(join(repoRoot, 'lib/components', 'index.js'));
const manifests = loadAll();

// Compact catalog for the Architect's onboarding retrieval + scaffolding, and the
// Lattice primer fed to Converse so the cloud model knows how to AUTHOR each layout
// (not just that it exists): name + bucket + tags + one-line description + the
// authoring skeleton + variants + slot contracts.
const obCatalog = manifests.map((m) => ({
	name: m.name,
	bucket: manifestBucket(m),
	tags: m.tags || [],
	summary: m.description || '',
	skeleton: m.skeleton || m.sample || `<!-- _class: ${m.name} -->\n`,
	variants: m.variants || [],
	// Family (scoped) modifiers in scope for this component — e.g. `checks-*` +
	// `heat` on the state-bearing layouts, `canvas` on charts. The class-directive
	// autocomplete offers these alongside the component's own variants.
	familyModifiers: familyModifiersFor(m),
	// Variants whose AUTHORING grammar differs from the base skeleton (e.g.
	// `list-tabular metric` → `1. Name `value``) ship their own skeleton so the
	// cloud model authors/validates them correctly instead of against the base.
	variantSkeletons: pickGrammarVariants(m),
	slots: Object.entries(m.slots || {}).map(([name, v]) => ({
		name,
		required: !!v.required,
		description: (v.description || '').slice(0, 240),
	})),
}));

// The Architect's deterministic linter runs in the browser against the same
// pure lint-core the Node CLI uses; only the name/modifier VOCABULARY is data,
// computed here at build time from the live manifests and shipped in the page.
const { buildVocab } = require(join(repoRoot, 'lib/authoring', 'lint.js'));
const _vocab = buildVocab(manifests);
// Serialize the map region/group vocab (Sets → arrays) for the page handoff,
// so the Architect's "did you mean" resolves country/state names client-side
// from static data instead of asking the model.
const mapRegions = Object.fromEntries(
	Object.entries(_vocab.mapRegions || {}).map(([k, v]) => [k, { valid: [...v.valid], names: v.names }]),
);
const lintVocab = {
	names: [..._vocab.names],
	modifiers: [..._vocab.modifiers],
	universalModifiers: [..._vocab.universalModifiers],
	mapRegions,
	finishNames: _vocab.finishNames || [],
};

// Registered theme names for front-matter `theme:` autocomplete — the `@theme`
// name declared inside each stylesheet in marp.config.js's themeSet (that set,
// not the filenames, is what Marp actually registers; a `theme:` outside it
// renders unstyled — see engineering/gotchas.md). Read at build time.
const marpConfig = require(join(repoRoot, 'marp.config.js'));
const themeNames = [
	...new Set(
		(marpConfig.themeSet || [])
			.map((p) => {
				try {
					const m = readFileSync(p, 'utf8').match(/@theme\s+([\w-]+)/);
					return m && m[1];
				} catch {
					return null;
				}
			})
			.filter(Boolean),
	),
].sort();

const base = import.meta.env.BASE_URL;
const url = (p) => joinBase(base, p);
// Cache-busted prefix for the playground's runtime-fetched assets (see
// asset-version.mjs); the bare `playground/` route is unchanged.
const pg = assetBase();
// Short per-deploy build id (the asset-version hash). Surfaced as a visible tag
// in the topbar so a tester on a device — where the browser truncates the
// branch subdomain and can't tell a stale deploy from a fresh one — can read
// off exactly which build they loaded. Correlates with the deployed
// `/playground/v/<hash>/` path.
const buildId = (pg.match(/v\/([0-9a-f]{6,})/)?.[1] || 'dev').slice(0, 8);
// Show the build + engine provenance badge ONLY on PR-preview deploys (and local
// dev), never on the public production site. GitHub Pages (production) builds
// without CF_PAGES; Cloudflare `*.pages.dev` branch deploys ARE the PR previews —
// excluding a `main`-branch Cloudflare deploy keeps it off any future production
// custom-domain build too.
const isPreviewDeploy =
	import.meta.env.DEV || (Boolean(process.env.CF_PAGES) && process.env.CF_PAGES_BRANCH !== 'main');

const tokensCss = readFileSync(join(docsRoot, 'src/styles/lattice-tokens.generated.css'), 'utf8');
const palettes = [...new Set([...tokensCss.matchAll(/data-palette="([^"]+)"/g)].map((m) => m[1]))];
const titleCase = (s) => s.replace(/(^|-)(\w)/g, (_, sep, c) => (sep ? ' ' : '') + c.toUpperCase());

// Starter deck = a known-good sample (the hero component's), so the heartbeat
// renders something real on first load without risking an authoring footgun.
const heroComp = manifests.find((m) => m.showcase && m.showcase.hero);
const starter =
	(heroComp && heroComp.sample) ||
	'<!-- _class: title silent -->\n\n`the drawing board`\n\n# A new deck\n\nStart sketching — the preview tracks every edit.\n';

// Engine + build provenance stamped into PDF/PPTX exports (drawing-board-export.js).
const pkgVersion = require(join(repoRoot, 'package.json')).version;

// Universal-token crosswalk (the SoT old→new pairs) for the "Token system"
// toggle — the board flips fetched CSS client-side via token-flip.js.
const { PAIRS: tokenCrosswalk } = require(join(repoRoot, 'lib/tokens/crosswalk.js'));

const dbData = JSON.stringify({
	themeBase: url(pg + 'themes/'),
	crosswalk: tokenCrosswalk,
	runtimeUrl: url(pg + 'lattice-runtime.js'),
	defaultPalette: 'indaco',
	slideBox: SLIDE_BOX,
	// Self-hosted @font-face block for the preview iframe. The engine's
	// Google-Fonts @import is inert inside the srcdoc <style> (it lands after
	// other rules; CSS ignores an @import that isn't first), so the iframe loads
	// none of its own webfonts — sketch's Caveat/Shantell never appear and body
	// drops to a system sans. Built from the vendored woff2 (URLs, not inlined).
	previewFontCss: previewFontFaceCss(),
	starter,
	lintVocab,
	themes: themeNames,
	// The base palette names the top-bar picker offers — the valid vocabulary for
	// the Deck setup drawer's theme control + the controller's propagation guard.
	palettes,
	catalog: obCatalog,
	version: pkgVersion,
	buildId,
});
---

<!doctype html>
<html lang="en" data-palette="indaco" data-mode="light">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>The Drawing Board — author Lattice decks in your browser</title>
		<meta
			name="description"
			content="A browser-only authoring workspace for Lattice decks: write Markdown, watch it render live, with the Architect at your side."
		/>
		<link rel="icon" type="image/png" href={url('lattice-logo.png')} />
		<script is:inline>
			(function () {
				var r = document.documentElement;
				r.classList.add('db-js'); // JS is available → hide the pre-hydration seed textarea (no white flash / no swap jump)
				try {
					var p = localStorage.getItem('lattice-docs-palette');
					if (p) r.setAttribute('data-palette', p);
					var m = localStorage.getItem('lattice-docs-mode');
					if (m === 'light' || m === 'dark') r.setAttribute('data-mode', m);
					else if (window.matchMedia && matchMedia('(prefers-color-scheme: dark)').matches) r.setAttribute('data-mode', 'dark');
				} catch (e) {}
			})();
		</script>
	</head>
	<body class="db-page" data-pane="editor">
		<header class="topbar">
			<div class="wrap topbar-inner" style="max-width:none">
				<a class="brand" href={url('')}>
					<img class="brand-logo" src={url('lattice-logo.png')} alt="" width="30" height="30" />
					<span class="brand-mark">Lattice</span>
				</a>
				<nav class="topnav" id="topnav">
					<a class="navlink" href={url('getting-started/')}>Get started</a>
					<a class="navlink" href={url('guides/authoring/')}>Guides</a>
					<a class="navlink" href={url('playground/')}>Playground</a>
					<a class="navlink" href={url('drawing-board/')} aria-current="page">Drawing Board</a>
					<a class="navlink" href={url('workbench/')}>Workbench</a>
					<a class="navlink" href={url('components/')}>Components</a>
					<a class="navlink" href="https://github.com/slidewright/lattice">GitHub</a>
				</nav>
				<div class="topbar-actions">
					<div class="controls">
						<select class="palette-select" id="palette" aria-label="Palette">
							{palettes.map((p) => <option value={p}>{titleCase(p)}</option>)}
						</select>
						<button class="mode-toggle" id="mode-toggle" aria-label="Toggle light / dark" title="Toggle light / dark"></button>
					</div>
					<button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu" aria-controls="topnav" aria-expanded="false"></button>
				</div>
			</div>
		</header>

		<div class="db-workspace" id="db-workspace">
			<!-- The Architect — deterministic onboarding + live review (Slice 5). The
			     deck library + checkpoint history fold into the "Decks" popover in this
			     panel's head; workspace + on-device-AI preferences into the settings
			     chip beside it. (The old standalone rail is retired.) -->
			<section class="db-panel db-architect" id="db-architect" aria-label="The Architect">
				<div class="db-panel-head">
					<!-- The deck-name gateway leads the head and grows to fill it: the
					     Architect's identity now lives once, in the avatar mark below, so
					     the head's job is to name the deck you're on. Opening it reveals
					     everything you can do with decks (switch / new / versions).
					     Replaces the old ambiguous "Decks" + "New" labels. -->
					<button class="db-deck-gw" id="db-decks-open" aria-haspopup="dialog" aria-expanded="false" aria-controls="db-decks-pop" title="Decks &amp; versions">
						<span class="db-deck-gw-dot" aria-hidden="true"></span>
						<span class="db-deck-gw-name" id="db-deck-gw-name">Deck</span>
					</button>
					<!-- Settings entry that also signals the live AI tier: gear (tap to
					     configure) + short tier word + a status dot (filled = AI active,
					     hollow = deterministic floor). Label text driven by settings JS. -->
					<button class="db-model-chip is-floor" id="db-model-chip" aria-haspopup="dialog" aria-expanded="false" aria-controls="db-settings-drawer" title="Settings — workspace &amp; on-device AI"><span class="db-model-chip-label">Floor</span></button>
				</div>
				<div class="db-panel-body db-arch-body" id="db-arch-body" data-arch-mode="coach" data-converse-ready="false">
					<div class="db-arch-scroll">
						<div class="db-arch-mark">
							<span class="db-arch-glyph" aria-hidden="true">A</span>
							<span class="db-arch-name">the Architect<small>your deck partner</small></span>
							{isPreviewDeploy && (
								<span class="db-arch-build" title="Build + render engine of this preview deploy">
									<span>build {buildId}</span>
									<span>engine <b id="db-arch-engine">lattice-engine</b></span>
								</span>
							)}
						</div>
						{isPreviewDeploy && (
							<script
								is:inline
								set:html={`(function(){var el=document.getElementById('db-arch-engine');if(!el)return;var eng='lattice';try{eng=new URLSearchParams(location.search).get('engine')||localStorage.getItem('lattice-db-render-engine')||'lattice';}catch(e){}el.textContent=eng==='lattice'?'lattice-engine':'marp-core';})();`}
							/>
						)}
						<div class="db-arch-onboard" id="db-arch-onboard"></div>

						<!-- Coach (deterministic) vs Converse (generative) — the help mode for
						     this deck. Coach is buttons + result cards (no fake chat); Converse
						     is a real conversation, shown only when a real model is available. -->
						<div class="db-arch-modes" id="db-arch-modes" role="tablist" aria-label="Architect mode">
							<button class="db-arch-mode" data-mode="coach" role="tab" aria-selected="true">Coach</button>
							<button class="db-arch-mode" data-mode="converse" role="tab" aria-selected="false">Converse</button>
						</div>

						<!-- Coach view: the deterministic assessment + action chips. -->
						<div class="db-coach" data-view="coach">
							<!-- The Architect's post-onboarding greeting (Drafting/Freehand) lands
							     here — visible in the default Coach mode. -->
							<p class="db-coach-intro" id="db-coach-intro" aria-live="polite"></p>
							<div class="db-arch-review" id="db-arch-review" aria-live="polite"></div>
							<div class="db-coach-chips" id="db-coach-chips"></div>
							<div class="db-coach-card" id="db-coach-card" aria-live="polite"></div>
						</div>

						<!-- Converse view: the real conversation (thread). -->
						<div class="db-converse" data-view="converse">
							<div class="db-arch-chat" id="db-arch-chat" aria-live="polite"></div>
							<div class="db-converse-empty" id="db-converse-empty">
								<p>Converse is a real AI conversation about your deck — the ask, a specific slide, tightening a line. (Coach handles the scores and fixes.)</p>
								<div class="db-converse-connect-wrap" id="db-converse-connect-wrap">
									<div class="db-converse-connect-row" id="db-converse-connect-row">
										<button class="db-btn db-btn-primary db-converse-connect-or" id="db-converse-connect-or" type="button">Connect OpenRouter — your account</button>
									</div>
									<p class="db-converse-fine">OpenRouter uses your own account credits via one-click sign-in — pick any of 500+ models. Your deck’s text is sent to the chosen model to generate replies. Prefer on-device? Turn it on from the settings chip.</p>
								</div>
							</div>
						</div>
					</div>
					<!-- Jump to top / latest — shown only when the panel overflows and you're
					     away from that end, so long threads + edit cards aren't a scroll slog. -->
					<div class="db-arch-jump" id="db-arch-jump">
						<button class="db-arch-jump-btn" data-dir="top" type="button" aria-label="Scroll to top" title="Top" hidden></button>
						<button class="db-arch-jump-btn" data-dir="bottom" type="button" aria-label="Scroll to latest" title="Latest" hidden></button>
					</div>
					<!-- The composer — only in Converse, only when a real model backs it. -->
					<form class="db-arch-composer" id="db-arch-composer">
						<textarea id="db-arch-input" rows="1" placeholder="Ask the Architect about your deck…" aria-label="Message the Architect"></textarea>
						<button type="submit" class="db-arch-send" aria-label="Send"></button>
					</form>
				</div>
			</section>

			<div class="db-resizer" id="db-resize-left" data-target="arch" role="separator" aria-orientation="vertical" aria-label="Resize the Architect panel"></div>

			<!-- Editor -->
			<section class="db-panel db-editor" id="db-editor">
				<div class="db-panel-head">
					<span class="db-panel-title">Markdown</span>
					<button class="db-btn db-focus-open" id="db-focus-open" hidden title="Edit the diagram/math block under the cursor in isolation">Focus</button>
					<div class="db-refine" id="db-refine-wrap">
						<button class="db-btn db-refine-open" id="db-refine-open" hidden aria-haspopup="menu">Refine</button>
						<div class="db-refine-pop" id="db-refine-menu" role="menu" hidden></div>
					</div>
					<span class="db-spacer"></span>
					<div class="db-export" id="db-export-wrap">
						<button class="db-btn" id="db-export" aria-haspopup="menu" aria-expanded="false" title="Export this deck">Export</button>
						<div class="db-export-menu" id="db-export-menu" role="menu" hidden>
							<button class="db-menu-item" type="button" data-export="md" role="menuitem">Markdown<small>.md — the source</small></button>
							<button class="db-menu-item" type="button" data-export="pdf" role="menuitem">PDF<small>.pdf — one click</small></button>
							<button class="db-menu-item" type="button" data-export="pptx" role="menuitem">PowerPoint<small>.pptx — image slides</small></button>
							<button class="db-menu-item" type="button" data-export="print" role="menuitem">Print<small>vector + selectable text</small></button>
						</div>
					</div>
					<!-- Deck setup — front-matter config (theme, size, pagination,
					     header/footer, …). A document-level action, parked at the right
					     end of the editor toolbar, after Export; the `is-set` cue lights
					     when the deck carries front matter. -->
					<button class="db-config-chip" id="db-config-open" aria-haspopup="dialog" aria-expanded="false" aria-controls="db-config-drawer" aria-label="Deck setup" title="Deck setup — theme, size, pagination, header &amp; footer"></button>
				</div>
				<div class="db-panel-body">
					<!-- CodeMirror mounts into #db-editor-host; the textarea is the no-JS /
					     pre-hydration fallback and the source of the starter text. -->
					<div class="db-editor-host" id="db-editor-host">
						<textarea id="db-editor-ta" spellcheck="false" aria-label="Lattice markdown editor">{starter}</textarea>
					</div>
				</div>
			</section>

			<div class="db-resizer" id="db-resize-right" data-target="preview" role="separator" aria-orientation="vertical" aria-label="Resize the preview panel"></div>

			<!-- Preview filmstrip -->
			<section class="db-panel db-preview" id="db-preview">
				<div class="db-panel-head">
					<span class="db-panel-title">Slides</span>
					<button class="db-btn db-practice-open" id="db-practice-open" title="Rehearse full-screen with pacing">Practice</button>
					<span class="db-spacer"></span>
					<span class="db-status" id="db-status">Ready.</span>
				</div>
				<div class="db-panel-body">
					<iframe id="db-frame" class="db-filmstrip" title="Rendered slides"></iframe>
				</div>
			</section>

			<!-- Mobile pane switcher (shown <=1024px) -->
			<nav class="db-mobile-tabs" role="tablist" aria-label="Workspace panes">
				<button class="db-mobile-tab" data-pane="architect" role="tab" aria-selected="false">Architect</button>
				<button class="db-mobile-tab" data-pane="editor" role="tab" aria-selected="true">Edit</button>
				<button class="db-mobile-tab" data-pane="preview" role="tab" aria-selected="false">Preview</button>
			</nav>

			<!-- Slide-in drawers — decks + settings. Modal panels that slide from the
			     left over a shared scrim, mirroring the component-reference nav drawer
			     (transform + scrim + body.db-drawer-open), with a scrollable body. -->
			<button class="db-drawer-scrim" id="db-drawer-scrim" type="button" aria-label="Close" hidden></button>

			<!-- The deck drawer — the deck-name gateway's destination. Two axes, two
			     tabs: Decks (space — which deck: switch / new) and Versions (time —
			     which state of this deck: view / restore, read-only until you act). -->
			<aside class="db-drawer db-drawer-decks" id="db-decks-pop" role="dialog" aria-modal="true" aria-label="Decks and versions" aria-hidden="true">
				<div class="db-drawer-head">
					<span class="db-panel-title">Decks</span>
					<span class="db-spacer"></span>
					<button class="db-drawer-close" data-drawer-close aria-label="Close" title="Close"></button>
				</div>
				<div class="db-drawer-tabs" role="tablist" aria-label="Decks and versions">
					<button class="db-drawer-tab is-on" id="db-tab-decks" type="button" role="tab" aria-selected="true" aria-controls="db-pane-decks" data-pane="decks">Decks</button>
					<button class="db-drawer-tab" id="db-tab-versions" type="button" role="tab" aria-selected="false" aria-controls="db-pane-versions" data-pane="versions">Versions</button>
				</div>
				<div class="db-drawer-body">
					<!-- Space axis: the deck library. New deck lives here, in context — a
					     new entry joins the list right below it. -->
					<div class="db-drawer-pane" id="db-pane-decks" role="tabpanel" aria-labelledby="db-tab-decks">
						<button class="db-new-deck" id="db-new-deck" type="button" aria-label="New deck" title="New deck"><span class="db-new-deck-label">New deck</span></button>
						<div class="db-deck-list" id="db-deck-list">
							<p class="db-rail-note">Loading your decks…</p>
						</div>
					</div>
					<!-- Time axis: this deck's versions. Opening changes nothing; Restore is
					     the one deliberate action. AI edits land here automatically. -->
					<div class="db-drawer-pane" id="db-pane-versions" role="tabpanel" aria-labelledby="db-tab-versions" hidden>
						<p class="db-versions-note">Every state of <span class="db-hist-scope" id="db-hist-scope" title="Versions apply to the active deck"></span>. Opening this changes nothing — <strong>Restore</strong> is the only action.</p>
						<div class="db-versions-actions">
							<button class="db-btn db-checkpoint-btn" id="db-checkpoint" type="button" aria-label="Save a version" title="Mark a state you can return to">Save a version</button>
						</div>
						<ul class="db-history-list db-timeline" id="db-history-list"></ul>
					</div>
				</div>
			</aside>

			<aside class="db-drawer db-drawer-settings" id="db-settings-drawer" role="dialog" aria-modal="true" aria-label="Settings" aria-hidden="true">
				<div class="db-drawer-head">
					<span class="db-panel-title">Settings</span>
					<span class="db-spacer"></span>
					<button class="db-drawer-close" data-drawer-close aria-label="Close settings" title="Close"></button>
				</div>
				<div class="db-drawer-body" id="db-settings-pop"></div>
			</aside>

			<!-- The deck-setup drawer — front-matter config. Friendly controls write a
			     managed `---` block at the top of the deck source (the channel that
			     already persists + exports), so the Markdown body stays content-only.
			     Pre-filled from the deck's current front matter when opened. -->
			<aside class="db-drawer db-drawer-config" id="db-config-drawer" role="dialog" aria-modal="true" aria-label="Deck setup" aria-hidden="true">
				<div class="db-drawer-head">
					<span class="db-panel-title">Deck setup</span>
					<span class="db-spacer"></span>
					<button class="db-drawer-close" data-drawer-close aria-label="Close deck setup" title="Close"></button>
				</div>
				<div class="db-drawer-body" id="db-config-pop"></div>
			</aside>
		</div>

		<!-- Practice mode — full-screen rehearsal overlay (deterministic pacing +
		     pause cues). Renders the deck one slide at a time in its own engine
		     iframe; created lazily on first open. -->
		<div class="db-practice" id="db-practice" hidden></div>

		<!-- Focus edit mode — isolated sub-editor + live fragment preview for the
		     ```mermaid / ```chart / $$…$$ block under the cursor (deterministic). -->
		<div class="db-focus" id="db-focus" hidden></div>

		<script type="application/json" id="db-data" is:inline set:html={dbData}></script>

		<!-- CodeMirror editor (bundled by Astro/Vite). Mounts into #db-editor-host,
		     seeded from the textarea, exposes a tiny adapter on window. -->
		<script>
			import { createEditor } from '../playground/editor.js';
			import { getPref } from '../playground/drawing-board-prefs.js';
			const host = document.getElementById('db-editor-host');
			const ta = document.getElementById('db-editor-ta');
			const initial = ta ? ta.value : '';
			// Catalog + vocab feed slide-context autocomplete (component names +
			// modifiers inside `_class:`), the same handoff the Architect lints from.
			const data = JSON.parse(document.getElementById('db-data').textContent);
			let notify = null;
			const cursorFns = []; // multiple consumers (filmstrip sync + focus toolbar)
			const ed = createEditor({
				parent: host,
				doc: initial,
				vocab: data.lintVocab,
				catalog: data.catalog,
				themes: data.themes,
				finishes: (data.lintVocab && data.lintVocab.finishNames) || [],
				autocomplete: getPref('autocomplete') === 'on',
				onChange: (v) => { if (notify) notify(v); },
				onCursor: (line) => { for (const f of cursorFns) f(line); },
			});
			if (ta) ta.remove();
			// Component bridge — autocomplete: merge the author's saved local
			// components into the live catalog + lint vocab so they complete inside
			// `_class:` (and offer their saved skeleton on an empty classed body) just
			// like a shipped component, marked *local*. The completion sources read
			// these arrays at completion time, so an in-place merge surfaces without
			// rebuilding the editor. See the component-bridge decision note.
			function mergeLocalComponents() {
				const local = window.__dbLibraryComponents || [];
				const have = new Set((data.catalog || []).map((c) => c.name));
				for (const c of local) {
					if (!c || !c.name || have.has(c.name)) continue;
					data.catalog.push({
						name: c.name,
						bucket: c.bucket || 'inventory',
						skeleton: c.skeleton || `<!-- _class: ${c.name} -->\n`,
						local: true,
					});
					if (data.lintVocab && data.lintVocab.names && data.lintVocab.names.indexOf(c.name) === -1) {
						data.lintVocab.names.push(c.name);
					}
					have.add(c.name);
				}
			}
			window.addEventListener('db-library-components', mergeLocalComponents);
			mergeLocalComponents();
			window.__dbEditor = {
				getValue: () => ed.getValue(),
				setValue: (t) => ed.setValue(t),
				focus: () => ed.focus(),
				goToLine: (n) => ed.goToLine(n),
				getCursorLine: () => ed.getCursorLine(),
				replaceLines: (a, b, t) => ed.replaceLines(a, b, t),
				getSelection: () => ed.getSelection(),
				replaceSelection: (t) => ed.replaceSelection(t),
				onChange: (fn) => { notify = fn; },
				onCursor: (fn) => { cursorFns.push(fn); },
				setAutocomplete: (on) => ed.setAutocomplete(on),
			};
			window.dispatchEvent(new Event('db-editor-ready'));
		</script>

		<!-- Local persistence + checkpoint history (Slice 3). Owns the deck/history
		     rail; bridges to the controller via the db-deck-loaded event +
		     window.__dbStore. Dependency-free (raw IndexedDB). -->
		<script>
			import { createStore } from '../playground/drawing-board-store.js';
			const data = JSON.parse(document.getElementById('db-data').textContent);
			const store = createStore({
				getSource: () => (window.__dbEditor ? window.__dbEditor.getValue() : ''),
				onLoadDeck: (source) => window.dispatchEvent(new CustomEvent('db-deck-loaded', { detail: { source } })),
				starter: data.starter || '',
			});
			window.__dbStore = store;
			window.dispatchEvent(new Event('db-store-ready'));
			store.init();
		</script>

		<!-- The Architect — deterministic live review (Slice 5). Runs the shared,
		     browser-safe lint-core against every edit; renders findings with reveal +
		     fix guidance. Zero model. -->
		<script>
			import { createArchitect, createOnboarding } from '../playground/drawing-board-architect.js';
			import { createArchitectModel } from '../playground/architect-model.js';
			import { createChat } from '../playground/drawing-board-chat.js';
			import { scrollJumpState } from '../playground/chat-markdown.js';
			import { createModelSettings } from '../playground/drawing-board-settings.js';
			import { createConfigPanel } from '../playground/drawing-board-config.js';
			import { createCoachConsole } from '../playground/coach-console.js';
			import { getPref } from '../playground/drawing-board-prefs.js';
			const data = JSON.parse(document.getElementById('db-data').textContent);

			// The on-device model ladder (Phase 2). Defaults on; degrades to the
			// deterministic floor when no model is present (which is every browser
			// until a tier loads). One switch (lattice-db-model=off) forces the floor.
			const model = createArchitectModel({
				getSettings: () => {
					let on = true;
					try { on = localStorage.getItem('lattice-db-model') !== 'off'; } catch (e) {}
					return { modelEnabled: on };
				},
			});
			window.__dbModel = model;

			// Model settings (Slice 8): the settings chip shows the live tier; the popover
			// toggles on-device AI, downloads a tier, and removes the cached weights.
			const settings = createModelSettings({
				host: document.getElementById('db-settings-pop'),
				trigger: document.getElementById('db-model-chip'),
				model,
				isOpen: () => { const d = document.getElementById('db-settings-drawer'); return !!d && d.classList.contains('is-open'); },
				onChange: () => { if (window.__dbChat) window.__dbChat.reload(); if (window.__dbSyncConverse) window.__dbSyncConverse(); },
			});
			window.__dbSettings = settings;

			// Deck setup (front-matter config): the config chip opens a drawer whose
			// controls write a managed `---` block into the editor source. Reads the
			// live editor, writes back through it (so the change re-renders + autosaves
			// via onEdit). syncTrigger lights the chip when the deck carries front matter.
			const config = createConfigPanel({
				host: document.getElementById('db-config-pop'),
				trigger: document.getElementById('db-config-open'),
				getSource: () => (window.__dbEditor ? window.__dbEditor.getValue() : ''),
				setSource: (next) => { if (window.__dbEditor) window.__dbEditor.setValue(next); },
				// Theme is the deck's palette: the drawer's select offers the same base
				// names as the top-bar picker, and falls back to the live page palette
				// when the deck declares none. Writes flow back through setSource → the
				// controller's onEdit → syncThemeControls (picker + chrome) below.
				palettes: data.palettes || [],
				finishes: (data.lintVocab && data.lintVocab.finishNames) || [],
				getDefaultTheme: () => document.documentElement.getAttribute('data-palette') || (data.palettes && data.palettes[0]) || '',
			});
			window.__dbConfig = config;
			config.syncTrigger();

			// Slide-in drawers (decks + settings) — modal panels over a shared scrim,
			// mirroring the component-reference nav drawer. A trigger opens its drawer;
			// the scrim, the close button, or Escape closes it. Settings re-renders its
			// body on open (the deck drawer's body is kept live by the store).
			(function () {
				var scrim = document.getElementById('db-drawer-scrim');
				var defs = {
					'db-decks-pop': { trigger: '#db-decks-open', onOpen: function () { if (window.__dbDrawerTab) window.__dbDrawerTab('decks'); } },
					'db-settings-drawer': { trigger: '#db-model-chip', onOpen: function () { if (window.__dbSettings && window.__dbSettings.openTab) window.__dbSettings.openTab('cloud'); else if (window.__dbSettings && window.__dbSettings.render) window.__dbSettings.render(); } },
					'db-config-drawer': { trigger: '#db-config-open', onOpen: function () { if (window.__dbConfig && window.__dbConfig.render) window.__dbConfig.render(); } },
				};
				var current = null;
				function openDrawer(id) {
					if (current && current !== id) shut(current);
					var d = defs[id]; if (!d || !d.el) return;
					d.el.classList.add('is-open');
					d.el.setAttribute('aria-hidden', 'false');
					if (d.trigEl) d.trigEl.setAttribute('aria-expanded', 'true');
					if (scrim) scrim.hidden = false;
					document.body.classList.add('db-drawer-open');
					current = id;
					if (d.onOpen) d.onOpen();
					var c = d.el.querySelector('[data-drawer-close]'); if (c) c.focus();
				}
				function shut(id) {
					var d = defs[id]; if (!d || !d.el) return;
					d.el.classList.remove('is-open');
					d.el.setAttribute('aria-hidden', 'true');
					if (d.trigEl) d.trigEl.setAttribute('aria-expanded', 'false');
					if (current === id) {
						current = null;
						if (scrim) scrim.hidden = true;
						document.body.classList.remove('db-drawer-open');
						if (d.trigEl) d.trigEl.focus();
					}
				}
				function close() { if (current) shut(current); }
				Object.keys(defs).forEach(function (id) {
					var d = defs[id];
					d.el = document.getElementById(id);
					d.trigEl = document.querySelector(d.trigger);
					if (d.trigEl) d.trigEl.addEventListener('click', function (e) { e.stopPropagation(); current === id ? close() : openDrawer(id); });
				});
				Array.prototype.forEach.call(document.querySelectorAll('[data-drawer-close]'), function (b) { b.addEventListener('click', close); });
				if (scrim) scrim.addEventListener('click', close);
				document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && current) close(); });
				window.__dbToggleDecks = function () { current === 'db-decks-pop' ? close() : openDrawer('db-decks-pop'); };
			})();

			// The deck drawer's two axes — Decks (space) | Versions (time). Tabs swap
			// the two panes; nothing here mutates a deck, so switching tabs is free.
			(function () {
				var tabs = Array.prototype.slice.call(document.querySelectorAll('.db-drawer-tab'));
				var panes = { decks: document.getElementById('db-pane-decks'), versions: document.getElementById('db-pane-versions') };
				function show(which) {
					if (!panes[which]) return;
					tabs.forEach(function (t) {
						var on = t.getAttribute('data-pane') === which;
						t.classList.toggle('is-on', on);
						t.setAttribute('aria-selected', on ? 'true' : 'false');
					});
					Object.keys(panes).forEach(function (k) { if (panes[k]) panes[k].hidden = k !== which; });
				}
				tabs.forEach(function (t) { t.addEventListener('click', function () { show(t.getAttribute('data-pane')); }); });
				window.__dbDrawerTab = show;
			})();

			// After detection, refresh the chip and reconnect a previously-loaded model
			// (weights are cached, but the running engine is lost on reload — re-init it,
			// which is what makes the model "stick" across refreshes).
			model.refreshAvailability().then(() => { settings.refresh(); settings.restore(); });

			// Reveal a source line in the editor. On the ≤1024px single-pane layout the
			// inactive panes are display:none, and CodeMirror can't scroll a hidden
			// view — so switch to the editor pane FIRST, then goToLine on the next
			// frame once it's laid out and measurable. (Both the Architect findings and
			// the Coach cards route their "Reveal" / "Go to slide" here.)
			function revealLine(line) {
				const go = () => { if (window.__dbEditor) window.__dbEditor.goToLine(line); };
				if (window.matchMedia('(max-width: 1024px)').matches && window.__dbSetPane) {
					window.__dbSetPane('editor');
					requestAnimationFrame(() => requestAnimationFrame(go));
				} else {
					go();
				}
			}

			const architect = createArchitect({
				vocab: data.lintVocab,
				catalog: data.catalog,
				model,
				mount: document.getElementById('db-arch-review'),
				reveal: revealLine,
				// setValue dispatches a doc change -> onEdit -> render + save + re-lint.
				applyFix: (newSource) => { if (window.__dbEditor) window.__dbEditor.setValue(newSource); },
			});
			window.__dbArchitect = architect;
			// Component bridge: teach the Architect's linter the author's saved local
			// components so a valid `_class: <local>` isn't flagged "unknown class".
			// Re-runs the review once names are known (and on every library refresh).
			function mergeArchComponents() {
				const local = window.__dbLibraryComponents || [];
				if (!local.length) return;
				architect.addNames(local.map((c) => c.name));
				architect.update(window.__dbEditor ? window.__dbEditor.getValue() : '');
			}
			window.addEventListener('db-library-components', mergeArchComponents);
			mergeArchComponents();

			// Coach console (deterministic): action chips -> result cards. The Coach
			// view's structured answers replace a fake chat composer.
			const coach = createCoachConsole({
				chipsHost: document.getElementById('db-coach-chips'),
				cardHost: document.getElementById('db-coach-card'),
				introHost: document.getElementById('db-coach-intro'),
				getAssessment: () => architect.getAssessment(),
				getSource: () => (window.__dbEditor ? window.__dbEditor.getValue() : ''),
				reveal: revealLine,
			});
			window.__dbCoach = coach;

			// Coach <-> Converse toggle: Coach is the deterministic console; Converse is
			// the real conversation (composer shown only when a real model backs it).
			const archBody = document.getElementById('db-arch-body');
			function setArchMode(mode) {
				archBody.setAttribute('data-arch-mode', mode);
				for (const t of document.querySelectorAll('.db-arch-mode')) t.setAttribute('aria-selected', t.getAttribute('data-mode') === mode ? 'true' : 'false');
				try { localStorage.setItem('lattice-db-arch-mode', mode); } catch (e) {}
			}
			window.__dbSetArchMode = setArchMode; // the onboarding lands the user in Coach
			for (const t of document.querySelectorAll('.db-arch-mode')) t.addEventListener('click', () => setArchMode(t.getAttribute('data-mode')));
			// Landing mode on reload: the preference pins Coach/Converse, or 'remember'
			// falls back to whichever mode you last used (the legacy behaviour).
			try {
				const landing = getPref('landingMode');
				if (landing === 'coach' || landing === 'converse') setArchMode(landing);
				else { const m = localStorage.getItem('lattice-db-arch-mode'); if (m === 'converse') setArchMode('converse'); }
			} catch (e) {}
			// A stale onboarding greeting shouldn't follow you to another deck.
			window.addEventListener('db-active-deck', () => { if (window.__dbCoach && window.__dbCoach.clearIntro) window.__dbCoach.clearIntro(); });

			// Converse is "ready" (composer shown) only with a real generative model.
			window.__dbSyncConverse = function () {
				var a = model.availability ? model.availability() : { generation: 'floor' };
				var ready = a.modelOn && a.generation !== 'floor';
				archBody.setAttribute('data-converse-ready', ready ? 'true' : 'false');
			};
			window.__dbSyncConverse();

			// Converse "Connect AI" — OpenRouter (your own account) via one-click
			// OAuth: a redirect to openrouter.ai and back (the ?code= return is handled
			// on load, below). On connect it becomes the active generation backend.
			(function () {
				var wrap = document.getElementById('db-converse-connect-wrap');
				var row = document.getElementById('db-converse-connect-row');
				var orBtn = document.getElementById('db-converse-connect-or');
				var fine = wrap && wrap.querySelector('.db-converse-fine');
				if (!wrap || !row || !orBtn) return;
				var el = function (t, c, x) { var e = document.createElement(t); if (c) e.className = c; if (x != null) e.textContent = x; return e; };
				function reset() { wrap.innerHTML = ''; wrap.appendChild(row); if (fine) wrap.appendChild(fine); }
				function showError(msg) {
					wrap.innerHTML = '';
					wrap.appendChild(el('p', 'db-settings-error', msg));
					var retry = el('button', 'db-btn', 'Back'); retry.type = 'button'; retry.addEventListener('click', reset);
					wrap.appendChild(retry);
				}
				// OpenRouter — one-click OAuth (PKCE). We redirect to openrouter.ai;
				// the callback returns here with ?code=, handled on the next load.
				orBtn.addEventListener('click', async function () {
					orBtn.disabled = true; orBtn.textContent = 'Redirecting…';
					try {
						var cb = location.origin + location.pathname; // return cleanly to this page
						var url = await window.__dbModel.beginOpenRouterAuth(cb);
						location.href = url;
					} catch (e) {
						orBtn.disabled = false; orBtn.textContent = 'Connect OpenRouter — your account';
						showError('Couldn’t start OpenRouter sign-in: ' + (e && e.message || e));
					}
				});
			})();

			// OpenRouter OAuth return: openrouter.ai redirects back with ?code=. Only
			// act on it when WE started the flow (a PKCE verifier is pending), then
			// exchange the code for a key, strip ?code from the URL, and drop the user
			// straight into Converse with OpenRouter as the active cloud.
			(function () {
				try {
					var params = new URLSearchParams(location.search);
					var code = params.get('code');
					if (!code || !window.__dbModel || !window.__dbModel.hasPendingOpenRouterAuth || !window.__dbModel.hasPendingOpenRouterAuth()) return;
					window.__dbModel.resumeOpenRouterAuth(code).then(function () {
						params.delete('code');
						var clean = location.pathname + (params.toString() ? '?' + params.toString() : '') + location.hash;
						try { history.replaceState({}, '', clean); } catch (e) {}
						if (window.__dbSetArchMode) window.__dbSetArchMode('converse');
						if (window.__dbSyncConverse) window.__dbSyncConverse();
						if (window.__dbSettings) window.__dbSettings.refresh();
						if (window.__dbChat) window.__dbChat.reload();
					}).catch(function (e) {
						try { console.error('[Architect] OpenRouter connect failed:', e); } catch (x) {}
					});
				} catch (e) {}
			})();

			// The chat surface — grounded in the architect's live deterministic
			// assessment, persisted per deck via the store, model phrases the reply.
			// Waits for the store so the thread can load/resume per deck.
			function wireChat() {
				const chat = createChat({
					mount: document.getElementById('db-arch-chat'),
					composer: document.getElementById('db-arch-composer'),
					model,
					store: window.__dbStore,
					getAssessment: () => architect.getAssessment(),
					catalog: data.catalog, // the Lattice primer for the cloud prompt
					// Slice B: Converse proposes edits → reviewable diff → Apply splices into
					// the live editor (which re-renders + re-scores via onEdit).
					getSource: () => (window.__dbEditor ? window.__dbEditor.getValue() : ''),
					applyFix: (next) => { if (window.__dbEditor) window.__dbEditor.setValue(next); },
					// Git-like time travel: snapshot the pre-edit deck as a labelled,
					// restorable checkpoint (History rail) the instant an AI edit applies.
					onApply: ({ before, label }) => { if (window.__dbStore?.autoCheckpoint) window.__dbStore.autoCheckpoint(before, label); },
				});
				window.__dbChat = chat;
			}
			if (window.__dbStore) wireChat();
			else window.addEventListener('db-store-ready', wireChat, { once: true });

			// Jump to top / latest: the Architect panel body (.db-arch-scroll) scrolls;
			// show each arrow only when overflowing AND away from that end (pure logic in
			// scrollJumpState). Saves a manual scroll through a long thread + edit cards.
			(function () {
				const scroller = document.querySelector('#db-architect .db-arch-scroll');
				const jump = document.getElementById('db-arch-jump');
				if (!scroller || !jump) return;
				const upBtn = jump.querySelector('[data-dir="top"]');
				const downBtn = jump.querySelector('[data-dir="bottom"]');
				const sync = () => {
					const s = scrollJumpState({ scrollTop: scroller.scrollTop, scrollHeight: scroller.scrollHeight, clientHeight: scroller.clientHeight });
					upBtn.hidden = !s.top;
					downBtn.hidden = !s.bottom;
					jump.classList.toggle('is-idle', !s.top && !s.bottom);
				};
				upBtn.addEventListener('click', () => scroller.scrollTo({ top: 0, behavior: 'smooth' }));
				downBtn.addEventListener('click', () => scroller.scrollTo({ top: scroller.scrollHeight, behavior: 'smooth' }));
				scroller.addEventListener('scroll', sync, { passive: true });
				// Re-evaluate when content changes (new messages, expanded edit cards).
				if (window.ResizeObserver) new ResizeObserver(sync).observe(scroller.firstElementChild || scroller);
				const mo = new MutationObserver(sync);
				mo.observe(scroller, { childList: true, subtree: true });
				sync();
			})();

			// Conversation-first onboarding: 3 questions -> retrieval -> scaffold a
			// new deck (via the store when present, else just load it into the editor).
			// The model upgrades archetype retrieval to semantic when embeddings load.
			createOnboarding({
				catalog: data.catalog,
				mount: document.getElementById('db-arch-onboard'),
				model,
				onBuild: async (src, name) => {
					// name = the archetype (Drafting) or undefined (Freehand → auto-titled
					// from the deck's H1). The store derives the title + description.
					// Flag onboarding-start so the controller doesn't yank narrow layouts to
					// the editor — keep you on the Architect to see its greeting (say, below).
					window.__dbOnboardingStart = true;
					if (window.__dbStore && window.__dbStore.create) await window.__dbStore.create(src, name);
					else if (window.__dbEditor) window.__dbEditor.setValue(src);
				},
				// The Architect "talks back" when it starts a deck — in COACH, the default
				// mode, where the review + chips live. (The Converse thread is hidden under
				// Coach, so a greeting posted there would never be seen.) On narrow layouts
				// stay on the Architect so the greeting + first review are seen.
				say: async (text) => {
					if (window.__dbSetArchMode) window.__dbSetArchMode('coach');
					if (window.__dbCoach && window.__dbCoach.intro) window.__dbCoach.intro(text);
					if (window.matchMedia('(max-width: 1024px)').matches && window.__dbSetPane) window.__dbSetPane('architect');
					window.__dbOnboardingStart = false;
				},
			});
		</script>

		<!-- Export — MD / PDF / PPTX (Slice 4). PptxGenJS is lazy-imported inside
		     the module on first PPTX use, so it never loads unless invoked. -->
		<script>
			import { exportMarkdown, exportPdf, exportPptx, exportPrint } from '../playground/drawing-board-export.js';
			import { listAssets } from '../playground/asset-store.js';
			import { referencedComponents } from '../playground/layout-core.generated.js';
			const wrap = document.getElementById('db-export-wrap');
			const trigger = document.getElementById('db-export');
			const menu = document.getElementById('db-export-menu');
			const statusEl = document.getElementById('db-status');
			const deckName = () => {
				const n = document.querySelector('.db-deck[aria-current="true"] .db-deck-name');
				return (n && n.textContent) || 'deck';
			};
			const status = (msg, err) => { if (statusEl) { statusEl.textContent = msg; statusEl.classList.toggle('err', !!err); } };
			const closeMenu = () => { menu.hidden = true; trigger.setAttribute('aria-expanded', 'false'); };
			trigger.addEventListener('click', (e) => {
				e.stopPropagation();
				const open = menu.hidden;
				menu.hidden = !open;
				trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
			});
			document.addEventListener('click', (e) => { if (wrap && !wrap.contains(e.target)) closeMenu(); });
			document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });
			menu.addEventListener('click', async (e) => {
				const btn = e.target.closest('[data-export]');
				if (!btn) return;
				closeMenu();
				const kind = btn.getAttribute('data-export');
				const frame = document.getElementById('db-frame');
				const source = window.__dbEditor ? window.__dbEditor.getValue() : '';
				// Provenance for the export stamp: which engine + build + theme rendered
				// these slides (drawing-board-export.js packs it into document properties).
				const root = document.documentElement;
				const PG = window.LatticePlayground;
				const dbd = JSON.parse(document.getElementById('db-data').textContent);
				const meta = {
					engine: (PG && PG.engine) || 'lattice',
					version: dbd.version || '',
					build: dbd.buildId || '',
					palette: root.getAttribute('data-palette') || '',
					mode: root.getAttribute('data-mode') || 'light',
					source,
					deck: deckName(),
				};
				// Export bridge: if the deck's active theme is a Workbench *library*
				// theme (not a built-in palette), resolve its saved CSS so the Markdown
				// export can embed it self-contained. PDF/PPTX/Print rasterize the live
				// DOM, which already carries the theme — only Markdown needs the embed.
				async function activeLibraryTheme() {
					const pal = root.getAttribute('data-palette') || '';
					if (!pal) return null;
					try {
						const hit = (await listAssets('theme')).find((t) => t.name === pal);
