			})();

			// The chat surface — grounded in the architect's live deterministic
			// assessment, persisted per deck via the store, model phrases the reply.
			// Waits for the store so the thread can load/resume per deck.
			function wireChat() {
				const chat = createChat({
					mount: document.getElementById('db-arch-chat'),
					composer: document.getElementById('db-arch-composer'),
					model,
					store: window.__dbStore,
					getAssessment: () => architect.getAssessment(),
					catalog: data.catalog, // the Lattice primer for the cloud prompt
					// Slice B: Converse proposes edits → reviewable diff → Apply splices into
					// the live editor (which re-renders + re-scores via onEdit).
					getSource: () => (window.__dbEditor ? window.__dbEditor.getValue() : ''),
					applyFix: (next) => { if (window.__dbEditor) window.__dbEditor.setValue(next); },
					// Git-like time travel: snapshot the pre-edit deck as a labelled,
					// restorable checkpoint (History rail) the instant an AI edit applies.
					onApply: ({ before, label }) => { if (window.__dbStore?.autoCheckpoint) window.__dbStore.autoCheckpoint(before, label); },
				});
				window.__dbChat = chat;
			}
			if (window.__dbStore) wireChat();
			else window.addEventListener('db-store-ready', wireChat, { once: true });

			// Jump to top / latest: the Architect panel body (.db-arch-scroll) scrolls;
			// show each arrow only when overflowing AND away from that end (pure logic in
			// scrollJumpState). Saves a manual scroll through a long thread + edit cards.
			(function () {
				const scroller = document.querySelector('#db-architect .db-arch-scroll');
				const jump = document.getElementById('db-arch-jump');
				if (!scroller || !jump) return;
				const upBtn = jump.querySelector('[data-dir="top"]');
				const downBtn = jump.querySelector('[data-dir="bottom"]');
				const sync = () => {
					const s = scrollJumpState({ scrollTop: scroller.scrollTop, scrollHeight: scroller.scrollHeight, clientHeight: scroller.clientHeight });
					upBtn.hidden = !s.top;
					downBtn.hidden = !s.bottom;
					jump.classList.toggle('is-idle', !s.top && !s.bottom);
				};
				upBtn.addEventListener('click', () => scroller.scrollTo({ top: 0, behavior: 'smooth' }));
				downBtn.addEventListener('click', () => scroller.scrollTo({ top: scroller.scrollHeight, behavior: 'smooth' }));
				scroller.addEventListener('scroll', sync, { passive: true });
