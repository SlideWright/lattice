				}
			}

			const architect = createArchitect({
				vocab: data.lintVocab,
				catalog: data.catalog,
				model,
				mount: document.getElementById('db-arch-review'),
				reveal: revealLine,
				// setValue dispatches a doc change -> onEdit -> render + save + re-lint.
				applyFix: (newSource) => { if (window.__dbEditor) window.__dbEditor.setValue(newSource); },
			});
			window.__dbArchitect = architect;
			// Component bridge: teach the Architect's linter the author's saved local
			// components so a valid `_class: <local>` isn't flagged "unknown class".
			// Re-runs the review once names are known (and on every library refresh).
			function mergeArchComponents() {
				const local = window.__dbLibraryComponents || [];
				if (!local.length) return;
				architect.addNames(local.map((c) => c.name));
				architect.update(window.__dbEditor ? window.__dbEditor.getValue() : '');
			}
			window.addEventListener('db-library-components', mergeArchComponents);
			mergeArchComponents();

			// Coach console (deterministic): action chips -> result cards. The Coach
			// view's structured answers replace a fake chat composer.
			const coach = createCoachConsole({
				chipsHost: document.getElementById('db-coach-chips'),
				cardHost: document.getElementById('db-coach-card'),
				introHost: document.getElementById('db-coach-intro'),
				getAssessment: () => architect.getAssessment(),
				getSource: () => (window.__dbEditor ? window.__dbEditor.getValue() : ''),
				reveal: revealLine,
			});
			window.__dbCoach = coach;

			// Coach <-> Converse toggle: Coach is the deterministic console; Converse is
			// the real conversation (composer shown only when a real model backs it).
			const archBody = document.getElementById('db-arch-body');
			function setArchMode(mode) {
				archBody.setAttribute('data-arch-mode', mode);
				for (const t of document.querySelectorAll('.db-arch-mode')) t.setAttribute('aria-selected', t.getAttribute('data-mode') === mode ? 'true' : 'false');
				try { localStorage.setItem('lattice-db-arch-mode', mode); } catch (e) {}
			}
			window.__dbSetArchMode = setArchMode; // the onboarding lands the user in Coach
			for (const t of document.querySelectorAll('.db-arch-mode')) t.addEventListener('click', () => setArchMode(t.getAttribute('data-mode')));
			// Landing mode on reload: the preference pins Coach/Converse, or 'remember'
			// falls back to whichever mode you last used (the legacy behaviour).
			try {
				const landing = getPref('landingMode');
				if (landing === 'coach' || landing === 'converse') setArchMode(landing);
				else { const m = localStorage.getItem('lattice-db-arch-mode'); if (m === 'converse') setArchMode('converse'); }
			} catch (e) {}
