					if (window.matchMedia('(max-width: 1024px)').matches && window.__dbSetPane) window.__dbSetPane('architect');
					window.__dbOnboardingStart = false;
				},
			});
		</script>

		<!-- Export — MD / PDF / PPTX (Slice 4). PptxGenJS is lazy-imported inside
		     the module on first PPTX use, so it never loads unless invoked. -->
		<script>
			import { exportMarkdown, exportPdf, exportPptx, exportPrint } from '../playground/drawing-board-export.js';
			const wrap = document.getElementById('db-export-wrap');
			const trigger = document.getElementById('db-export');
			const menu = document.getElementById('db-export-menu');
			const statusEl = document.getElementById('db-status');
			const deckName = () => {
				const n = document.querySelector('.db-deck[aria-current="true"] .db-deck-name');
				return (n && n.textContent) || 'deck';
			};
			const status = (msg, err) => { if (statusEl) { statusEl.textContent = msg; statusEl.classList.toggle('err', !!err); } };
			const closeMenu = () => { menu.hidden = true; trigger.setAttribute('aria-expanded', 'false'); };
			trigger.addEventListener('click', (e) => {
				e.stopPropagation();
				const open = menu.hidden;
				menu.hidden = !open;
				trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
			});
			document.addEventListener('click', (e) => { if (wrap && !wrap.contains(e.target)) closeMenu(); });
			document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });
			menu.addEventListener('click', async (e) => {
				const btn = e.target.closest('[data-export]');
				if (!btn) return;
				closeMenu();
				const kind = btn.getAttribute('data-export');
				const frame = document.getElementById('db-frame');
				const source = window.__dbEditor ? window.__dbEditor.getValue() : '';
				try {
					if (kind === 'md') { exportMarkdown(source, deckName()); status('Markdown exported.'); }
					else if (kind === 'pdf') { status('Exporting PDF…'); await exportPdf(frame, deckName(), (m) => status(m)); status('PDF exported.'); }
					else if (kind === 'pptx') { await exportPptx(frame, deckName(), (m) => status(m)); status('PowerPoint exported.'); }
					else if (kind === 'print') { exportPrint(frame); status('Opening print dialog…'); }
				} catch (err) { status(String(err.message || err), true); }
			});
		</script>

		<!-- Focus edit modes (Slice 9). The toolbar button enables when the cursor
