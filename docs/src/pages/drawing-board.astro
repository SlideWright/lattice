				if (window.ResizeObserver) new ResizeObserver(sync).observe(scroller.firstElementChild || scroller);
				const mo = new MutationObserver(sync);
				mo.observe(scroller, { childList: true, subtree: true });
				sync();
			})();

			// Conversation-first onboarding: 3 questions -> retrieval -> scaffold a
			// new deck (via the store when present, else just load it into the editor).
			// The model upgrades archetype retrieval to semantic when embeddings load.
			createOnboarding({
				catalog: data.catalog,
				mount: document.getElementById('db-arch-onboard'),
				model,
				onBuild: async (src, name) => {
					// name = the archetype (Drafting) or undefined (Freehand → auto-titled
					// from the deck's H1). The store derives the title + description.
					// Flag onboarding-start so the controller doesn't yank narrow layouts to
					// the editor — keep you on the Architect to see its greeting (say, below).
					window.__dbOnboardingStart = true;
					if (window.__dbStore && window.__dbStore.create) await window.__dbStore.create(src, name);
					else if (window.__dbEditor) window.__dbEditor.setValue(src);
				},
				// The Architect "talks back" when it starts a deck — in COACH, the default
				// mode, where the review + chips live. (The Converse thread is hidden under
				// Coach, so a greeting posted there would never be seen.) On narrow layouts
				// stay on the Architect so the greeting + first review are seen.
				say: async (text) => {
					if (window.__dbSetArchMode) window.__dbSetArchMode('coach');
					if (window.__dbCoach && window.__dbCoach.intro) window.__dbCoach.intro(text);
					if (window.matchMedia('(max-width: 1024px)').matches && window.__dbSetPane) window.__dbSetPane('architect');
					window.__dbOnboardingStart = false;
				},
			});
		</script>

		<!-- Export — MD / PDF / PPTX (Slice 4). PptxGenJS is lazy-imported inside
		     the module on first PPTX use, so it never loads unless invoked. -->
		<script>
			import { exportMarkdown, exportMarp, exportPdf, exportPptx, exportPrint, exportChart, activeChartSection } from '../playground/drawing-board-export.js';
			import { listAssets } from '../playground/asset-store.js';
			import { referencedComponents } from '../playground/layout-core.generated.js';
			const statusEl = document.getElementById('db-status');
			const deckName = () => {
				const n = document.querySelector('.db-deck[aria-current="true"] .db-deck-name');
				return (n && n.textContent) || 'deck';
			};
			const status = (msg, err) => { if (statusEl) { statusEl.textContent = msg; statusEl.classList.toggle('err', !!err); } };

			// ── Export progress cue ───────────────────────────────────────────────
			// The inline .db-status lives in the *preview* pane header — invisible from
			// the editor pane on mobile, where Export is tapped. A rasterizing export
			// (PDF/PPTX) takes seconds-to-tens-of-seconds on a phone, so without a
			// pane-independent cue it reads as "nothing happened / it's broken." This
			// floating card mirrors the toast's visual language and shows a determinate
			// bar (slide i of N) where we have it, indeterminate otherwise.
			let progressEl = null;
			let progressFill = null;
			let progressMsg = null;
			function showProgress(msg) {
				if (!progressEl) {
					progressEl = document.createElement('div');
					progressEl.className = 'db-progress is-indeterminate';
					progressEl.setAttribute('role', 'status');
					progressEl.setAttribute('aria-live', 'polite');
					const track = document.createElement('div');
					track.className = 'db-progress-track';
					progressFill = document.createElement('div');
					progressFill.className = 'db-progress-fill';
					track.appendChild(progressFill);
					progressMsg = document.createElement('span');
					progressMsg.className = 'db-progress-msg';
					progressEl.appendChild(track);
					progressEl.appendChild(progressMsg);
					document.body.appendChild(progressEl);
					requestAnimationFrame(() => progressEl && progressEl.classList.add('is-in'));
				}
				if (progressMsg) progressMsg.textContent = msg;
			}
			function setProgress(prog) {
				if (!progressEl) return;
				if (prog && typeof prog.total === 'number' && prog.total > 0) {
					progressEl.classList.remove('is-indeterminate');
					progressFill.style.width = Math.round((prog.current / prog.total) * 100) + '%';
				} else {
					progressEl.classList.add('is-indeterminate');
					progressFill.style.width = '';
				}
			}
			function hideProgress() {
				if (!progressEl) return;
				const el = progressEl;
				el.classList.remove('is-in');
				setTimeout(() => el.remove(), 200);
				progressEl = progressFill = progressMsg = null;
			}
			// Surface a failure where the user is actually looking (a toast floats over
			// any pane) AND in the inline status, with a one-tap Retry of the same kind.
			function exportError(err, retry) {
				const msg = String((err && err.message) || err || 'Export failed.');
				status(msg, true);
				const toast = window.__dbStore && window.__dbStore.toast;
				if (toast) toast('Export failed: ' + msg, retry ? 'Retry' : null, retry || null);
			}
			// The Export menu CHROME is a React + shadcn DropdownMenu island
			// (DrawingBoardExportMenu); the export LOGIC below (runExport →
			// drawing-board-export.js) is UNCHANGED — the island only drives it
			// through this bus. "Export chart" shows only when the cursor's slide
			// carries a chart; the island queries hasActiveChart() each time it opens.
			window.__dbExport = {
				run: (kind) => runExport(kind),
				hasActiveChart: () => !!activeChartSection(document.getElementById('db-frame')),
			};
			window.dispatchEvent(new Event('db-export-ready'));

			async function runExport(kind) {
				const frame = document.getElementById('db-frame');
				const source = window.__dbEditor ? window.__dbEditor.getValue() : '';
				// Provenance for the export stamp: which engine + build + theme rendered
				// these slides (drawing-board-export.js packs it into document properties).
				const root = document.documentElement;
				const PG = window.LatticePlayground;
				const dbd = JSON.parse(document.getElementById('db-data').textContent);
				const meta = {
					engine: (PG && PG.engine) || 'lattice',
					version: dbd.version || '',
					build: dbd.buildId || '',
					palette: root.getAttribute('data-palette') || '',
					mode: root.getAttribute('data-mode') || 'light',
					source,
					deck: deckName(),
				};
				// Export bridge: if the deck's active theme is a Workbench *library*
				// theme (not a built-in palette), resolve its saved CSS so the Markdown
				// export can embed it self-contained. PDF/PPTX/Print rasterize the live
				// DOM, which already carries the theme — only Markdown needs the embed.
				async function activeLibraryTheme() {
					const pal = root.getAttribute('data-palette') || '';
					if (!pal) return null;
					try {
						const hit = (await listAssets('theme')).find((t) => t.name === pal);
						return hit ? { name: hit.name, css: hit.text || '' } : null;
					} catch (_e) { return null; }
				}
				// Component bridge: vendor the CSS of every library component the deck
				// references (detected from its _class directives), so the exported .md
				// renders them across all three engine paths. Referenced-only keeps it
				// lean; PDF/PPTX/Print rasterize the already-styled live DOM.
				async function referencedLibraryComponents() {
					try {
						const lib = await listAssets('component');
						if (!lib.length) return [];
						const refs = referencedComponents(source, lib.map((c) => c.name));
						return refs
							.map((name) => lib.find((c) => c.name === name))
							.filter(Boolean)
							.map((c) => ({ name: c.name, css: c.text || '' }));
					} catch (_e) { return []; }
				}
				// Drive both the inline status text AND the floating progress card from
				// the export callback — the card carries the determinate {current,total}.
				const onStatus = (m, prog) => { status(m); showProgress(m); setProgress(prog); };
				try {
					if (kind === 'md') {
						const lib = await activeLibraryTheme();
						const comps = await referencedLibraryComponents();
						exportMarkdown(source, deckName(), lib, comps);
						const bits = [];
						if (lib) bits.push('theme');
						if (comps.length) bits.push(comps.length + ' component' + (comps.length === 1 ? '' : 's'));
						status(bits.length ? `Markdown exported (${bits.join(' + ')} embedded).` : 'Markdown exported.');
					}
					else if (kind === 'pdf') { onStatus('Exporting PDF…'); await exportPdf(frame, deckName(), onStatus, meta); status('PDF exported.'); }
					else if (kind === 'pptx') { onStatus('Exporting PowerPoint…'); await exportPptx(frame, deckName(), onStatus, meta); status('PowerPoint exported.'); }
					else if (kind === 'print') { exportPrint(frame, meta); status('Opening print dialog…'); }
					else if (kind === 'charts-svg') { onStatus('Exporting chart…'); await exportChart(frame, deckName(), onStatus); }
					else if (kind === 'marp') {
						onStatus('Building Marp bundle…');
						await exportMarp(source, deckName(), meta.palette, dbd.themeBase);
						status('Marp bundle exported (.zip).');
					}
					hideProgress();
				} catch (err) { hideProgress(); exportError(err, () => runExport(kind)); }
			}
		</script>

		<!-- Workbench library themes (export bridge) — load the user's saved themes
		     from the lattice-workbench asset store and hand them to the
		     render-controller module (drawing-board-render.js) via a global +
		     a refresh event. See engineering/decisions/2026-06-11-workbench-export-
		     bridge.md. -->
		<script>
			import { listAssets } from '../playground/asset-store.js';
			async function loadLibraryThemes() {
				let themes = [];
				try {
					themes = (await listAssets('theme'))
						.map((t) => ({ name: t.name, label: t.label || t.name, css: t.text || '' }))
						.filter((t) => t.name && t.css);
				} catch (_e) { themes = []; }
				window.__dbLibraryThemes = themes;
				window.dispatchEvent(new Event('db-library-themes'));
			}
			window.addEventListener('db-library-themes-refresh', loadLibraryThemes);
			loadLibraryThemes();
		</script>

		<!-- Workbench library COMPONENTS (component bridge) — load the user's saved
		     CSS-only local components and expose (a) the raw list for the editor's
		     autocomplete merge, and (b) a prepare() helper the render-controller
		     module + export use to vendor only the components a deck references.
		     One pure scan (referencedComponents) feeds live render AND export, so
		     they can't drift. See engineering/decisions/2026-06-12-workbench-
		     component-bridge.md. -->
		<script>
			import { listAssets } from '../playground/asset-store.js';
			import { referencedComponents, embedComponentsInMarkdown } from '../playground/layout-core.generated.js';
			let LIBC = [];
			const names = () => LIBC.map((c) => c.name);
			const refComps = (src) =>
				referencedComponents(src, names()).map((n) => LIBC.find((c) => c.name === n)).filter(Boolean);
			// Stable across reloads of the list (methods read the live LIBC). embed()
			// vendors referenced component CSS into the source; key() is the referenced
			// set, folded into the render signature so a newly-referenced component
			// forces a full frame rebuild (its CSS lands in out.css, which the
			// section-only patch path does not refresh).
			window.__dbComponents = {
				list: () => LIBC,
				embed: (src) => embedComponentsInMarkdown(src, refComps(src)),
				key: (src) => referencedComponents(src, names()).join(','),
			};
			async function loadLibraryComponents() {
				try {
					LIBC = (await listAssets('component'))
						.map((c) => ({
							name: c.name, css: c.text || '', bucket: c.bucket || null,
							skeleton: c.skeleton || '', manifest: c.manifest || null,
						}))
						.filter((c) => c.name && c.css);
				} catch (_e) { LIBC = []; }
				window.__dbLibraryComponents = LIBC;
				window.dispatchEvent(new Event('db-library-components'));
			}
			window.addEventListener('db-library-components-refresh', loadLibraryComponents);
			loadLibraryComponents();
		</script>

		<!-- Focus edit modes (Slice 9). The toolbar button enables when the cursor
		     sits in a ```mermaid / ```chart / $$…$$ block; opening swaps in an
		     isolated sub-editor + live fragment preview. Deterministic, no model. -->
		<script>
			import { createFocus } from '../playground/drawing-board-focus.js';
			import { createRefine } from '../playground/drawing-board-refine.js';
			const data = JSON.parse(document.getElementById('db-data').textContent);
			const openBtn = document.getElementById('db-focus-open');
			function wireFocus() {
				const focus = createFocus({
					host: document.getElementById('db-focus'),
					editor: window.__dbEditor,
					themeBase: data.themeBase,
					runtimeUrl: data.runtimeUrl,
				});
				window.__dbFocus = focus;
				if (openBtn) openBtn.addEventListener('click', () => focus.open());

				// Refine actions — gated on a real generation tier (model.complete);
				// disabled with a hint when running deterministically.
				const statusEl = document.getElementById('db-status');
				const refine = createRefine({
					trigger: document.getElementById('db-refine-open'),
					menuHost: document.getElementById('db-refine-menu'),
					editor: window.__dbEditor,
					model: window.__dbModel,
					onStatus: (msg, err) => { if (statusEl) { statusEl.textContent = msg; statusEl.classList.toggle('err', !!err); } },
				});
				window.__dbRefine = refine;

				// Toolbar state tracks the caret: focusable-block detection + selection.
				const sync = () => {
					if (openBtn) {
						const b = focus.focusable();
						openBtn.hidden = !b;
						if (b) openBtn.textContent = 'Focus ' + b.kind;
					}
					refine.sync();
				};
				window.__dbEditor.onCursor(sync);
				sync();
			}
			if (window.__dbEditor) wireFocus();
			else window.addEventListener('db-editor-ready', wireFocus, { once: true });
		</script>

		<!-- Practice mode (full-screen rehearsal). Renders the deck one slide at a
		     time through render path #2 (window.LatticePlayground) + the runtime in
		     its own iframe (slide-box pinned for preview parity), paces against a
		     target talk length, and coaches delivery with timed beats over the slide.
		     The plan is deterministic by default, AI-tailored when a model is
		     connected (see drawing-board-rehearsal.js). -->
		<script>
			import { createPractice } from '../playground/drawing-board-practice.js';
			const data = JSON.parse(document.getElementById('db-data').textContent);
			// name -> bucket lookup from the compact catalog, for slide pause cues.
			const buckets = new Map((data.catalog || []).map((c) => [c.name, c.bucket]));
			const practice = createPractice({
				host: document.getElementById('db-practice'),
				getSource: () => (window.__dbEditor ? window.__dbEditor.getValue() : ''),
				runtimeUrl: data.runtimeUrl,
				themeBase: data.themeBase,
				bucketOf: (name) => buckets.get(name) || null,
				// Share the page's model ladder so a connected cloud/local tier tailors
				// the rehearsal plan; absent one, the deterministic floor still runs.
				model: window.__dbModel,
			});
			const openBtn = document.getElementById('db-practice-open');
			if (openBtn) openBtn.addEventListener('click', () => practice.open());
		</script>

		<!-- Bridge: expose the shared filmstrip-preview controller (deck-preview.js)
		     on window so the render-controller module (drawing-board-render.js) drives
		     the iframe write/patch/fit through one implementation — the same module
		     the playground + both Workbench studios use. -->
		<script>
			import { renderDeck } from '../playground/deck-preview.js';
			window.LatticeDeckPreview = { renderDeck };
		</script>

		<!-- The marp render engine (window.LatticePlayground) loads ON DEMAND via
		     load-engine.ts (triggered on idle below, after the chrome + editor
		     paint), NOT eagerly here — so the topbar + editor host paint without the
		     ~554KB-gz bundle blocking first paint / mobile LCP. The render loop polls
		     for the global, so deferring injection is safe (load-engine.ts contract,
		     matching the playground + workbench surfaces). -->
		<script>
			import { ensureEngine } from '../lib/load-engine.ts';
			const __dbData = JSON.parse(document.getElementById('db-data').textContent);
			const __engineUrl = __dbData.engineUrl;
			function __loadEngine() { if (__engineUrl) void ensureEngine(__engineUrl); }
			// On idle so the chrome paints first; the { timeout } bounds it so a
			// perpetually busy main thread can't starve the engine load (the render
			// loop tolerates a late global, but we don't want it indefinitely late).
			// Falls back to a microtask where requestIdleCallback is unavailable.
			if (window.requestIdleCallback) window.requestIdleCallback(__loadEngine, { timeout: 2000 });
			else setTimeout(__loadEngine, 0);
		</script>
		<!-- The live render controller — the render loop + the Drawing-Board-specific
		     extras (token-flip, cursor↔slide sync, slide-start cache, theme sync,
		     resizers, mobile panes). Extracted to an importable vanilla module
		     (drawing-board-render.js); this is the thin bootstrap that parses the
		     page handoff + calls it. It was an is:inline script; it now rides the
		     module graph (deferred) — order-independent: it guards the engine +
		     deck-preview globals with a polling retry, drives editor/store/architect
		     through window globals + custom events, and the pre-paint palette/mode
		     seed stays the separate <head> is:inline script above. -->
		<script>
			import { createRenderController } from '../playground/drawing-board-render.js';
			createRenderController(JSON.parse(document.getElementById('db-data').textContent));
		</script>

		<!-- Guided tour: first-visit walkthrough + replay button (driver.js). -->
		<script>
			import { initDrawingBoardTour } from '../playground/drawing-board-tour.js';
			initDrawingBoardTour();
		</script>
	</body>
</html>
