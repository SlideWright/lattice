				window.__dbDrawerTab = show;
			})();

			// After detection, refresh the chip and reconnect a previously-loaded model
			// (weights are cached, but the running engine is lost on reload — re-init it,
			// which is what makes the model "stick" across refreshes).
			model.refreshAvailability().then(() => { settings.refresh(); settings.restore(); });

			// Reveal a source line in the editor. On the ≤1024px single-pane layout the
			// inactive panes are display:none, and CodeMirror can't scroll a hidden
			// view — so switch to the editor pane FIRST, then goToLine on the next
			// frame once it's laid out and measurable. (Both the Architect findings and
			// the Coach cards route their "Reveal" / "Go to slide" here.)
			function revealLine(line) {
