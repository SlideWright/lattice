			window.addEventListener('db-active-deck', () => { if (window.__dbCoach && window.__dbCoach.clearIntro) window.__dbCoach.clearIntro(); });

			// Converse is "ready" (composer shown) only with a real generative model.
			window.__dbSyncConverse = function () {
				var a = model.availability ? model.availability() : { generation: 'floor' };
				var ready = a.modelOn && a.generation !== 'floor';
				archBody.setAttribute('data-converse-ready', ready ? 'true' : 'false');
			};
			window.__dbSyncConverse();

			// Converse "Connect AI" — OpenRouter (your own account) via one-click
			// OAuth: a redirect to openrouter.ai and back (the ?code= return is handled
			// on load, below). On connect it becomes the active generation backend.
			(function () {
				var wrap = document.getElementById('db-converse-connect-wrap');
				var row = document.getElementById('db-converse-connect-row');
				var orBtn = document.getElementById('db-converse-connect-or');
				var fine = wrap && wrap.querySelector('.db-converse-fine');
				if (!wrap || !row || !orBtn) return;
				var el = function (t, c, x) { var e = document.createElement(t); if (c) e.className = c; if (x != null) e.textContent = x; return e; };
				function reset() { wrap.innerHTML = ''; wrap.appendChild(row); if (fine) wrap.appendChild(fine); }
				function showError(msg) {
					wrap.innerHTML = '';
					wrap.appendChild(el('p', 'db-settings-error', msg));
					var retry = el('button', 'db-btn', 'Back'); retry.type = 'button'; retry.addEventListener('click', reset);
					wrap.appendChild(retry);
				}
				// OpenRouter — one-click OAuth (PKCE). We redirect to openrouter.ai;
				// the callback returns here with ?code=, handled on the next load.
				orBtn.addEventListener('click', async function () {
					orBtn.disabled = true; orBtn.textContent = 'Redirecting…';
					try {
						var cb = location.origin + location.pathname; // return cleanly to this page
						var url = await window.__dbModel.beginOpenRouterAuth(cb);
						location.href = url;
					} catch (e) {
						orBtn.disabled = false; orBtn.textContent = 'Connect OpenRouter — your account';
						showError('Couldn’t start OpenRouter sign-in: ' + (e && e.message || e));
					}
				});
			})();

			// OpenRouter OAuth return: openrouter.ai redirects back with ?code=. Only
			// act on it when WE started the flow (a PKCE verifier is pending), then
			// exchange the code for a key, strip ?code from the URL, and drop the user
			// straight into Converse with OpenRouter as the active cloud.
			(function () {
				try {
					var params = new URLSearchParams(location.search);
					var code = params.get('code');
					if (!code || !window.__dbModel || !window.__dbModel.hasPendingOpenRouterAuth || !window.__dbModel.hasPendingOpenRouterAuth()) return;
					window.__dbModel.resumeOpenRouterAuth(code).then(function () {
