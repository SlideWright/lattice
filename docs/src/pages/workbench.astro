---
// The Workbench — a standalone Astro route (like the Playground / Drawing
// Board) where an author FABRICATES the parts of a deck. Two faculties: the
// Theme Studio (craft a palette → derived, WCAG-audited, rendered live) and the
// Layout Studio (author a CSS-only local component, gated like the engine).
//
// Phase 5 of the shadcn migration: the page chrome is a React + shadcn island
// (WorkbenchApp). Astro owns the head, the topbar, and the engine <script>;
// React owns the faculty Tabs, the action buttons / text inputs / textareas, the
// theme-CSS Collapsible, the faculty switch, and BOOTS the two vanilla studios —
// WRAPPING the irreducible engine pieces (theme-studio.js, component-studio.js,
// deck-config.js, deck-preview.js, the engine bundle, the driver.js tour) rather
// than reimplementing them. See engineering/decisions/2026-06-09-shadcn-migration.md §0.
import { readFileSync } from 'node:fs';
import { createRequire } from 'node:module';
import { join } from 'node:path';
import '../styles/landing.css';
import '../styles/workbench.css';
import '../styles/deck-config.css';
import SiteHeader from '../components/site/SiteHeader.astro';
import ResourceHints from '../components/site/ResourceHints.astro';
import WorkbenchApp from '../components/workbench/WorkbenchApp.tsx';
import { joinBase } from '../lib/base-url.mjs';
import { toursMode } from '../lib/deploy-env.mjs';
import { assetBase } from '../playground/asset-version.mjs';

const base = import.meta.env.BASE_URL;
const url = (p) => joinBase(base, p);
const pg = assetBase();

// Tours gate, baked into the HTML so the client check is build-time: 'on' on the
// production site (launchers + first-visit auto-start), 'preview' on Cloudflare PR
// previews (launchers show for review, no auto-start popup), 'off' on local dev
// (opt in with ?tours=on). See lib/deploy-env.mjs.
const toursAttr = toursMode({
	dev: import.meta.env.DEV,
	cfPages: process.env.CF_PAGES,
	cfBranch: process.env.CF_PAGES_BRANCH,
});

// Shipped component class names, loaded at build time from the live manifests.
// The Layout Studio blocks a local component whose name collides with one of
// these (the component bridge keeps a saved local name from shadowing or
// double-defining a shipped class). See the component-bridge decision note.
const require = createRequire(import.meta.url);
const { loadAll } = require(join(process.cwd(), '..', 'lib/components', 'index.js'));
const { FINISH_NAMES } = require(join(process.cwd(), '..', 'lib/core', 'resolve-finish.js'));
const shippedNames = loadAll().map((m) => m.name);

// The config payload the React island hands to both studios at boot.
const wbData = {
	themeBase: url(pg + 'themes/'),
	runtimeUrl: url(pg + 'lattice-runtime.js'),
	engineUrl: url(pg + 'lattice-playground.js'),
	shippedNames,
	finishes: FINISH_NAMES,
};

// The same palette vocabulary every site picker uses (incl. the a11y themes) —
// so the Workbench topbar offers the identical theme dropdown as everywhere
// else. It restyles the page chrome; the Theme Studio's specimen still previews
// the theme you're crafting.
const tokensCss = readFileSync(join(process.cwd(), 'src/styles/lattice-tokens.generated.css'), 'utf8');
const palettes = [...new Set([...tokensCss.matchAll(/data-palette="([^"]+)"/g)].map((m) => m[1]))];
---

<!doctype html>
<html lang="en" data-palette="indaco" data-mode="light" data-tours={toursAttr}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<ResourceHints />
		<title>Lattice Workbench — craft a theme</title>
		<meta name="description" content="Craft a Lattice palette from a handful of essential colours. The Workbench derives the full token contract, audits WCAG AA contrast, and renders it live on a specimen deck — copy or download a droppable theme." />
		<link rel="icon" type="image/svg+xml" href={url('favicon.svg')} />
		<script is:inline>
			(function () {
				var r = document.documentElement;
				try {
					var p = localStorage.getItem('lattice-docs-palette');
					if (p) r.setAttribute('data-palette', p);
					var m = localStorage.getItem('lattice-docs-mode');
					if (m === 'light' || m === 'dark') r.setAttribute('data-mode', m);
					else if (window.matchMedia && matchMedia('(prefers-color-scheme: dark)').matches) r.setAttribute('data-mode', 'dark');
				} catch (e) {}
			})();
		</script>
	</head>
	<body class="wb-page">
		<SiteHeader palettes={palettes} wide={true} />

		<!-- The Workbench surface: one React + shadcn island owning the faculty
		     Tabs, the chrome controls, the theme-CSS Collapsible, the faculty
		     switch, and booting the two vanilla studios into the host elements it
		     renders (theme-studio.js + component-studio.js, queried by class). -->
		<WorkbenchApp client:load data={wbData} />

		<!-- The in-browser engine (same bundle as the Playground) is loaded ON
		     DEMAND by load-engine.ts (WorkbenchApp triggers it on idle, after the
		     chrome paints), not eagerly here — so the faculty Tabs + controls paint
		     without the ~554KB-gz bundle blocking. The studios poll for the global. -->

		<!-- Guided tour: first-visit walkthrough + replay button (driver.js). It
		     targets the live DOM by selector, so it runs after the island hydrates
		     (a 550ms auto-start delay covers hydration); production-only. -->
		<script>
			import { initWorkbenchTour } from '../playground/workbench-tour.js';
			initWorkbenchTour();
		</script>
	</body>
</html>
