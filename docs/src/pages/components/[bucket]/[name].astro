---
// Per-component reference page — one focused page per component, built from the
// manifests via getStaticPaths(). Live preview that flips to an in-browser
// editor (Specimen), the full anatomy/slots/variants documentation
// (ComponentDocs), and the shared left nav + topbar (ComponentsLayout). This
// is the "built-in, not bolted-on" replacement for the old single-file portal.
import { createRequire } from 'node:module';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Specimen from '../../../components/Specimen.astro';
import ComponentDocs from '../../../components/ComponentDocs.astro';
import { buildCatalog, buildLenses, groupCatalog } from '../../../lib/families.mjs';

const base = import.meta.env.BASE_URL;
const url = (p) => `${base.replace(/\/$/, '')}/${p}`.replace(/([^:])\/{2,}/g, '$1/');
const tc = (s) => (s ? s[0].toUpperCase() + s.slice(1) : s);

export async function getStaticPaths() {
	const repoRoot = join(process.cwd(), '..');
	const require = createRequire(import.meta.url);
	const { loadAll, manifestBucket } = require(join(repoRoot, 'lib/components', 'index.js'));
	const { resolveAnatomy } = require(join(repoRoot, 'tools', 'anatomy-catalog.js'));

	const manifests = loadAll();

	// Shared browse data: the flat catalog, the Group-by lenses, and the SSR
	// default (Family) grouping for the left nav. prev/next follows the same
	// family order, so the pager matches the default nav.
	const catalog = buildCatalog(manifests, manifestBucket);
	const lenses = buildLenses();
	const navGroups = groupCatalog(catalog, 'family');
	const flat = navGroups.flatMap((g) => g.items.map((it) => ({ name: it.name, bucket: it.bucket })));
	const nameToBucket = {};
	for (const it of catalog) nameToBucket[it.name] = it.bucket;

	return manifests.map((m) => {
		const bucket = manifestBucket(m);
		const i = flat.findIndex((f) => f.name === m.name);
		const prev = i > 0 ? flat[i - 1] : null;
		const next = i >= 0 && i < flat.length - 1 ? flat[i + 1] : null;
		const anatomy = m.anatomyBlock ? resolveAnatomy(m.anatomyBlock) : null;
		return {
			params: { bucket, name: m.name },
			props: { m, bucket, anatomy, catalog, lenses, navGroups, nameToBucket, prev, next },
		};
	});
}

const { m, bucket, anatomy, catalog, lenses, navGroups, nameToBucket, prev, next } = Astro.props;

const docsRoot = process.cwd();
const tokensCss = readFileSync(join(docsRoot, 'src/styles/lattice-tokens.generated.css'), 'utf8');
const palettes = [...new Set([...tokensCss.matchAll(/data-palette="([^"]+)"/g)].map((x) => x[1]))];

const sample = m.sample || m.skeleton;

// Variants for the specimen switcher: the base layout plus each documented
// modifier (its own slide markdown). Clicking one previews it in place; each
// can also be opened in the playground seeded with that markdown.
const variantDocs = m.variantDocs || {};
const variantKeys = Array.isArray(m.variants) ? m.variants.filter((v) => variantDocs[v]) : [];
const variants = [
	{ key: 'default', label: 'default', caption: '', sample },
	...variantKeys.map((v) => ({ key: v, label: v, caption: variantDocs[v].caption || '', sample: variantDocs[v].sample })),
];
const mermaid = variants.some((v) => /```mermaid/.test(v.sample));

// Optional: group the variant chips by axis (manifest.variantAxes) so the
// switcher reads as e.g. "Basemap: world · us" + "Modifier: highlight · …"
// instead of a flat peer list. The exclusive axis's `default` member maps to
// the 'default' chip (the bare sample). Falls back to the flat list when a
// component declares no axes.
const chipKeys = new Set(variants.map((c) => c.key));
const variantGroups = Array.isArray(m.variantAxes) && m.variantAxes.length
	? m.variantAxes
			.map((ax) => ({
				label: ax.label,
				chips: ax.members
					.map((mem) => {
						const key = mem === ax.default ? 'default' : mem;
						return chipKeys.has(key) ? { key, label: mem } : null;
					})
					.filter(Boolean),
			}))
			.filter((g) => g.chips.length)
	: null;
---

<ComponentsLayout
	title={`${m.name} — Lattice component`}
	description={m.description}
	palettes={palettes}
	catalog={catalog}
	lenses={lenses}
	navGroups={navGroups}
	current={m.name}
>
	<article class="cpage">
		<header class="cpage-head">
			<p class="cpage-crumb">
				<a href={url('components/')}>Components</a>
				<span aria-hidden="true">/</span>
				<span>{tc(bucket)}</span>
			</p>
			<div class="cpage-titlerow">
				<h1>{m.name}</h1>
				<div class="cpage-ffs">
					<span class="ffs-pill" title="Function">{tc(m.function)}</span>
					<span class="ffs-pill" title="Form">{tc(m.form)}</span>
					<span class="ffs-pill" title="Substance">{tc(m.substance)}</span>
				</div>
			</div>
			<p class="cpage-lead">{m.description}</p>
		</header>

		<Specimen name={m.name} sample={sample} mermaid={mermaid} variants={variants} variantGroups={variantGroups} />

		<ComponentDocs m={m} anatomy={anatomy} nameToBucket={nameToBucket} />

		<nav class="cpage-pager" aria-label="Previous and next component">
			{prev ? (
				<a class="cpage-pager-link prev" href={url(`components/${prev.bucket}/${prev.name}/`)}>
					<span class="cpage-pager-dir"><span class="ico ico-arrow-left" aria-hidden="true"></span> Previous</span>
					<span class="cpage-pager-name">{prev.name}</span>
				</a>
			) : <span />}
			{next ? (
				<a class="cpage-pager-link next" href={url(`components/${next.bucket}/${next.name}/`)}>
					<span class="cpage-pager-dir">Next <span class="ico ico-arrow-right" aria-hidden="true"></span></span>
					<span class="cpage-pager-name">{next.name}</span>
				</a>
			) : <span />}
		</nav>
	</article>
</ComponentsLayout>
