---
// Component reference index — the browsable catalog landing. A fuzzy search +
// "Group by" lens (Family by default) organize the whole set; each card links
// to the focused per-component page. The grid + controls are one React island
// (ComponentIndexIsland) sharing a store with the left-nav island, so search
// and Group-by drive both. Replaces the old vanilla component-browser.js.
import { createRequire } from 'node:module';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import ComponentsLayout from '../../layouts/ComponentsLayout.astro';
import ComponentIndexIsland from '../../components/components-ref/ComponentIndexIsland.tsx';
import { buildCatalog, buildLenses, groupCatalog } from '../../lib/families.mjs';

const base = import.meta.env.BASE_URL;

const docsRoot = process.cwd();
const repoRoot = join(docsRoot, '..');
const require = createRequire(import.meta.url);
const { loadAll, manifestBucket } = require(join(repoRoot, 'lib/components', 'index.js'));

const manifests = loadAll();
const catalog = buildCatalog(manifests, manifestBucket);
const lenses = buildLenses();
const groups = groupCatalog(catalog, 'family');

const tokensCss = readFileSync(join(docsRoot, 'src/styles/lattice-tokens.generated.css'), 'utf8');
const palettes = [...new Set([...tokensCss.matchAll(/data-palette="([^"]+)"/g)].map((x) => x[1]))];
---

<ComponentsLayout
	title="Components — Lattice"
	description="Browse every Lattice slide component: fuzzy search, group by family or function, a live preview, an in-browser editor, and the full anatomy/slots/variants reference — themable in every palette."
	palettes={palettes}
	catalog={catalog}
	lenses={lenses}
	navGroups={groups}
	current={null}
>
	<div class="cindex">
		<ComponentIndexIsland client:idle catalog={catalog} lenses={lenses} base={base} />
	</div>
</ComponentsLayout>
