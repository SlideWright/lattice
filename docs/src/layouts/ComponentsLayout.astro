---
// Full-document shell for the component reference (index + per-component
// pages). Shares the landing/playground topbar and palette/light-dark
// controls, adds the persistent left nav, and exposes a main slot. This is
// what makes the reference feel built-in (like the playground) rather than a
// bolted-on generated blob: same chrome, same tokens, same controls.
//
// Props:
//   title       string
//   description string
//   palettes    string[]
//   catalog     lib/families.buildCatalog() output
//   lenses      lib/families.buildLenses() output
//   navGroups   groupCatalog(catalog, 'family') — SSR default left-nav grouping
//   current     string|null  — active component name (null on the index)
import '../styles/landing.css';
import '../styles/components.css';
import TopBar from '../components/TopBar.astro';
import ComponentNav from '../components/ComponentNav.astro';

const { title, description, palettes = [], catalog = [], lenses = [], navGroups = [], current = null } = Astro.props;

const base = import.meta.env.BASE_URL;
const url = (p) => `${base}/${p}`.replace(/([^:])\/{2,}/g, '$1/');
---

<!doctype html>
<html lang="en" data-palette="indaco" data-mode="light">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="icon" type="image/png" href={url('lattice-logo.png')} />
		<!-- Set palette/mode before first paint to avoid a flash. Shares the
		     landing/playground localStorage keys so a choice carries across. -->
		<script is:inline>
			(function () {
				var r = document.documentElement;
				try {
					var p = localStorage.getItem('lattice-docs-palette');
					if (p) r.setAttribute('data-palette', p);
					var m = localStorage.getItem('lattice-docs-mode');
					if (m === 'light' || m === 'dark') r.setAttribute('data-mode', m);
					else if (window.matchMedia && matchMedia('(prefers-color-scheme: dark)').matches)
						r.setAttribute('data-mode', 'dark');
				} catch (e) {}
			})();
		</script>
	</head>
	<body class="cbody">
		<TopBar palettes={palettes} current="components" wide={true} />

		<div class="csub">
			<button class="cnav-toggle" id="cnav-toggle" type="button" aria-controls="cnav-aside" aria-expanded="false">
				<span class="cnav-toggle-bars"></span> Components
			</button>
			<slot name="subbar" />
		</div>

		<div class="clayout">
			<aside class="clayout-nav" id="cnav-aside">
				<ComponentNav catalog={catalog} lenses={lenses} groups={navGroups} current={current} />
			</aside>
			<button class="cnav-scrim" id="cnav-scrim" aria-hidden="true" tabindex="-1"></button>
			<main class="clayout-main">
				<slot />
			</main>
		</div>

		<!-- Palette + light/dark + nav wiring. Same localStorage keys as the
		     landing/playground, so palette/mode follow you across the site. The
		     Specimen's own observer re-renders the preview when these change. -->
		<script is:inline>
			(function () {
				var root = document.documentElement;
				var sel = document.getElementById('palette');
				if (sel) {
					sel.value = root.getAttribute('data-palette');
					sel.addEventListener('change', function () {
						root.setAttribute('data-palette', sel.value);
						try { localStorage.setItem('lattice-docs-palette', sel.value); } catch (e) {}
					});
				}
				var btn = document.getElementById('mode-toggle');
				if (btn) {
					btn.addEventListener('click', function () {
						var next = root.getAttribute('data-mode') === 'dark' ? 'light' : 'dark';
						root.setAttribute('data-mode', next);
						try { localStorage.setItem('lattice-docs-mode', next); } catch (e) {}
					});
				}
				var navToggle = document.getElementById('nav-toggle');
				var topbar = document.querySelector('.topbar');
				if (navToggle && topbar) {
					navToggle.addEventListener('click', function () {
						var open = topbar.classList.toggle('nav-open');
						navToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
					});
				}
				// Mobile left-nav drawer.
				var cnavToggle = document.getElementById('cnav-toggle');
				var scrim = document.getElementById('cnav-scrim');
				function setNav(open) {
					document.body.classList.toggle('cnav-open', open);
					if (cnavToggle) cnavToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
				}
				if (cnavToggle) cnavToggle.addEventListener('click', function () { setNav(!document.body.classList.contains('cnav-open')); });
				if (scrim) scrim.addEventListener('click', function () { setNav(false); });
				// Close the drawer after picking a component (mobile). Delegated,
				// because the nav list is re-rendered by the component browser.
				var aside = document.getElementById('cnav-aside');
				if (aside) aside.addEventListener('click', function (e) {
					if (e.target.closest('a')) setNav(false);
				});

				// Re-sync palette/mode from storage on every show — including
				// back/forward (bfcache) restores, where the pre-paint <head>
				// script doesn't re-run, so a theme picked on another page (e.g.
				// the playground) would otherwise be stale after Back. Setting the
				// attribute also triggers the Specimen's observer to re-render.
				window.addEventListener('pageshow', function () {
					try {
						var p = localStorage.getItem('lattice-docs-palette');
						if (p && p !== root.getAttribute('data-palette')) root.setAttribute('data-palette', p);
						var m = localStorage.getItem('lattice-docs-mode');
						if ((m === 'light' || m === 'dark') && m !== root.getAttribute('data-mode')) root.setAttribute('data-mode', m);
						if (sel) sel.value = root.getAttribute('data-palette');
					} catch (e) {}
				});
			})();
		</script>
	</body>
</html>
