{
  "name": "@slidewright/lattice",
  "version": "1.0.0",
  "description": "A Marp-based slide deck system for boardroom-quality PDFs from Markdown. Themed layouts, Mermaid diagrams, WCAG AA throughout. Lattice is the engine layer of the SlideWright deck system.",
  "keywords": [
    "marp",
    "slides",
    "presentation",
    "markdown",
    "pdf",
    "mermaid",
    "deck",
    "theme",
    "design-system",
    "slidewright"
  ],
  "homepage": "https://github.com/slidewright/lattice",
  "repository": {
    "type": "git",
    "url": "https://github.com/slidewright/lattice.git"
  },
  "bugs": {
    "url": "https://github.com/slidewright/lattice/issues"
  },
  "license": "MIT",
  "author": "SlideWright",
  "main": "lattice-emulator.js",
  "files": [
    "lattice-emulator.js",
    "lattice-runtime.js",
    "lattice.css",
    "marp.config.js",
    "mermaid-v11.min.js",
    "lib/",
    "themes/",
    "docs/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build:gallery": "node lattice-emulator.js examples/gallery.md examples/gallery.pdf",
    "build:mermaid": "node lattice-emulator.js examples/mermaid-gallery.md examples/mermaid-gallery.pdf",
    "build:backgrounds": "node lattice-emulator.js examples/backgrounds-gallery.md examples/backgrounds-gallery.pdf",
    "build:kpi": "node lattice-emulator.js examples/kpi-gallery.md examples/kpi-gallery.pdf",
    "build": "npm run build:gallery && npm run build:mermaid && npm run build:backgrounds && npm run build:kpi",
    "new:theme": "node tools/new-theme.js",
    "new:slide": "node tools/new-slide.js",
    "snippets:build": "node tools/build-snippets.js",
    "snippets:check": "node tools/build-snippets.js --check",
    "test": "node --test 'test/unit/**/*.test.js'",
    "test:watch": "node --test --watch 'test/unit/**/*.test.js'",
    "test:coverage": "c8 node --test 'test/unit/**/*.test.js'",
    "test:coverage:all": "c8 node --test 'test/unit/**/*.test.js' 'test/integration/**/*.test.js'",
    "test:palette": "node --test 'test/unit/palette/*.test.js'",
    "test:mermaid": "node --test 'test/unit/mermaid/*.test.js'",
    "test:parsing": "node --test 'test/unit/parsing/*.test.js'",
    "test:layouts": "node --test 'test/unit/layouts/*.test.js'",
    "test:cli": "node --test 'test/unit/cli/*.test.js'",
    "test:integration": "node --test 'test/integration/**/*.test.js'",
    "test:integration:galleries": "node --test 'test/integration/galleries/*.test.js'",
    "test:integration:parity": "node --test 'test/integration/parity/*.test.js'",
    "test:integration:mermaid": "node --test 'test/integration/mermaid/*.test.js'",
    "test:integration:screenshot": "node --test 'test/integration/screenshot/*.test.js'",
    "test:all": "node --test 'test/unit/**/*.test.js' 'test/integration/**/*.test.js'",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "clean:scratch": "find .scratch -mindepth 1 -mtime +14 -print -delete",
    "prepare": "lefthook install || true",
    "prepublishOnly": "npm test"
  },
  "dependencies": {
    "@marp-team/marp-cli": "^4.3.1",
    "@mermaid-js/mermaid-cli": "^11.0.0",
    "function-plot": "^1.25.4",
    "katex": "^0.16.46",
    "puppeteer": "^23.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "c8": "^11.0.0",
    "lefthook": "^2.1.6"
  }
}
