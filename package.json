{
  "name": "@slidewright/lattice",
  "version": "1.0.0",
  "description": "A Marp-based slide deck system for boardroom-quality PDFs from Markdown. Themed layouts, Mermaid diagrams, WCAG AA throughout. Lattice is the engine layer of the SlideWright deck system.",
  "keywords": [
    "marp",
    "slides",
    "presentation",
    "markdown",
    "pdf",
    "mermaid",
    "deck",
    "theme",
    "design-system",
    "slidewright"
  ],
  "homepage": "https://github.com/slidewright/lattice",
  "repository": {
    "type": "git",
    "url": "https://github.com/slidewright/lattice.git"
  },
  "bugs": {
    "url": "https://github.com/slidewright/lattice/issues"
  },
  "license": "MIT",
  "author": "SlideWright",
  "main": "lattice-emulator.js",
  "files": [
    "lattice-emulator.js",
    "lattice-runtime.js",
    "lattice.css",
    "themes/",
    "README.md",
    "SKILL.md",
    "THEMING.md",
    "EDITORIAL.md",
    "ARCHITECTURE.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build:gallery": "node lattice-emulator.js examples/gallery.md lattice.css examples/gallery.pdf",
    "build:mermaid": "node lattice-emulator.js examples/mermaid-gallery.md lattice.css examples/mermaid-gallery.pdf",
    "build": "npm run build:gallery && npm run build:mermaid",
    "test": "node --test test/unit",
    "test:integration": "node --test test/integration",
    "test:all": "node --test test/unit test/integration"
  },
  "dependencies": {
    "@marp-team/marp-cli": "^4.3.1",
    "@mermaid-js/mermaid-cli": "^11.0.0",
    "puppeteer": "^23.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
