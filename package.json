{
  "name": "@slidewright/lattice",
  "version": "1.0.0",
  "description": "A Marp-based slide deck system for boardroom-quality PDFs from Markdown. Author every slide as plain Markdown lists; render it as KaTeX math, gantt/kanban/roadmaps, all 25 Mermaid diagram types, native charts, and legal layouts — 58 layouts, one palette, WCAG AA throughout. Lattice is the engine layer of the SlideWright deck system.",
  "keywords": [
    "marp",
    "slides",
    "presentation",
    "markdown",
    "pdf",
    "mermaid",
    "deck",
    "theme",
    "design-system",
    "slidewright"
  ],
  "homepage": "https://github.com/slidewright/lattice",
  "repository": {
    "type": "git",
    "url": "https://github.com/slidewright/lattice.git"
  },
  "bugs": {
    "url": "https://github.com/slidewright/lattice/issues"
  },
  "license": "MIT",
  "author": "SlideWright",
  "main": "dist/lattice-emulator.js",
  "bin": {
    "lattice": "dist/lattice-emulator.js"
  },
  "exports": {
    ".": "./dist/lattice-emulator.js",
    "./min": "./dist/lattice-emulator.min.js",
    "./runtime": "./dist/lattice-runtime.js",
    "./runtime/min": "./dist/lattice-runtime.min.js",
    "./css": "./dist/lattice.css",
    "./css/min": "./dist/lattice.min.css",
    "./default": "./dist/lattice-default.css",
    "./default/min": "./dist/lattice-default.min.css",
    "./engine": "./lib/engine/index.js",
    "./themes/*": "./themes/*",
    "./lib/*": "./lib/*",
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "files": [
    "lattice-emulator.js",
    "mermaid-v11.min.js",
    "dist/",
    "lib/",
    "themes/",
    "design/skill.md",
    "design/design-system.md",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "!**/*.pdf",
    "!**/*.gallery.md"
  ],
  "scripts": {
    "build:gallery-jargon": "node lattice-emulator.js examples/gallery-jargon.md examples/gallery-jargon.pdf",
    "build": "node tools/build.js",
    "build:check": "node tools/build.js --check",
    "new:theme": "node tools/new-theme.js",
    "new:slide": "node tools/new-slide.js",
    "new:component": "node tools/new-component.js",
    "scorecard": "node tools/theme-scorecard.js",
    "scorecard:check": "node tools/theme-scorecard.js --check",
    "snippets:build": "node tools/build-snippets.js",
    "snippets:check": "node tools/build-snippets.js --check",
    "css:build": "node tools/build-css.js",
    "css:check": "node tools/build-css.js --check",
    "default:build": "node tools/build-default-bundle.js",
    "default:check": "node tools/build-default-bundle.js --check",
    "runtime:build": "node tools/build-runtime.js",
    "runtime:check": "node tools/build-runtime.js --check",
    "runtime:watch": "node tools/build-runtime.js --watch",
    "emulator:build": "node tools/build-emulator.js",
    "emulator:check": "node tools/build-emulator.js --check",
    "playground:build": "node tools/build-playground.js",
    "playground:check": "node tools/build-playground.js --check",
    "playground:watch": "node tools/build-playground.js --watch",
    "theme-core:build": "node tools/build-theme-core.js",
    "theme-core:check": "node tools/build-theme-core.js --check",
    "layout-core:build": "node tools/build-layout-core.js",
    "layout-core:check": "node tools/build-layout-core.js --check",
    "authoring-core:build": "node tools/build-authoring-core.js",
    "authoring-core:check": "node tools/build-authoring-core.js --check",
    "exemplar-core:build": "node tools/build-exemplar-core.js",
    "exemplar-core:check": "node tools/build-exemplar-core.js --check",
    "standalone-core:build": "node tools/build-standalone-core.js",
    "standalone-core:check": "node tools/build-standalone-core.js --check",
    "a11y-textures:build": "node tools/build-a11y-textures.js",
    "a11y-textures:check": "node tools/build-a11y-textures.js --check",
    "dist-readme:build": "node tools/build-dist-readme.js",
    "dist-readme:check": "node tools/build-dist-readme.js --check",
    "capabilities:build": "node tools/build-capabilities.js",
    "capabilities:check": "node tools/build-capabilities.js --check",
    "release": "node tools/release.js",
    "release:dry": "node tools/release.js --dry-run",
    "release:zip": "node tools/build-release-zip.js",
    "changelog:bump": "node tools/changelog.js --bump",
    "docs:components": "node tools/build-component-docs.js",
    "docs:components:check": "node tools/build-component-docs.js --check",
    "docs:portal": "node tools/build-docs-portal.js",
    "docs:portal:check": "node tools/build-docs-portal.js --check",
    "docs:forms": "node tools/build-forms.js",
    "docs:forms:check": "node tools/build-forms.js --check",
    "docs:concepts": "node tools/build-concepts.js",
    "docs:concepts:check": "node tools/build-concepts.js --check",
    "docs:landing-tokens": "node tools/build-landing-tokens.js",
    "docs:landing-tokens:check": "node tools/build-landing-tokens.js --check",
    "docs:spec": "node tools/build-spec-docs.js",
    "docs:spec:check": "node tools/build-spec-docs.js --check",
    "decisions:index": "node tools/build-decisions-index.js",
    "decisions:index:check": "node tools/build-decisions-index.js --check",
    "check:ownership": "node tools/check-ownership.js",
    "check:responsive": "node tools/check-chart-responsiveness.js",
    "fonts:check": "node tools/check-fonts.js",
    "build:galleries": "node tools/build-galleries.js",
    "build:galleries:check": "node tools/build-galleries.js --check",
    "build:bucket-galleries": "node tools/build-bucket-galleries.js",
    "build:bucket-galleries:check": "node tools/build-bucket-galleries.js --check",
    "build:exemplar-pdfs": "node tools/build-exemplar-pdfs.js",
    "preview": "node tools/preview.js",
    "preview:watch": "node tools/preview.js --watch",
    "test": "node --test 'test/unit/**/*.test.js'",
    "test:watch": "node --test --watch 'test/unit/**/*.test.js'",
    "bench": "node test/benchmark/engine-bench.mjs",
    "regress": "node tools/regression-gate.mjs",
    "bless": "node tools/regression-gate.mjs --bless",
    "test:coverage": "c8 node --test 'test/unit/**/*.test.js'",
    "test:coverage:all": "c8 node --test 'test/unit/**/*.test.js' 'test/integration/**/*.test.js'",
    "test:palette": "node --test 'test/unit/palette/*.test.js'",
    "test:mermaid": "node --test 'test/unit/mermaid/*.test.js'",
    "test:parsing": "node --test 'test/unit/parsing/*.test.js'",
    "test:components": "node --test 'test/unit/components/*.test.js'",
    "test:cli": "node --test 'test/unit/cli/*.test.js'",
    "test:docs": "node --test 'test/unit/docs/*.test.js'",
    "test:playground": "node --test 'test/unit/playground/*.test.js'",
    "test:engine": "node --test 'test/unit/engine/*.test.js'",
    "test:layout": "node --test 'test/unit/layout/*.test.js'",
    "test:transformers": "node --test 'test/unit/transformers/*.test.js'",
    "test:authoring": "node --test 'test/unit/authoring/*.test.js'",
    "test:contracts": "node --test 'test/unit/contracts/*.test.js'",
    "test:core": "node --test 'test/unit/core/*.test.js'",
    "test:export": "node --test 'test/unit/export/*.test.js'",
    "test:release": "node --test 'test/unit/release/*.test.js'",
    "test:tokens": "node --test 'test/unit/tokens/*.test.js'",
    "test:tools": "node --test 'test/unit/tools/*.test.js'",
    "test:integration": "node --test 'test/integration/**/*.test.js'",
    "test:integration:galleries": "node --test 'test/integration/galleries/*.test.js'",
    "test:integration:parity": "node --test 'test/integration/parity/*.test.js'",
    "test:integration:mermaid": "node --test 'test/integration/mermaid/*.test.js'",
    "test:integration:screenshot": "node --test 'test/integration/screenshot/*.test.js'",
    "test:integration:exemplars": "node --test 'test/integration/exemplars/*.test.js'",
    "test:all": "node --test 'test/unit/**/*.test.js' 'test/integration/**/*.test.js'",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "lint:deck": "node tools/lint-deck.js",
    "lint:deck:all": "node tools/lint-deck.js --all --strict",
    "export:marp": "node tools/export-marp.js",
    "sync:backlog": "node tools/sync-backlog.js",
    "sync:labels": "node tools/sync-labels.js",
    "clean:scratch": "find .scratch -mindepth 1 -mtime +14 -print -delete",
    "prepare": "lefthook install || true",
    "prepublishOnly": "npm test"
  },
  "dependencies": {
    "@mermaid-js/mermaid-cli": "^11.0.0",
    "function-plot": "^1.25.4",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.46",
    "markdown-it": "^14.1.1",
    "pdf-lib": "^1.17.1",
    "pptxgenjs": "^3.12.0",
    "puppeteer": "^23.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "c8": "^11.0.0",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1",
    "lefthook": "^2.1.6",
    "tinybench": "^6.0.2"
  }
}
