{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "includes": [
      "**/*.js",
      "**/*.mjs",
      "**/*.cjs",
      "**/*.json",
      "**/*.ts",
      "**/*.tsx",
      "!node_modules",
      "!dist",
      "!**/.astro",
      "!docs/.astro",
      "!docs/src/components/ui",
      "!docs/public/playground/lattice-playground.js",
      "!docs/src/playground/theme-core.generated.js",
      "!docs/src/playground/layout-core.generated.js",
      "!docs/src/playground/authoring-core.generated.js",
      "!docs/src/playground/exemplar-core.generated.js",
      "!docs/src/playground/standalone-svg.generated.js",
      "!docs/src/playground/a11y-textures.generated.js",
      "!**/*.min.js",
      "!mermaid-v11.min.js",
      "!examples/**/*.json",
      "!.scratch",
      "!package-lock.json",
      "!**/*.pdf"
    ]
  },
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noAssignInExpressions": "off"
      },
      "style": {
        "useTemplate": "off",
        "useNodejsImportProtocol": "off"
      },
      "complexity": {
        "noForEach": "off"
      },
      "performance": {
        "noDelete": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.test.js", "test/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    }
  ]
}
